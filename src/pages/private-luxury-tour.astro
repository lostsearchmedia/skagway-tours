---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout
  title="Private Luxury Tour"
  description="Private small-group luxury tours from Skagway, AK."
>
  <PageHero
    eyebrow="For groups of 6 or more"
    title="Private Luxury Tours"
    lead="Claim your own slice of the Klondike with a private small-group adventure designed just for you."
  />
  <section class="section">
    <div class="container prose">
      <p>
        Full details coming soon. To plan a private tour, call
        <a href="tel:9079214344">(907) 921-4344</a> or email
        <a href="mailto:info@skagway.tours">info@skagway.tours</a>.
      </p>
    </div>
  </section>
</BaseLayout>
