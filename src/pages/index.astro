---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import TourCard from "../components/TourCard.astro";
import NoPassportPopup from "../components/NoPassportPopup.astro";
import { getCollection, getEntry } from "astro:content";

const tours = (await getCollection("tours", (e) => !e.data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const site = await getEntry("site", "default");
const passportNote = site?.data.passport_note;

const home = await getEntry("pages", "index");
if (!home || home.data._schema !== "home") {
  throw new Error("src/content/pages/index.md must exist with _schema: home");
}
const d = home.data;
const toursSection = d.tours_section;
const intro = d.intro_section;
const gallery = d.gallery_section;
const fullBleed = d.full_bleed;

const galleryImages = gallery?.images ?? [];
const galleryTrack = galleryImages.length
  ? [...galleryImages, ...galleryImages]
  : [];
---

<BaseLayout transparentHeader title={d.title} description={d.description} seo={d.seo}>
  <Hero />

  <!-- Passport call-out note above tours (edited in Site settings) -->
  {
    passportNote && (
      <section class="passport-note">
        <div class="container passport-note__inner">
          <svg aria-hidden="true" viewBox="0 0 24 24" width="28" height="28">
            <rect x="5" y="3" width="14" height="18" rx="2" fill="#dd5154" />
            <circle cx="12" cy="10" r="3" fill="#fff" />
            <rect x="8" y="15" width="8" height="1.5" fill="#fff" />
            <rect x="8" y="17" width="8" height="1.5" fill="#fff" />
          </svg>
          <p data-editable="text" data-prop="@data[default].passport_note">{passportNote}</p>
          <a href="/passport-requirements/">Requirements →</a>
        </div>
      </section>
    )
  }

  <!-- Intro: sensory brand promise -->
  {
    intro && (
      <section class="section intro">
        <div class="container intro__inner">
          <span
            class="script script--accent intro__script"
            data-editable="text"
            data-prop="intro_section.eyebrow"
          >
            {intro.eyebrow}
          </span>
          <h2
            class="intro__title"
            data-editable="text"
            data-prop="intro_section.title"
          >
            {intro.title}
          </h2>
          {intro.body && (
            <p
              class="intro__body"
              data-editable="text"
              data-prop="intro_section.body"
            >
              {intro.body}
            </p>
          )}
        </div>
      </section>
    )
  }

  <!-- Tours section -->
  <section id="tours" class="section tours-section">
    <div class="container">
      <div class="section__head">
        <span class="script script--accent section__script" data-editable="text" data-prop="tours_section.eyebrow">
          {toursSection.eyebrow}
        </span>
        <h2 data-editable="text" data-prop="tours_section.title">{toursSection.title}</h2>
      </div>

      {
        tours.length === 0 ? (
          <p class="muted">{toursSection.empty_message}</p>
        ) : (
          <div class="grid grid--tours">
            {tours.map((tour) => (
              <TourCard
                slug={tour.id}
                title={tour.data.title}
                summary={tour.data.summary}
                image={tour.data.featured_image}
                duration={tour.data.duration_hours}
                priceFrom={tour.data.price_from}
                priceChild={tour.data.price_child}
                videoUrl={tour.data.video_url}
                fareharborItemId={tour.data.fareharbor_item_id}
                featured={tour.id === "private-luxury-tours" || tour.id === "group-sales"}
                featuredColor={tour.id === "group-sales" ? "#DD5154" : "#292546"}
                featuredIcon={tour.id === "group-sales" ? "group" : "luxury"}
              />
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- Gallery marquee: 9×1:1 desktop, 3×1:1 mobile, infinite smooth loop -->
  {
    galleryTrack.length > 0 && (
      <section class="gallery-marquee" aria-label="Tour photo gallery">
        {gallery.eyebrow && (
          <div class="gallery-marquee__head container">
            <span
              class="script script--accent gallery-marquee__script"
              data-editable="text"
              data-prop="gallery_section.eyebrow"
            >
              {gallery.eyebrow}
            </span>
            {gallery.title && (
              <h2
                class="gallery-marquee__title"
                data-editable="text"
                data-prop="gallery_section.title"
              >
                {gallery.title}
              </h2>
            )}
          </div>
        )}

        <div class="gallery-marquee__viewport">
          <div class="gallery-marquee__track">
            {galleryTrack.map((src, i) => (
              <div
                class="gallery-marquee__item"
                aria-hidden={i >= galleryImages.length ? "true" : undefined}
              >
                <img src={src} alt="" loading="lazy" />
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Why travel with us -->
  <section class="section why-us">
    <div class="container">
      <div class="why-us__head">
        <span class="script why-us__script">Why travel with us</span>
        <h2 class="why-us__heading">We work hard.<br />We love our guests.</h2>
      </div>

      <div class="why-us__grid">
        <article class="why-us__item">
          <svg viewBox="0 0 40 40" width="40" height="40" aria-hidden="true">
            <circle cx="20" cy="20" r="15" fill="none" stroke="currentColor" stroke-width="2" />
            <path d="M20 10 V20 L27 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          <h3>Never missed a ship — ever</h3>
          <p>In 13 years of business, we have never missed a ship. Every tour is scheduled to return 45+ minutes before all-aboard time. Watch the scenery, not the clock.</p>
        </article>

        <article class="why-us__item">
          <svg viewBox="0 0 40 40" width="40" height="40" aria-hidden="true">
            <circle cx="14" cy="14" r="5" fill="none" stroke="currentColor" stroke-width="2"/>
            <circle cx="26" cy="14" r="5" fill="none" stroke="currentColor" stroke-width="2"/>
            <circle cx="8" cy="26" r="4" fill="none" stroke="currentColor" stroke-width="2"/>
            <circle cx="20" cy="28" r="4" fill="none" stroke="currentColor" stroke-width="2"/>
            <circle cx="32" cy="26" r="4" fill="none" stroke="currentColor" stroke-width="2"/>
          </svg>
          <h3>Every group size welcome</h3>
          <p>Families, solo travelers, cruise charters, corporate retreats — we have tours and rates for all. Special discounts for groups of 6 or more. Pickup at your ship or in town.</p>
        </article>

        <article class="why-us__item">
          <svg viewBox="0 0 40 40" width="40" height="40" aria-hidden="true">
            <path d="M20 6 L24 16 L34 16 L26 22 L29 32 L20 26 L11 32 L14 22 L6 16 L16 16 Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
          </svg>
          <h3>Expert local guides</h3>
          <p>Our driver-guides are dedicated to giving a fun, engaging, and informative tour every time. They know the land, the history, and exactly where to pull over for the best views.</p>
        </article>

        <article class="why-us__item">
          <svg viewBox="0 0 40 40" width="40" height="40" aria-hidden="true">
            <path d="M20 5 L23.5 15 L34 15 L25.5 21 L29 31 L20 25 L11 31 L14.5 21 L6 15 L16.5 15 Z" fill="currentColor" />
          </svg>
          <h3>1,000+ five-star reviews</h3>
          <p>Top rated on TripAdvisor and Google, year after year. Our guests keep coming back — and telling their friends. We give tours people never forget.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Full-screen image moment -->
  {
    fullBleed && fullBleed.image && (
      <section
        class="full-bleed"
        style={`background-image: linear-gradient(rgba(41,37,70,0.55), rgba(41,37,70,0.72)), url('${fullBleed.image}');`}
      >
        <div class="container full-bleed__inner">
          {fullBleed.eyebrow && (
            <span
              class="script script--accent full-bleed__script"
              data-editable="text"
              data-prop="full_bleed.eyebrow"
            >
              {fullBleed.eyebrow}
            </span>
          )}
          {fullBleed.title && (
            <p
              class="splash-heading full-bleed__heading"
              data-editable="text"
              data-prop="full_bleed.title"
            >
              {fullBleed.title}
            </p>
          )}
          {fullBleed.body && (
            <p
              class="full-bleed__lead"
              data-editable="text"
              data-prop="full_bleed.body"
            >
              {fullBleed.body}
            </p>
          )}
          {fullBleed.cta_label && fullBleed.cta_href && (
            <a href={fullBleed.cta_href} class="button button--white full-bleed__cta">
              {fullBleed.cta_label}
            </a>
          )}
        </div>
        <div class="full-bleed__scroll" aria-hidden="true">
          <span>Keep going</span>
          <svg viewBox="0 0 24 24" width="18" height="18">
            <path d="M6 9 L12 15 L18 9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
      </section>
    )
  }

  <!-- Callouts -->
  <section class="callouts section">
    <div class="container">
      <div class="callouts__grid" data-editable="array" data-prop="callouts">
        {
          d.callouts.map((c, index) => (
            <article
              class:list={["callout", c.variant === "primary" && "callout--primary"]}
              data-editable="array-item"
            >
              {c.eyebrow && (
                <span class="eyebrow" data-editable="text" data-prop={`callouts[${index}].eyebrow`}>
                  {c.eyebrow}
                </span>
              )}
              <h3 data-editable="text" data-prop={`callouts[${index}].title`}>{c.title}</h3>
              {c.body && (
                <p data-editable="text" data-prop={`callouts[${index}].body`}>{c.body}</p>
              )}
              {c.cta_label && c.cta_href && (
                <a href={c.cta_href} class:list={["", c.variant === "primary" && "button"]}>
                  {c.cta_label}
                </a>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Reviews CTA -->
  {
    d.reviews_cta && (
      <section class="section reviews-cta section--dark">
        <div class="container reviews-cta__inner">
          <div>
            {d.reviews_cta.eyebrow && (
              <span class="eyebrow" data-editable="text" data-prop="reviews_cta.eyebrow">
                {d.reviews_cta.eyebrow}
              </span>
            )}
            <h2 data-editable="text" data-prop="reviews_cta.title">{d.reviews_cta.title}</h2>
            {d.reviews_cta.lead && (
              <p data-editable="text" data-prop="reviews_cta.lead">{d.reviews_cta.lead}</p>
            )}
          </div>
          <a href={d.reviews_cta.cta_href} class="button">{d.reviews_cta.cta_label}</a>
        </div>
      </section>
    )
  }

  <NoPassportPopup />
</BaseLayout>

<style>
  /* --- Passport strip ---------------------------------------------- */
  .passport-note {
    background: var(--c-paper-soft);
    border-top: 1px solid var(--c-fog);
    border-bottom: 1px solid var(--c-fog);
    padding: 0.9rem 0;
  }
  .passport-note__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .passport-note p { margin: 0; flex: 1; min-width: 0; }
  @media (max-width: 640px) {
    .passport-note__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .passport-note__inner svg { display: none; }
  }

  /* --- Intro section ----------------------------------------------- */
  .intro {
    background: #fff;
    padding-block: clamp(3rem, 6vw, 5rem);
  }
  .intro__inner {
    max-width: 62ch;
    text-align: center;
  }
  .intro__script {
    display: block;
    font-size: 2rem;
    color: var(--c-ember);
    margin-bottom: 0.25rem;
  }
  .intro__title {
    font-size: clamp(1.75rem, 3vw + 1rem, 2.75rem);
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin: 0 0 1.25rem;
    color: var(--c-ink);
  }
  .intro__body {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--c-ink-soft);
  }

  /* --- Tours section ----------------------------------------------- */
  .tours-section {
    background-image:
      linear-gradient(rgba(255,255,255,0.5), rgba(255,255,255,0.5)),
      url('https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp/skagway.tours/wp-content/uploads/2026/02/skagway-bg.jpg');
    background-size: cover;
    background-position: center;
    border-top: 1px solid #d6e1e6;
  }
  .section__head {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section__script {
    display: block;
    font-size: 2rem;
    margin-bottom: -0.25rem;
  }
  .muted { color: var(--c-ink-soft); text-align: center; }

  /* --- Gallery marquee --------------------------------------------- */
  .gallery-marquee {
    background: var(--c-paper-soft);
    padding-block: clamp(2.5rem, 5vw, 4rem);
    overflow: hidden;
  }
  .gallery-marquee__head {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .gallery-marquee__script {
    display: block;
    font-size: 2rem;
    color: var(--c-ember);
  }
  .gallery-marquee__title {
    margin: 0.25rem 0 0;
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
    text-transform: uppercase;
  }
  .gallery-marquee__viewport {
    width: 100%;
    overflow: hidden;
    /* Soft edge fade so items enter/exit gracefully */
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 6%,
      #000 94%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 6%,
      #000 94%,
      transparent
    );
  }
  .gallery-marquee__track {
    display: flex;
    gap: 0.5rem;
    width: max-content;
    animation: gallery-marquee 60s linear infinite;
    will-change: transform;
  }
  .gallery-marquee:hover .gallery-marquee__track {
    animation-play-state: paused;
  }
  @keyframes gallery-marquee {
    from { transform: translate3d(0, 0, 0); }
    to { transform: translate3d(-50%, 0, 0); }
  }
  .gallery-marquee__item {
    flex: 0 0 calc((100vw - 5rem) / 9);
    aspect-ratio: 1 / 1;
    border-radius: 14px;
    overflow: hidden;
    background: var(--c-fog);
  }
  .gallery-marquee__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (max-width: 760px) {
    .gallery-marquee__item {
      flex: 0 0 calc((100vw - 2rem) / 3);
      border-radius: 10px;
    }
    .gallery-marquee__track {
      animation-duration: 45s;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .gallery-marquee__track { animation: none; }
  }

  /* --- Why us ------------------------------------------------------ */
  .why-us {
    background: #fff;
  }
  .why-us__head {
    text-align: center;
    margin-bottom: 3rem;
  }
  .why-us__script {
    font-size: 2rem;
    color: var(--c-ember);
    display: block;
    margin-bottom: 0.5rem;
  }
  .why-us__heading {
    font-size: clamp(2rem, 4vw + 1rem, 3.5rem);
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin: 0;
    color: var(--c-ink);
  }
  .why-us__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }
  .why-us__item {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .why-us__item svg { color: var(--c-ember); }
  .why-us__item h3 { font-size: 1.1rem; margin: 0; color: var(--c-ink); }
  .why-us__item p { margin: 0; font-size: 0.95rem; color: var(--c-ink-soft); }

  /* --- Full-bleed image moment ------------------------------------- */
  .full-bleed {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: grid;
    place-items: center;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: var(--c-paper);
    padding: clamp(4rem, 10vh, 8rem) 1.25rem;
    overflow: hidden;
  }
  .full-bleed__inner {
    text-align: center;
    max-width: 52ch;
  }
  .full-bleed__script {
    display: block;
    font-size: clamp(2rem, 3vw + 1rem, 2.75rem);
    color: var(--c-ember-bright, #ff8a5b);
    margin-bottom: 0.25rem;
  }
  .full-bleed__heading {
    white-space: normal;
    color: var(--c-paper);
    margin: 0;
    font-size: clamp(3rem, 8vw + 1rem, 7rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
  }
  .full-bleed__lead {
    margin: 1.75rem auto 0;
    color: rgba(246,241,231,0.9);
    font-size: 1.1rem;
    line-height: 1.6;
  }
  .full-bleed__cta {
    margin-top: 2rem;
  }
  .full-bleed__scroll {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: rgba(246,241,231,0.75);
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    animation: full-bleed-bounce 2.4s ease-in-out infinite;
  }
  @keyframes full-bleed-bounce {
    0%, 100% { transform: translate(-50%, 0); opacity: 0.75; }
    50%      { transform: translate(-50%, 6px); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .full-bleed__scroll { animation: none; }
  }

  /* --- Callouts ---------------------------------------------------- */
  .callouts__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 1.5rem;
  }
  @media (max-width: 880px) {
    .callouts__grid { grid-template-columns: 1fr; }
  }
  .callout {
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 16px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .callout--primary {
    background: var(--c-ink);
    color: var(--c-paper);
    border-color: var(--c-ink);
  }
  .callout--primary .eyebrow { color: var(--c-ember-bright); }
  .callout h3 { color: inherit; }
  .callout p { margin: 0 0 1rem; opacity: 0.9; }
  .callout a { align-self: flex-start; margin-top: auto; }

  /* --- Reviews CTA ------------------------------------------------- */
  .reviews-cta__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .reviews-cta__inner h2 { margin: 0.25rem 0; }
</style>
