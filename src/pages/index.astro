---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import TourCard from "../components/TourCard.astro";
import NoPassportPopup from "../components/NoPassportPopup.astro";
import { getCollection, getEntry } from "astro:content";

const tours = (await getCollection("tours", (e) => !e.data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const site = await getEntry("site", "default");
const passportNote = site?.data.passport_note;

const home = await getEntry("pages", "index");
if (!home || home.data._schema !== "home") {
  throw new Error("src/content/pages/index.md must exist with _schema: home");
}
const d = home.data;
const toursSection = d.tours_section;
---

<BaseLayout transparentHeader title={d.title} description={d.description} seo={d.seo}>
  <Hero />

  <!-- Passport call-out note above tours (edited in Site settings) -->
  {
    passportNote && (
      <section class="passport-note">
        <div class="container passport-note__inner">
          <svg aria-hidden="true" viewBox="0 0 24 24" width="28" height="28">
            <rect x="5" y="3" width="14" height="18" rx="2" fill="#dd5154" />
            <circle cx="12" cy="10" r="3" fill="#fff" />
            <rect x="8" y="15" width="8" height="1.5" fill="#fff" />
            <rect x="8" y="17" width="8" height="1.5" fill="#fff" />
          </svg>
          <p data-editable="text" data-prop="@data[default].passport_note">{passportNote}</p>
          <a href="/passport-requirements/">Requirements →</a>
        </div>
      </section>
    )
  }

  <!-- Tours section -->
  <section id="tours" class="section tours-section">
    <div class="container">
      <div class="section__head">
        <span class="script script--accent section__script" data-editable="text" data-prop="tours_section.eyebrow">
          {toursSection.eyebrow}
        </span>
        <h2 data-editable="text" data-prop="tours_section.title">{toursSection.title}</h2>
      </div>

      {
        tours.length === 0 ? (
          <p class="muted">{toursSection.empty_message}</p>
        ) : (
          <div class="grid grid--tours">
            {tours.map((tour) => (
              <TourCard
                slug={tour.id}
                title={tour.data.title}
                summary={tour.data.summary}
                image={tour.data.featured_image}
                duration={tour.data.duration_hours}
                priceFrom={tour.data.price_from}
                videoUrl={tour.data.video_url}
                fareharborItemId={tour.data.fareharbor_item_id}
              />
            ))}

            <TourCard
              href="/group-sales/"
              eyebrow="Groups of 14+"
              title="Group Tours"
              summary="Private tours and charters for groups up to 160. Choose from tailored buses, custom itineraries, and narrated adventures along the Klondike Highway."
              imageSrc="https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2025/09/buses_2.jpg"
              priceLabel="Call for"
              priceValue="Quote"
              inquiry
            />

            <TourCard
              href="/private-luxury-tour/"
              eyebrow="Groups of 6–13"
              title="Private Luxury Tour"
              summary="Claim your own slice of the Klondike. Your vehicle, your guide, your day — a private small-group adventure designed just for you."
              imageSrc="https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2026/03/Limo.jpg"
              priceLabel="Call for"
              priceValue="Quote"
              inquiry
            />
          </div>
        )
      }
    </div>
  </section>

  <!-- Why travel with us — moss-green block -->
  <section class="section section--moss why-us">
    <div class="container">
      <div class="why-us__head">
        <span class="script why-us__script">Why travel with us</span>
        <h2 class="why-us__heading">Small groups.<br />Big stories.</h2>
      </div>

      <div class="why-us__grid">
        <article class="why-us__item">
          <svg viewBox="0 0 40 40" width="40" height="40" aria-hidden="true">
            <rect x="4" y="13" width="26" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="2" />
            <rect x="26" y="17" width="8" height="10" rx="1" fill="none" stroke="currentColor" stroke-width="2" />
            <circle cx="10" cy="29" r="3" fill="none" stroke="currentColor" stroke-width="2" />
            <circle cx="28" cy="29" r="3" fill="none" stroke="currentColor" stroke-width="2" />
            <path d="M7 13 L11 16 M11 13 L15 16 M15 13 L19 16 M19 13 L23 16" stroke="currentColor" stroke-width="1.5" opacity="0.5" />
          </svg>
          <h3>13-passenger vans</h3>
          <p>No packed coach buses. You're our guest for the day, not just a seat number.</p>
        </article>

        <article class="why-us__item">
          <svg viewBox="0 0 40 40" width="40" height="40" aria-hidden="true">
            <path d="M20 6 L24 16 L34 16 L26 22 L29 32 L20 26 L11 32 L14 22 L6 16 L16 16 Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
          </svg>
          <h3>Local guides</h3>
          <p>Alaskan and Yukon locals who know the stories the guidebooks never got around to printing.</p>
        </article>

        <article class="why-us__item">
          <svg viewBox="0 0 40 40" width="40" height="40" aria-hidden="true">
            <circle cx="20" cy="20" r="15" fill="none" stroke="currentColor" stroke-width="2" />
            <path d="M20 10 V20 L27 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          <h3>All Aboard guarantee</h3>
          <p>We run on ship time and have never missed a departure. Watch the view, not the clock.</p>
        </article>

        <article class="why-us__item">
          <svg viewBox="0 0 40 40" width="40" height="40" aria-hidden="true">
            <path d="M20 5 L23.5 15 L34 15 L25.5 21 L29 31 L20 25 L11 31 L14.5 21 L6 15 L16.5 15 Z" fill="currentColor" />
          </svg>
          <h3>3,000+ five-star reviews</h3>
          <p>Year after year, cruise guests and families keep choosing us for their Skagway day out.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Feature cards — Families / Private Groups -->
  <section class="section section--paper-soft feature-cards-section">
    <div class="container">
      <div class="feature-cards-grid">
        <article class="feature-card feature-card--sky">
          <span class="script script--accent feature-card__script">For families</span>
          <h3 class="feature-card__title">Great with kids</h3>
          <p>Most tours are Easy-rated and perfect for families. Kids 2–11 get a discounted rate and infants under 2 ride free.</p>
          <a href="/#tours" class="button button--dark">Browse tours</a>
        </article>

        <article class="feature-card feature-card--sun">
          <span class="script script--moss feature-card__script">Private groups</span>
          <h3 class="feature-card__title">Your day, your way</h3>
          <p>Charter the whole 13-passenger van for your group. Custom routes, your pacing, our local guide.</p>
          <a href="/private-group/" class="button button--dark">Plan a private tour</a>
        </article>
      </div>
    </div>
  </section>

  <!-- Splash heading — oversized bleed type -->
  <section class="section splash-section">
    <div class="container splash-section__inner">
      <span class="script script--accent splash-section__script">Skagway · Yukon</span>
      <p class="splash-heading splash-section__heading">Built for<br />the Klondike</p>
      <p class="splash-section__lead">Every tour crosses the White Pass into Canada — where the Gold Rush story still runs in the rivers and the road.</p>
    </div>
  </section>

  <!-- Callouts -->
  <section class="callouts section">
    <div class="container">
      <div class="callouts__grid" data-editable="array" data-prop="callouts">
        {
          d.callouts.map((c, index) => (
            <article
              class:list={["callout", c.variant === "primary" && "callout--primary"]}
              data-editable="array-item"
            >
              {c.eyebrow && (
                <span class="eyebrow" data-editable="text" data-prop={`callouts[${index}].eyebrow`}>
                  {c.eyebrow}
                </span>
              )}
              <h3 data-editable="text" data-prop={`callouts[${index}].title`}>{c.title}</h3>
              {c.body && (
                <p data-editable="text" data-prop={`callouts[${index}].body`}>{c.body}</p>
              )}
              {c.cta_label && c.cta_href && (
                <a href={c.cta_href} class:list={["", c.variant === "primary" && "button"]}>
                  {c.cta_label}
                </a>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Reviews CTA -->
  {
    d.reviews_cta && (
      <section class="section reviews-cta section--dark">
        <div class="container reviews-cta__inner">
          <div>
            {d.reviews_cta.eyebrow && (
              <span class="eyebrow" data-editable="text" data-prop="reviews_cta.eyebrow">
                {d.reviews_cta.eyebrow}
              </span>
            )}
            <h2 data-editable="text" data-prop="reviews_cta.title">{d.reviews_cta.title}</h2>
            {d.reviews_cta.lead && (
              <p data-editable="text" data-prop="reviews_cta.lead">{d.reviews_cta.lead}</p>
            )}
          </div>
          <a href={d.reviews_cta.cta_href} class="button">{d.reviews_cta.cta_label}</a>
        </div>
      </section>
    )
  }

  <NoPassportPopup />
</BaseLayout>

<style>
  .passport-note {
    background: var(--c-paper-soft);
    border-top: 1px solid var(--c-fog);
    border-bottom: 1px solid var(--c-fog);
    padding: 0.9rem 0;
  }
  .passport-note__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .passport-note p { margin: 0; flex: 1; min-width: 0; }

  /* --- Why us (moss-green block) ----------------------------------- */
  .why-us__head {
    text-align: center;
    margin-bottom: 3rem;
  }
  .why-us__script {
    font-size: 2rem;
    color: var(--c-sun-soft);
    display: block;
    margin-bottom: 0.5rem;
  }
  .why-us__heading {
    font-size: clamp(2rem, 4vw + 1rem, 3.5rem);
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin: 0;
    color: var(--c-paper);
  }
  .why-us__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }
  .why-us__item {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .why-us__item svg {
    color: var(--c-sun-soft);
  }
  .why-us__item h3 {
    font-size: 1.1rem;
    margin: 0;
    color: var(--c-paper);
  }
  .why-us__item p {
    margin: 0;
    font-size: 0.95rem;
    opacity: 0.85;
  }

  /* --- Tours section ------------------------------------------------ */
  .tours-section {
    background: #eaf1f4;
    border-top: 1px solid #d6e1e6;
  }
  .section__head {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section__script {
    display: block;
    font-size: 2rem;
    margin-bottom: -0.25rem;
  }
  .muted { color: var(--c-ink-soft); text-align: center; }

  /* --- Feature cards (Families / Private Groups) -------------------- */
  .feature-cards-section { padding-block: clamp(3rem, 5vw, 5rem); }
  .feature-cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  @media (max-width: 760px) {
    .feature-cards-grid { grid-template-columns: 1fr; }
  }
  .feature-card {
    padding: 2rem;
    gap: 0.5rem;
  }
  .feature-card__script {
    font-size: 1.75rem;
    margin-bottom: -0.25rem;
  }
  .feature-card__title {
    font-size: clamp(1.5rem, 2vw + 0.5rem, 2.25rem);
    color: var(--c-ink);
  }
  .feature-card p {
    margin: 0 0 1.25rem;
    color: var(--c-ink);
    opacity: 0.85;
  }
  .feature-card a.button { align-self: flex-start; }

  /* --- Splash heading ----------------------------------------------- */
  .splash-section {
    background: var(--c-paper);
    overflow: hidden;
    padding-block: clamp(4rem, 8vw, 8rem);
  }
  .splash-section__inner {
    text-align: center;
    position: relative;
  }
  .splash-section__script {
    display: block;
    font-size: 2.25rem;
    color: var(--c-ember);
    margin-bottom: 0.25rem;
  }
  .splash-section__heading {
    white-space: normal;
    color: var(--c-ink);
    margin: 0;
  }
  .splash-section__lead {
    max-width: 48ch;
    margin: 1.5rem auto 0;
    color: var(--c-ink-soft);
    font-size: 1.1rem;
  }

  /* --- Callouts ----------------------------------------------------- */
  .callouts__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 1.5rem;
  }
  @media (max-width: 880px) {
    .callouts__grid { grid-template-columns: 1fr; }
  }
  .callout {
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 16px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .callout--primary {
    background: var(--c-ink);
    color: var(--c-paper);
    border-color: var(--c-ink);
  }
  .callout--primary .eyebrow { color: var(--c-ember-bright); }
  .callout h3 { color: inherit; }
  .callout p { margin: 0 0 1rem; opacity: 0.9; }
  .callout a { align-self: flex-start; margin-top: auto; }

  /* --- Reviews CTA -------------------------------------------------- */
  .reviews-cta__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .reviews-cta__inner h2 { margin: 0.25rem 0; }
</style>
