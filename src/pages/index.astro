---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import TourCard from "../components/TourCard.astro";
import NoPassportPopup from "../components/NoPassportPopup.astro";
import { Icon } from "astro-icon/components";
import { getCollection, getEntry } from "astro:content";

const tours = (await getCollection("tours", (e) => !e.data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const site = await getEntry("site", "default");
const passportNote = site?.data.passport_note;

const home = await getEntry("pages", "index");
if (!home || home.data._schema !== "home") {
  throw new Error("src/content/pages/index.md must exist with _schema: home");
}
const d = home.data;
const toursSection = d.tours_section;
const intro = d.intro_section;
const gallery = d.gallery_section;
const fullBleed = d.full_bleed;

const GALLERY_FALLBACK = "https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2024/02/st_wide.jpg";
// 20 identical copies — animating exactly 1 item width per loop makes the reset invisible
const galleryTrack = Array.from({ length: 20 }, () => GALLERY_FALLBACK);
---

<BaseLayout transparentHeader title={d.title} description={d.description} seo={d.seo}>
  <Hero />

  <!-- Passport call-out note above tours (edited in Site settings) -->
  {
    passportNote && (
      <section class="passport-note">
        <div class="container passport-note__inner">
          <svg aria-hidden="true" viewBox="0 0 24 24" width="28" height="28">
            <rect x="5" y="3" width="14" height="18" rx="2" fill="#dd5154" />
            <circle cx="12" cy="10" r="3" fill="#fff" />
            <rect x="8" y="15" width="8" height="1.5" fill="#fff" />
            <rect x="8" y="17" width="8" height="1.5" fill="#fff" />
          </svg>
          <p data-editable="text" data-prop="@data[default].passport_note">{passportNote}</p>
          <a href="/passport-requirements/">Requirements →</a>
        </div>
      </section>
    )
  }

  <!-- Tours section -->
  <section id="tours" class="section tours-section">
    <div class="container">
      <div class="section__head">
        <span class="script script--accent section__script" data-editable="text" data-prop="tours_section.eyebrow">
          {toursSection.eyebrow}
        </span>
        <h2 data-editable="text" data-prop="tours_section.title">{toursSection.title}</h2>
      </div>

      {
        tours.length === 0 ? (
          <p class="muted">{toursSection.empty_message}</p>
        ) : (
          <div class="grid grid--tours">
            {tours.map((tour) => (
              <TourCard
                slug={tour.id}
                title={tour.data.title}
                summary={tour.data.summary}
                image={tour.data.featured_image}
                duration={tour.data.duration_hours}
                priceFrom={tour.data.price_from}
                priceChild={tour.data.price_child}
                videoUrl={tour.data.video_url}
                fareharborItemId={tour.data.fareharbor_item_id}
                featured={tour.id === "private-luxury-tours" || tour.id === "group-sales"}
                featuredColor={tour.id === "group-sales" ? "#DD5154" : "#292546"}
                featuredIcon={tour.id === "group-sales" ? "group" : "luxury"}
              />
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- Gallery marquee: 9×1:1 desktop, 3×1:1 mobile, infinite smooth loop -->
  {
    galleryTrack.length > 0 && (
      <section class="gallery-marquee" aria-label="Tour photo gallery">
        <div class="gallery-marquee__head container">
          {gallery.eyebrow && (
            <span
              class="script script--accent gallery-marquee__script"
              data-editable="text"
              data-prop="gallery_section.eyebrow"
            >
              {gallery.eyebrow}
            </span>
          )}
          {gallery.title && (
            <h2
              class="gallery-marquee__title"
              data-editable="text"
              data-prop="gallery_section.title"
            >
              {gallery.title}
            </h2>
          )}
          {gallery.body && (
            <p
              class="gallery-marquee__body"
              data-editable="text"
              data-prop="gallery_section.body"
            >
              {gallery.body}
            </p>
          )}
        </div>

        <div class="gallery-marquee__viewport">
          <div class="gallery-marquee__track">
            {galleryTrack.map((src, i) => (
              <div
                class="gallery-marquee__item"
                data-gallery-index={i}
                role="button"
                tabindex="0"
                aria-label={`Open photo ${i + 1}`}
              >
                <img src={src} alt="" loading="eager" />
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Why travel with us -->
  <section class="section why-us">
    <div class="container">
      <div class="why-us__head">
        <span class="script why-us__script">Why travel with us</span>
        <h2 class="why-us__heading">We work hard.<br />We love our guests.</h2>
      </div>

      <div class="why-us__grid">
        <article class="why-us__item">
          <Icon name="ph:clock-fill" class="why-us__icon" aria-hidden="true" />
          <h3>Never missed a ship — ever</h3>
          <p>In 13 years of business, we have never missed a ship. Every tour is scheduled to return 45+ minutes before all-aboard time. Watch the scenery, not the clock.</p>
        </article>

        <article class="why-us__item">
          <Icon name="ph:users-three-fill" class="why-us__icon" aria-hidden="true" />
          <h3>Every group size welcome</h3>
          <p>Families, solo travelers, cruise charters, corporate retreats — we have tours and rates for all. Special discounts for groups of 6 or more. Pickup at your ship or in town.</p>
        </article>

        <article class="why-us__item">
          <Icon name="ph:map-trifold-fill" class="why-us__icon" aria-hidden="true" />
          <h3>Expert local guides</h3>
          <p>Our driver-guides are dedicated to giving a fun, engaging, and informative tour every time. They know the land, the history, and exactly where to pull over for the best views.</p>
        </article>

        <article class="why-us__item">
          <Icon name="ph:star-fill" class="why-us__icon" aria-hidden="true" />
          <h3>1,000+ five-star reviews</h3>
          <p>Top rated on TripAdvisor and Google, year after year. Our guests keep coming back — and telling their friends. We give tours people never forget.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Guest reviews (Elfsight Google Reviews) - immersive dark overlay -->
  <section
    class="section home-reviews"
    style={`background-image: linear-gradient(rgba(31,28,57,0.82), rgba(41,37,70,0.86)), url('https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2024/02/st_wide.jpg');`}
  >
    <div class="container">
      <div class="section__head">
        <span class="script script--accent section__script">What guests say</span>
        <h2 class="home-reviews__heading">Real stories from the road.</h2>
      </div>
      <div class="home-reviews__widget">
        <script src="https://elfsightcdn.com/platform.js" async is:inline></script>
        <div class="elfsight-app-be8882ad-c2f2-4122-a216-f1f1f2793578" data-elfsight-app-lazy></div>
      </div>
    </div>
  </section>

  <!-- Klondike callout — white section with image-filled headline -->
  {
    fullBleed && fullBleed.image && (
      <section class="section klondike">
        <div class="container klondike__inner">
          {fullBleed.eyebrow && (
            <span
              class="script script--accent klondike__script"
              data-editable="text"
              data-prop="full_bleed.eyebrow"
            >
              {fullBleed.eyebrow}
            </span>
          )}
          {fullBleed.title && (
            <p
              class="splash-heading klondike__heading"
              style={`background-image: url('${fullBleed.image}');`}
              data-editable="text"
              data-prop="full_bleed.title"
            >
              {fullBleed.title}
            </p>
          )}
          {fullBleed.body && (
            <p
              class="klondike__lead"
              data-editable="text"
              data-prop="full_bleed.body"
            >
              {fullBleed.body}
            </p>
          )}
          {fullBleed.cta_label && fullBleed.cta_href && (
            <a href={fullBleed.cta_href} class="button button--dark klondike__cta">
              {fullBleed.cta_label}
            </a>
          )}
        </div>
      </section>
    )
  }

  <!-- Callouts -->
  <section class="callouts section">
    <div class="container">
      <div class="callouts__grid" data-editable="array" data-prop="callouts">
        {
          d.callouts.map((c, index) => (
            <article
              class:list={["callout", c.variant === "primary" && "callout--primary"]}
              data-editable="array-item"
            >
              {c.eyebrow && (
                <span class="eyebrow" data-editable="text" data-prop={`callouts[${index}].eyebrow`}>
                  {c.eyebrow}
                </span>
              )}
              <h3 data-editable="text" data-prop={`callouts[${index}].title`}>{c.title}</h3>
              {c.body && (
                <p data-editable="text" data-prop={`callouts[${index}].body`}>{c.body}</p>
              )}
              {c.cta_label && c.cta_href && (
                <a href={c.cta_href} class:list={["", c.variant === "primary" && "button"]}>
                  {c.cta_label}
                </a>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Reviews CTA -->
  {
    d.reviews_cta && (
      <section class="section reviews-cta section--dark">
        <div class="container reviews-cta__inner">
          <div>
            {d.reviews_cta.eyebrow && (
              <span class="eyebrow" data-editable="text" data-prop="reviews_cta.eyebrow">
                {d.reviews_cta.eyebrow}
              </span>
            )}
            <h2 data-editable="text" data-prop="reviews_cta.title">{d.reviews_cta.title}</h2>
            {d.reviews_cta.lead && (
              <p data-editable="text" data-prop="reviews_cta.lead">{d.reviews_cta.lead}</p>
            )}
          </div>
          <a href={d.reviews_cta.cta_href} class="button">{d.reviews_cta.cta_label}</a>
        </div>
      </section>
    )
  }

  <NoPassportPopup />

  <!-- Lightbox -->
  <div id="gallery-lightbox" class="lb" hidden role="dialog" aria-modal="true" aria-label="Photo gallery" tabindex="-1">
    <button id="lb-close" class="lb__close" aria-label="Close">
      <Icon name="ph:x-bold" class="lb__close-icon" aria-hidden="true" />
    </button>
    <button id="lb-prev" class="lb__arrow lb__arrow--prev" aria-label="Previous photo">
      <Icon name="ph:arrow-left-fill" class="lb__arrow-icon" aria-hidden="true" />
    </button>
    <div class="lb__img-wrap">
      <img id="lb-img" src="" alt="Gallery photo" />
    </div>
    <button id="lb-next" class="lb__arrow lb__arrow--next" aria-label="Next photo">
      <Icon name="ph:arrow-right-fill" class="lb__arrow-icon" aria-hidden="true" />
    </button>
  </div>
</BaseLayout>

<style>
  /* --- Passport strip ---------------------------------------------- */
  .passport-note {
    background: var(--c-ink);
    border-top: none;
    border-bottom: none;
    padding: 0.9rem 0;
    color: var(--c-paper);
  }
  .passport-note__inner svg { color: var(--c-ember); }
  .passport-note a { color: var(--c-ember-bright); }
  .passport-note a:hover { color: #fff; }
  .passport-note__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .passport-note p { margin: 0; flex: 1; min-width: 0; }
  @media (max-width: 640px) {
    .passport-note__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .passport-note__inner svg { display: none; }
  }

  /* --- Tours section ----------------------------------------------- */
  .tours-section {
    background-image:
      linear-gradient(rgba(255,255,255,0.5), rgba(255,255,255,0.5)),
      url('https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp/skagway.tours/wp-content/uploads/2026/02/skagway-bg.jpg');
    background-size: cover;
    background-position: center;
    border-top: 1px solid #d6e1e6;
  }
  .section__head {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section__script {
    display: block;
    font-size: 2rem;
    margin-bottom: -0.25rem;
  }
  .muted { color: var(--c-ink-soft); text-align: center; }

  /* --- Gallery marquee --------------------------------------------- */
  .gallery-marquee {
    background: var(--c-paper-soft);
    padding-block: clamp(2.5rem, 5vw, 4rem);
    overflow: hidden;
  }
  .gallery-marquee__head {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .gallery-marquee__script {
    display: block;
    font-size: 2rem;
    color: var(--c-ember);
  }
  .gallery-marquee__title {
    margin: 0.25rem 0 0;
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem);
    text-transform: uppercase;
  }
  .gallery-marquee__body {
    margin: 0.75rem auto 0;
    max-width: 56ch;
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--c-ink-soft);
  }
  .gallery-marquee__viewport {
    width: 100%;
    overflow: hidden;
    /* Soft edge fade so items enter/exit gracefully */
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 6%,
      #000 94%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 6%,
      #000 94%,
      transparent
    );
  }
  /* --gal-item = one item's total footprint (width + gap).
     Animating exactly this distance per loop makes the reset invisible
     because every frame looks identical when all images are the same. */
  :root {
    --gal-item: calc((100vw - 5rem) / 9 + 0.5rem);
  }
  @media (max-width: 760px) {
    :root { --gal-item: calc((100vw - 2rem) / 3 + 0.5rem); }
  }
  .gallery-marquee__track {
    display: flex;
    gap: 0;
    width: max-content;
    animation: gallery-scroll 4s linear infinite;
    will-change: transform;
  }
  @media (hover: hover) {
    .gallery-marquee__viewport:hover .gallery-marquee__track {
      animation-play-state: paused;
    }
  }
  @keyframes gallery-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-1 * var(--gal-item))); }
  }
  @media (prefers-reduced-motion: reduce) {
    .gallery-marquee__track { animation: none; }
  }
  .gallery-marquee__item {
    flex: 0 0 calc(var(--gal-item) - 0.5rem);
    aspect-ratio: 1 / 1;
    border-radius: 14px;
    overflow: hidden;
    background: var(--c-fog);
    position: relative;
    cursor: pointer;
    margin-right: 0.5rem;
  }
  .gallery-marquee__item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(15, 10, 30, 0.3);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .gallery-marquee__item:hover::after { opacity: 1; }
  .gallery-marquee__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* --- Lightbox ---------------------------------------------------- */
  .lb {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(15, 10, 30, 0.93);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    backdrop-filter: blur(6px);
    padding: 1rem;
  }
  .lb[hidden] { display: none; }
  .lb__img-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: calc(100vw - 160px);
    max-height: 90vh;
  }
  .lb__img-wrap img {
    max-width: 100%;
    max-height: 85vh;
    border-radius: 8px;
    object-fit: contain;
    display: block;
  }
  .lb__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .lb__close:hover { background: var(--c-ember); border-color: var(--c-ember); }
  .lb__close-icon { width: 18px; height: 18px; }
  .lb__arrow {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .lb__arrow:hover { background: var(--c-ember); border-color: var(--c-ember); }
  .lb__arrow-icon { width: 22px; height: 22px; }
  @media (max-width: 640px) {
    .lb { gap: 0.5rem; padding: 0.5rem; }
    .lb__arrow { width: 40px; height: 40px; }
    .lb__arrow-icon { width: 18px; height: 18px; }
    .lb__img-wrap { max-width: calc(100vw - 100px); }
  }
  @media (max-width: 760px) {
    .gallery-marquee__item { border-radius: 10px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .gallery-marquee__track { animation: none; }
  }

  /* --- Why us ------------------------------------------------------ */
  .why-us {
    background: #fff;
  }
  .why-us__head {
    text-align: center;
    margin-bottom: 3rem;
  }
  .why-us__script {
    font-size: 2rem;
    color: var(--c-ember);
    display: block;
    margin-bottom: 0.5rem;
  }
  .why-us__heading {
    font-size: clamp(2rem, 4vw + 1rem, 3.5rem);
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin: 0;
    color: var(--c-ink);
  }
  .why-us__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }
  .why-us__item {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .why-us__icon {
    width: 40px;
    height: 40px;
    color: var(--c-ember);
  }
  .why-us__item h3 { font-size: 1.1rem; margin: 0; color: var(--c-ink); }
  .why-us__item p { margin: 0; font-size: 0.95rem; color: var(--c-ink-soft); }

  /* --- Home reviews (immersive dark overlay) ----------------------- */
  .home-reviews {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: var(--c-paper);
  }
  .home-reviews__heading {
    color: var(--c-paper);
  }
  .home-reviews__widget {
    width: 100%;
  }

  /* --- Klondike callout (white, image-filled headline) ------------- */
  .klondike {
    background: #fff;
  }
  .klondike__inner {
    text-align: center;
    max-width: 900px;
    margin-inline: auto;
  }
  .klondike__script {
    display: block;
    font-size: clamp(2rem, 3vw + 1rem, 2.75rem);
    color: var(--c-ember);
    margin-bottom: 0.25rem;
  }
  .klondike__heading {
    white-space: normal;
    margin: 0;
    font-size: clamp(3rem, 8vw + 1rem, 7rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .klondike__lead {
    margin: 1.5rem auto 0;
    color: var(--c-ink-soft);
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 52ch;
  }
  .klondike__cta {
    margin-top: 1.75rem;
  }

  /* --- Callouts ---------------------------------------------------- */
  .callouts__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  @media (max-width: 700px) {
    .callouts__grid { grid-template-columns: 1fr; }
  }
  .callout {
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 16px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .callout--primary {
    background: var(--c-ink);
    color: var(--c-paper);
    border-color: var(--c-ink);
  }
  .callout--primary .eyebrow { color: var(--c-ember-bright); }
  .callout h3 { color: inherit; }
  .callout p { margin: 0 0 1rem; opacity: 0.9; }
  .callout a { align-self: flex-start; margin-top: auto; }
  .callout a:not(.button) {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.9rem;
    color: var(--c-ember);
  }
  .callout a:not(.button):hover {
    color: var(--c-ember-bright);
  }

  /* --- Reviews CTA ------------------------------------------------- */
  .reviews-cta__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .reviews-cta__inner h2 { margin: 0.25rem 0; }
</style>

<script>
  const allItems = document.querySelectorAll<HTMLElement>('.gallery-marquee__item');
  const srcs = [...new Set(Array.from(allItems).map(el => (el.querySelector('img') as HTMLImageElement).src))];

  const lb = document.getElementById('gallery-lightbox') as HTMLElement;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbClose = document.getElementById('lb-close') as HTMLButtonElement;
  const lbPrev = document.getElementById('lb-prev') as HTMLButtonElement;
  const lbNext = document.getElementById('lb-next') as HTMLButtonElement;
  let cur = 0;

  function openLb(i: number) {
    cur = i;
    lbImg.src = srcs[cur];
    lb.hidden = false;
    document.body.style.overflow = 'hidden';
    lb.focus();
  }
  function closeLb() {
    lb.hidden = true;
    document.body.style.overflow = '';
  }
  function showPrev() { cur = (cur - 1 + srcs.length) % srcs.length; lbImg.src = srcs[cur]; }
  function showNext() { cur = (cur + 1) % srcs.length; lbImg.src = srcs[cur]; }

  allItems.forEach(el => {
    const idx = parseInt(el.dataset.galleryIndex ?? '0', 10);
    el.addEventListener('click', () => openLb(idx));
    if (el.getAttribute('role') === 'button') {
      el.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLb(idx); }
      });
    }
  });

  lbClose.addEventListener('click', closeLb);
  lb.addEventListener('click', (e: MouseEvent) => { if (e.target === lb) closeLb(); });
  lbPrev.addEventListener('click', (e: MouseEvent) => { e.stopPropagation(); showPrev(); });
  lbNext.addEventListener('click', (e: MouseEvent) => { e.stopPropagation(); showNext(); });

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (lb.hidden) return;
    if (e.key === 'Escape') closeLb();
    if (e.key === 'ArrowLeft') showPrev();
    if (e.key === 'ArrowRight') showNext();
  });

  let tx = 0;
  lb.addEventListener('touchstart', (e: TouchEvent) => { tx = e.touches[0].clientX; }, { passive: true });
  lb.addEventListener('touchend', (e: TouchEvent) => {
    const dx = e.changedTouches[0].clientX - tx;
    if (Math.abs(dx) > 40) dx < 0 ? showNext() : showPrev();
  });
</script>
