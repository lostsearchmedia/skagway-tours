---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getCollection, render } from "astro:content";

const all = await getCollection("faqs");
const sorted = all.sort((a, b) => a.data.order - b.data.order);

// Group FAQs by category
const byCategory = new Map<string, typeof all>();
for (const faq of sorted) {
  const cat = faq.data.category || "General";
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(faq);
}

const rendered = await Promise.all(
  sorted.map(async (faq) => {
    const { Content } = await render(faq);
    return { faq, Content };
  })
);
const renderedMap = new Map(rendered.map(({ faq, Content }) => [faq.id, Content]));
---

<BaseLayout title="FAQs" description="Frequently asked questions about Skagway Tours — booking, cancellation, passports, and more.">
  <PageHero
    eyebrow="Questions"
    title="Frequently asked questions"
    lead="Booking, cancellation policy, passports, and everything else."
  />

  <section class="section">
    <div class="container">
      {sorted.length === 0 ? (
        <p class="muted">FAQs will appear here once added in CloudCannon.</p>
      ) : (
        Array.from(byCategory.entries()).map(([category, items]) => (
          <div class="faq-group">
            <h2>{category}</h2>
            {items.map((faq) => {
              const Content = renderedMap.get(faq.id)!;
              return (
                <details class="faq">
                  <summary>
                    <span>{faq.data.question}</span>
                    <svg aria-hidden="true" viewBox="0 0 20 20" width="18" height="18">
                      <path d="M5 8 L10 13 L15 8" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" />
                    </svg>
                  </summary>
                  <div class="faq__body prose">
                    <Content />
                  </div>
                </details>
              );
            })}
          </div>
        ))
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .faq-group { margin-bottom: 3rem; max-width: 820px; }
  .faq-group h2 {
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--c-ember);
  }
  .faq {
    border: 1px solid var(--c-fog);
    border-radius: 6px;
    margin-bottom: 0.6rem;
    background: #fff;
    overflow: hidden;
  }
  .faq[open] { border-color: var(--c-ember); }
  .faq summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    font-weight: 600;
    color: var(--c-ink);
  }
  .faq summary::-webkit-details-marker { display: none; }
  .faq[open] summary svg { transform: rotate(180deg); }
  .faq summary svg { transition: transform 0.2s ease; color: var(--c-ember); }
  .faq__body {
    padding: 0 1.25rem 1.25rem;
    color: var(--c-ink-soft);
  }
  .muted { color: var(--c-ink-soft); text-align: center; }
</style>
