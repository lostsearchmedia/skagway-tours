---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "contact");
if (!entry || entry.data._schema !== "page") {
  throw new Error("src/content/pages/contact.md is missing or has the wrong _schema");
}
const d = entry.data;
const { Content } = await render(entry);

const site = await getEntry("site", "default");
const s = site?.data;

const error = Astro.url.searchParams.get("error");
const errorMessage =
  error === "validation"
    ? "Please fill in all required fields with a valid email."
    : error
    ? "Something went wrong sending your message. Please try again or email us directly."
    : null;
---

<BaseLayout title={d.title} description={d.description}>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_title ?? d.title}
    lead={d.hero_lead}
  />

  <section class="section">
    <div class="container contact__grid">
      <div>
        <div class="prose" data-editable="text" data-type="block" data-prop="@content">
          <Content />
        </div>

        {d.reach_heading && <h2 data-editable="text" data-prop="reach_heading">{d.reach_heading}</h2>}
        {s?.phone && (
          <p>
            <strong>{s.phone_label ?? "Call"}:</strong> <a href={`tel:${s.phone.replace(/[^+\d]/g, "")}`}>{s.phone}</a>
          </p>
        )}
        {s?.email && (
          <p>
            <strong>Email:</strong> <a href={`mailto:${s.email}`}>{s.email}</a>
          </p>
        )}
        {d.response_note && (
          <p class="muted" data-editable="text" data-prop="response_note">{d.response_note}</p>
        )}

        {d.newsletter_heading && <h3 data-editable="text" data-prop="newsletter_heading">{d.newsletter_heading}</h3>}
        <form class="newsletter" action="/api/newsletter" method="POST">
          <label class="sr-only" for="nl-email">Email</label>
          <input id="nl-email" type="email" name="email" placeholder="you@example.com" required />
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" class="honeypot" />
          <button type="submit" class="button">Subscribe</button>
        </form>
      </div>

      <form class="contact-form" action="/api/contact" method="POST">
        {errorMessage && <p class="form-error full" role="alert">{errorMessage}</p>}
        <label>
          <span>Name</span>
          <input type="text" name="name" required />
        </label>
        <label>
          <span>Email</span>
          <input type="email" name="email" required />
        </label>
        <label class="full">
          <span>Subject</span>
          <input type="text" name="subject" />
        </label>
        <label class="full">
          <span>Message</span>
          <textarea name="message" rows="6" required></textarea>
        </label>
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" class="honeypot" />
        <button type="submit" class="button full">Send message</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 880px) {
    .contact__grid { grid-template-columns: 1fr; }
  }
  .contact-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 8px;
    padding: 1.75rem;
  }
  .contact-form label { display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.9rem; }
  .contact-form label span { font-weight: 600; }
  .contact-form .full { grid-column: 1 / -1; }
  .contact-form input,
  .contact-form textarea {
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--c-fog);
    border-radius: 4px;
    font: inherit;
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: 2px solid var(--c-ember);
    outline-offset: 1px;
  }
  .newsletter { display: flex; gap: 0.5rem; margin-top: 0.5rem; }
  .newsletter input {
    flex: 1;
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--c-fog);
    border-radius: 4px;
    font: inherit;
  }
  .muted { color: var(--c-ink-soft); }
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  .honeypot {
    position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0;
  }
  .form-error {
    background: #fdecea;
    color: #a12a1f;
    border: 1px solid #f5b5ad;
    border-radius: 4px;
    padding: 0.75rem 1rem;
    margin: 0;
  }
</style>
