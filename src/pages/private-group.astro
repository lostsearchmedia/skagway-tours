---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import BookButton from "../components/BookButton.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "private-group");
if (!entry || entry.data._schema !== "page") {
  throw new Error("src/content/pages/private-group.md is missing or has the wrong _schema");
}
const d = entry.data;
const { Content } = await render(entry);
---

<BaseLayout title={d.title} description={d.description}>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_title ?? d.title}
    lead={d.hero_lead}
  />

  <section class="section">
    <div class="container prose">
      <div data-editable="text" data-type="block" data-prop="@content">
        <Content />
      </div>

      <p style="margin-top: 2rem;">
        <BookButton label={d.book_button_label ?? "Request a private tour"} />
      </p>
    </div>
  </section>
</BaseLayout>
