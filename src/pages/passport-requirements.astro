---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "passport-requirements");
const d = entry?.data;

const FALLBACK = "https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2024/02/st_wide.jpg";
const PASSPORT_IMG = "https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp/skagway.tours/wp-content/uploads/2025/09/Passport_Requirements-scaled.png";

const notAllowed = [
  "Photocopies or digital copies of Passports or IDs",
  "Expired passports",
  "Other forms of ID: Global Entry Card, Nexus Card, Student IDs, Cruise Ship IDs, etc.",
  "REAL ID (unless used in conjunction with an original Birth Certificate)",
];
---

<BaseLayout title={d?.title ?? "Passport Requirements"} description={d?.description} seo={d?.seo}>

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="psp-hero">
    <div class="psp-hero__media" aria-hidden="true">
      <img src={FALLBACK} alt="" />
      <div class="psp-hero__shade"></div>
    </div>
    <div class="psp-hero__inner container">
      <span class="psp-eyebrow psp-eyebrow--light">Border Crossing</span>
      <h1 class="psp-hero__title">All Of Our Tours Cross The Canadian Border</h1>
      <p class="psp-hero__lead">Every Skagway Tours route crosses into the Yukon Territory. A valid passport or approved alternative document is required for every traveler — no exceptions.</p>
    </div>
  </section>

  <!-- ── Bold statement band ──────────────────────────────────── -->
  <section class="psp-section psp-alert">
    <div class="container psp-alert__inner">
      <div class="psp-alert__icon" aria-hidden="true">
        <svg viewBox="0 0 48 48" width="48" height="48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M24 6 L42 40 H6 Z"/>
          <path d="M24 20 V28"/>
          <circle cx="24" cy="34" r="1.5" fill="currentColor" stroke="none"/>
        </svg>
      </div>
      <p class="psp-alert__text">Passports are <strong>required</strong> for <strong>all travel</strong> into Canada and the United States <strong>for all passengers</strong>, <strong>all the time</strong>.</p>
    </div>
  </section>

  <!-- ── Passport image feature ───────────────────────────────── -->
  <section class="psp-section psp-image">
    <div class="container psp-image__inner">
      <span class="psp-eyebrow">At a Glance</span>
      <h2>Passport Requirements Reference</h2>
      <p>A quick visual breakdown of what's accepted at the Canadian border — pin it, save it, send it to your travel group.</p>
      <figure class="psp-image__figure">
        <img src={PASSPORT_IMG} alt="Passport requirements visual reference" loading="lazy" />
      </figure>
    </div>
  </section>

  <!-- ── Visas section ────────────────────────────────────────── -->
  <section class="psp-section psp-visas">
    <div class="container psp-visas__inner">
      <div class="psp-section-head">
        <span class="psp-eyebrow">Visas</span>
        <h2>International Travelers</h2>
      </div>
      <p>Passengers required to have visas for travel into the US or Canada <em>may also</em> be required to present their visas at the border.</p>
      <p class="psp-visas__exceptions"><strong>Exceptions apply for US and Canadian residents only</strong> — see below.</p>
    </div>
  </section>

  <!-- ── US Residents ─────────────────────────────────────────── -->
  <section class="psp-section psp-residents">
    <div class="container">
      <div class="psp-section-head">
        <span class="psp-eyebrow">United States</span>
        <h2>US Residents</h2>
        <p class="psp-section-head__lead">The following forms of ID for travel into Canada and the US are acceptable for US Residents:</p>
      </div>

      <div class="psp-residents__grid">
        <article class="psp-req">
          <div class="psp-req__icon" aria-hidden="true">
            <svg viewBox="0 0 40 40" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="10" y="6" width="20" height="28" rx="2"/><circle cx="20" cy="18" r="3"/><path d="M14 27 Q20 22 26 27"/></svg>
          </div>
          <h3>US Passport Card</h3>
          <p>A federally issued passport card is accepted at land and sea border crossings between the US and Canada.</p>
        </article>

        <article class="psp-req">
          <div class="psp-req__icon" aria-hidden="true">
            <svg viewBox="0 0 40 40" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="8" width="28" height="24" rx="2"/><path d="M12 16 H28 M12 22 H28 M12 28 H22"/></svg>
          </div>
          <h3>Birth Certificate + Gov ID</h3>
          <p><strong>Original</strong> birth certificate (not a photocopy) paired with a government issued photo ID.</p>
        </article>

        <article class="psp-req psp-req--wide">
          <div class="psp-req__icon" aria-hidden="true">
            <svg viewBox="0 0 40 40" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="10" width="30" height="20" rx="2"/><circle cx="13" cy="19" r="2.5"/><path d="M19 17 H30 M19 22 H27"/></svg>
          </div>
          <h3>Enhanced Driver's License (EDL)</h3>
          <p>Only issued by <em>Michigan, Minnesota, New York, Vermont,</em> and <em>Washington</em>. No other states offer them.</p>
          <ul class="psp-sublist">
            <li>Must have the word <strong>ENHANCED</strong> in bold letters across the top.</li>
            <li>A Real ID is <strong>not</strong> the same thing — Real ID has a star at the top and is <strong>not valid</strong> for Canada unless accompanied by an original birth certificate.</li>
          </ul>
        </article>

        <article class="psp-req">
          <div class="psp-req__icon" aria-hidden="true">
            <svg viewBox="0 0 40 40" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="10" width="28" height="20" rx="2"/><path d="M14 20 L18 24 L26 16"/></svg>
          </div>
          <h3>Green Card</h3>
          <p>US Permanent Resident Cards are accepted for legal residents traveling across the border.</p>
        </article>

        <article class="psp-req psp-req--wide">
          <div class="psp-req__icon" aria-hidden="true">
            <svg viewBox="0 0 40 40" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="14" cy="14" r="5"/><circle cx="26" cy="14" r="5"/><path d="M5 32 Q8 24 14 24 Q20 24 23 28 Q26 24 32 24 Q38 24 35 32"/></svg>
          </div>
          <h3>Children Traveling With Parent(s)</h3>
          <ul class="psp-sublist">
            <li><strong>Up to age 16</strong> when accompanied by a parent or legal guardian: original Birth Certificate (not a photocopy).</li>
            <li><strong>16 and older:</strong> original Birth Certificate (not a photocopy) <em>and</em> a government issued ID.</li>
            <li><em>Note:</em> Single parents or legal guardians traveling with children are <strong>not</strong> required to have a letter of permission from the other parent or guardian while on one of our tours.</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ── Canadian Residents ───────────────────────────────────── -->
  <section class="psp-section psp-canadian">
    <div class="container psp-canadian__inner">
      <div class="psp-canadian__icon" aria-hidden="true">
        <svg viewBox="0 0 64 64" width="56" height="56" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M32 10 L36 20 L44 18 L40 28 L50 32 L40 36 L44 46 L36 44 L32 54 L28 44 L20 46 L24 36 L14 32 L24 28 L20 18 L28 20 Z"/>
        </svg>
      </div>
      <div class="psp-canadian__copy">
        <span class="psp-eyebrow">Canada</span>
        <h2>Canadian Residents</h2>
        <p>An <strong>original</strong> Birth Certificate (not a photocopy) with a government issued ID is acceptable for Canadian citizens traveling into the US and Canada.</p>
      </div>
    </div>
  </section>

  <!-- ── Not allowed (dark warning) ───────────────────────────── -->
  <section class="psp-section psp-denied">
    <div class="container psp-denied__inner">
      <div class="psp-section-head">
        <span class="psp-eyebrow psp-eyebrow--light">Heads Up</span>
        <h2>Not Allowed — Ever</h2>
        <p class="psp-denied__lead">These documents <strong>will not</strong> get you across the border. Please don't show up with one of these as your only ID.</p>
      </div>
      <ul class="psp-denied__list">
        {notAllowed.map((item) => (
          <li>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M5 5 L19 19"/>
            </svg>
            <span set:html={item}></span>
          </li>
        ))}
      </ul>
      <p class="psp-denied__note"><em>REAL ID is NOT an ENHANCED ID. Enhanced IDs have the word "ENHANCED" written across the top. Real ID has a star at the top.</em></p>
    </div>
  </section>

  <!-- ── Still have questions ─────────────────────────────────── -->
  <section class="psp-section psp-help">
    <div class="container psp-help__inner">
      <span class="psp-eyebrow psp-eyebrow--light">Still Unsure?</span>
      <h2>Reach Out Before You Travel</h2>
      <p>We'd rather clear up any confusion ahead of time than have you miss your tour. Get in touch and we'll walk you through what you need.</p>
      <div class="psp-help__actions">
        <a href="mailto:info@skagway.tours" class="button">Email Us</a>
        <a href="/faqs/" class="button button--ghost-light">View FAQs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .psp-section { padding: clamp(3.5rem, 7vw, 6rem) 0; }

  .psp-eyebrow {
    display: inline-block;
    font-family: var(--font-accent);
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: var(--c-ember);
    margin-bottom: 0.4rem;
  }
  .psp-eyebrow--light { color: var(--c-ember-bright); }

  .psp-section-head {
    text-align: center;
    margin-bottom: 2.5rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }
  .psp-section-head h2 {
    font-size: clamp(2rem, 3.5vw + 1rem, 3rem);
    margin: 0;
  }
  .psp-section-head__lead {
    margin: 1rem 0 0;
    color: var(--c-ink-soft);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  /* ── Hero ─────────────────────────────────────────────────── */
  .psp-hero {
    position: relative;
    min-height: 52vh;
    display: flex;
    align-items: flex-end;
    color: #fff;
    overflow: hidden;
    background: var(--c-spruce-deep);
  }
  .psp-hero__media { position: absolute; inset: 0; }
  .psp-hero__media img { width: 100%; height: 100%; object-fit: cover; }
  .psp-hero__shade {
    position: absolute; inset: 0;
    background: linear-gradient(105deg,
      rgba(31, 28, 57, 0.9) 0%,
      rgba(41, 37, 70, 0.65) 60%,
      rgba(41, 37, 70, 0.25) 100%);
  }
  .psp-hero__inner {
    position: relative;
    max-width: 780px;
    padding-top: 6rem;
    padding-bottom: 4rem;
  }
  .psp-hero__title {
    font-size: clamp(2.2rem, 4.5vw + 1rem, 4rem);
    line-height: 1.05;
    margin: 0 0 1.2rem;
    color: #fff;
  }
  .psp-hero__lead {
    font-size: 1.15rem;
    line-height: 1.55;
    opacity: 0.95;
    max-width: 62ch;
    margin: 0;
  }

  /* ── Alert band ───────────────────────────────────────────── */
  .psp-alert {
    background: var(--c-ember);
    color: #fff;
    padding: 2.5rem 0;
  }
  .psp-alert__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    max-width: 960px;
  }
  .psp-alert__icon { flex-shrink: 0; color: #fff; }
  .psp-alert__text {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.55;
  }
  .psp-alert__text strong { font-weight: 700; text-decoration: underline; text-underline-offset: 3px; }
  @media (max-width: 640px) {
    .psp-alert__inner { flex-direction: column; text-align: center; gap: 1rem; }
  }

  /* ── Passport image feature ───────────────────────────────── */
  .psp-image { background: var(--c-paper); }
  .psp-image__inner { text-align: center; max-width: 820px; }
  .psp-image__inner h2 {
    font-size: clamp(1.75rem, 2.5vw + 1rem, 2.5rem);
    margin: 0 0 0.75rem;
  }
  .psp-image__inner > p {
    color: var(--c-ink-soft);
    font-size: 1.05rem;
    margin: 0 0 2rem;
  }
  .psp-image__figure {
    margin: 0;
    background: #fff;
    border-radius: 16px;
    padding: 1rem;
    box-shadow: 0 20px 40px -20px rgba(41, 37, 70, 0.25);
  }
  .psp-image__figure img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }

  /* ── Visas ─────────────────────────────────────────────────── */
  .psp-visas { background: var(--c-paper-soft); }
  .psp-visas__inner {
    max-width: 820px;
    text-align: center;
  }
  .psp-visas__inner p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--c-ink-soft);
    margin: 0 0 1rem;
  }
  .psp-visas__exceptions {
    padding: 1rem 1.5rem;
    background: #fff;
    border-radius: 12px;
    border: 1px solid var(--c-fog);
    margin-top: 1.5rem !important;
  }
  .psp-visas__exceptions strong { color: var(--c-ink); }

  /* ── US Residents grid ────────────────────────────────────── */
  .psp-residents { background: #fff; }
  .psp-residents__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 960px;
    margin: 0 auto;
  }
  .psp-req {
    background: var(--c-paper);
    border: 1px solid var(--c-fog);
    border-radius: 16px;
    padding: 1.75rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .psp-req:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(41, 37, 70, 0.2);
  }
  .psp-req--wide { grid-column: 1 / -1; }
  .psp-req__icon {
    width: 52px; height: 52px;
    border-radius: 12px;
    background: var(--c-paper-soft);
    color: var(--c-ember);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .psp-req h3 {
    font-size: 1.25rem;
    margin: 0 0 0.5rem;
    color: var(--c-ink);
  }
  .psp-req p {
    margin: 0;
    color: var(--c-ink-soft);
    line-height: 1.6;
  }
  .psp-sublist {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .psp-sublist li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--c-ink-soft);
  }
  .psp-sublist li::before {
    content: "";
    position: absolute;
    left: 0; top: 0.65em;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--c-ember);
  }
  .psp-sublist strong { color: var(--c-ink); }
  @media (max-width: 720px) {
    .psp-residents__grid { grid-template-columns: 1fr; }
  }

  /* ── Canadian Residents ───────────────────────────────────── */
  .psp-canadian {
    background: var(--c-paper);
  }
  .psp-canadian__inner {
    display: flex;
    gap: 2rem;
    align-items: center;
    max-width: 820px;
  }
  .psp-canadian__icon {
    flex-shrink: 0;
    width: 96px; height: 96px;
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-ember);
    box-shadow: 0 12px 28px -12px rgba(41, 37, 70, 0.25);
  }
  .psp-canadian__copy h2 {
    font-size: clamp(1.75rem, 2.5vw + 1rem, 2.5rem);
    margin: 0 0 0.5rem;
  }
  .psp-canadian__copy p {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--c-ink-soft);
  }
  .psp-canadian__copy strong { color: var(--c-ink); }
  @media (max-width: 640px) {
    .psp-canadian__inner { flex-direction: column; text-align: center; gap: 1.25rem; }
  }

  /* ── Not allowed (dark) ───────────────────────────────────── */
  .psp-denied {
    background: var(--c-ink);
    color: var(--c-paper);
  }
  .psp-denied__inner { max-width: 820px; margin: 0 auto; }
  .psp-denied .psp-section-head h2 { color: #fff; }
  .psp-denied__lead {
    margin: 1rem 0 0;
    color: rgba(246, 241, 231, 0.82);
    line-height: 1.65;
    font-size: 1.05rem;
  }
  .psp-denied__lead strong { color: var(--c-ember-bright); font-weight: 700; }
  .psp-denied__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 0.9rem;
  }
  .psp-denied__list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    color: rgba(246, 241, 231, 0.92);
    font-size: 0.98rem;
    line-height: 1.4;
  }
  .psp-denied__list svg {
    flex-shrink: 0;
    color: var(--c-ember-bright);
  }
  .psp-denied__note {
    margin: 1.5rem 0 0;
    color: rgba(246, 241, 231, 0.65);
    font-size: 0.92rem;
    line-height: 1.6;
    text-align: center;
  }

  /* ── Help CTA ─────────────────────────────────────────────── */
  .psp-help {
    background: var(--c-spruce-deep);
    color: var(--c-paper);
    text-align: center;
  }
  .psp-help__inner { max-width: 640px; }
  .psp-help h2 {
    color: #fff;
    font-size: clamp(2rem, 3.5vw + 1rem, 3rem);
    margin: 0 0 1rem;
  }
  .psp-help p {
    font-size: 1.1rem;
    margin: 0 0 1.75rem;
    color: rgba(246, 241, 231, 0.88);
  }
  .psp-help__actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .psp-help__actions :global(.button--ghost-light) {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }
  .psp-help__actions :global(.button--ghost-light:hover) {
    background: rgba(255, 255, 255, 0.12);
    border-color: #fff;
    text-decoration: none;
  }
</style>
