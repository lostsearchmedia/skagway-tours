---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "passport-requirements");
const Content = entry ? (await render(entry)).Content : null;
const data = entry?.data;
---

<BaseLayout
  title={data?.title ?? "Passport requirements"}
  description={data?.description ?? "All Skagway Tours cross into Canada. Here's what documents you need."}
>
  <PageHero
    eyebrow="Before you book"
    title={data?.title ?? "All our tours cross the Canadian border"}
    lead="Here's what you need to bring — no passport, no tour, no kidding."
    image={data?.cover}
  />

  <section class="section">
    <div class="container prose">
      {Content ? <Content /> : (
        <>
          <h2>Short version</h2>
          <ul>
            <li>Every Skagway Tours route crosses into Canada (Yukon Territory).</li>
            <li>US and Canadian citizens need a valid passport, NEXUS card, or approved alternative.</li>
            <li>Non-US/Canadian citizens generally need a passport plus any required visas.</li>
            <li>Children under 16 follow different rules in some cases — see below.</li>
          </ul>
          <h2>Acceptable documents</h2>
          <p>Add detailed requirements here (client will provide revised copy).</p>
          <h2>Common questions</h2>
          <p>See also: <a href="/faqs/">FAQs</a>.</p>
        </>
      )}
    </div>
  </section>
</BaseLayout>
