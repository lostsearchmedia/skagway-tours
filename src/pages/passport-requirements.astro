---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "passport-requirements");
const d = entry?.data;

const notAllowed = [
  "Photocopies or digital copies of passports or IDs",
  "Expired passports",
  "Global Entry Card, Nexus Card, Student IDs, Cruise Ship IDs, or other forms of ID",
  "REAL ID — unless accompanied by an original birth certificate",
];
---

<BaseLayout title={d?.title ?? "Passport Requirements"} description={d?.description} seo={d?.seo}>

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="psp-hero">
    <div class="psp-hero__inner container">
      <span class="psp-eyebrow">Border Crossing</span>
      <h1 class="psp-hero__title">Skagway Passport Requirements</h1>
      <p class="psp-hero__lead">Every Skagway Tours route crosses into Canada. A valid passport — or an approved alternative for US &amp; Canadian residents — is <strong>required for every traveler</strong>.</p>
    </div>
  </section>

  <!-- ── Main content (all cards in one section) ──────────────── -->
  <section class="psp-section psp-main">
    <div class="container psp-main__inner">

      <!-- Passports + Visas side-by-side -->
      <div class="psp-top-grid">
        <article class="psp-card">
          <div class="psp-card__head">
            <div class="psp-card__icon" aria-hidden="true">
              <Icon name="ph:identification-card-fill" class="psp-card__icon-svg" />
            </div>
            <h2>Passports</h2>
          </div>
          <ul class="psp-list">
            <li>A valid passport is required for all travel between the US and Canada.</li>
            <li>Must be valid for the entire duration of your trip.</li>
            <li>Photocopies or digital copies are not accepted.</li>
          </ul>
        </article>

        <article class="psp-card">
          <div class="psp-card__head">
            <div class="psp-card__icon" aria-hidden="true">
              <Icon name="ph:globe-hemisphere-west-fill" class="psp-card__icon-svg" />
            </div>
            <h2>Visas</h2>
          </div>
          <ul class="psp-list">
            <li>If your nationality requires a visa for the US or Canada, bring it with you.</li>
            <li>You may be asked to show your visa at the border.</li>
          </ul>
          <div class="psp-card__note">
            <Icon name="ph:info-fill" class="psp-card__note-icon" aria-hidden="true" />
            <span>Exceptions apply for US and Canadian residents only — see below.</span>
          </div>
        </article>
      </div>

      <!-- Acceptable ID Alternatives -->
      <article class="psp-card">
        <div class="psp-card__head">
          <div class="psp-card__icon" aria-hidden="true">
            <Icon name="ph:check-circle-fill" class="psp-card__icon-svg" />
          </div>
          <div>
            <h2>Acceptable ID Alternatives</h2>
            <p class="psp-card__sub">Only for US &amp; Canadian residents.</p>
          </div>
        </div>

        <div class="psp-alts-grid">
          <div class="psp-alt">
            <h3>For US Residents</h3>
            <ul class="psp-list">
              <li><strong>US Passport Card</strong></li>
              <li><strong>Original birth certificate</strong> (not a photocopy) + government-issued ID</li>
              <li>
                <strong>Enhanced Driver's License (EDL)</strong> — only issued by Michigan, Minnesota, New York, Vermont, and Washington. Must say <strong>ENHANCED</strong> in bold at the top.
                <div class="psp-inline-note">
                  <Icon name="ph:warning-fill" class="psp-inline-note__icon" aria-hidden="true" />
                  <span><strong>Real ID is NOT an Enhanced Driver's License.</strong> Real ID has a star at the top and is not valid for Canada unless accompanied by an original birth certificate.</span>
                </div>
              </li>
              <li><strong>Green Card</strong></li>
              <li><strong>Children traveling with a parent or legal guardian</strong> — under 16 need an original birth certificate (not a photocopy); ages 16 and older need a birth certificate plus a government-issued ID. Single parents do not need a permission letter from the other parent.</li>
            </ul>
          </div>

          <div class="psp-alt psp-alt--canadian">
            <h3>For Canadian Residents</h3>
            <ul class="psp-list">
              <li><strong>Original birth certificate</strong> (not a photocopy) + government-issued ID</li>
            </ul>
          </div>
        </div>
      </article>

      <!-- Not Allowed -->
      <div class="psp-denied">
        <h2>Not Allowed — Ever</h2>
        <p class="psp-denied__lead">These documents will <strong>not</strong> get you across the border.</p>
        <ul class="psp-denied__list">
          {notAllowed.map((item) => (
            <li>
              <Icon name="ph:prohibit-fill" class="psp-denied__icon" aria-hidden="true" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </section>

  <!-- ── Help CTA ─────────────────────────────────────────────── -->
  <section class="psp-section psp-help">
    <div class="container psp-help__inner">
      <h2>Still unsure what you need?</h2>
      <p>We'd rather clear up any confusion ahead of time than have you miss your tour.</p>
      <div class="psp-help__actions">
        <a href="mailto:info@skagway.tours" class="button">Email Us</a>
        <a href="/faqs/" class="button button--ghost">View FAQs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .psp-section { padding: clamp(3rem, 6vw, 5rem) 0; }

  .psp-eyebrow {
    display: inline-block;
    font-family: var(--font-accent);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--c-ember-bright);
    margin-bottom: 0.4rem;
  }

  /* ── Hero ─────────────────────────────────────────────────── */
  .psp-hero {
    background: linear-gradient(135deg, #1f1c39 0%, #292546 55%, #3d3870 100%);
    color: #fff;
    padding: clamp(4rem, 8vw, 6rem) 0 clamp(3rem, 6vw, 4.5rem);
  }
  .psp-hero__inner { max-width: 820px; }
  .psp-hero__title {
    font-size: clamp(2.2rem, 4vw + 1rem, 3.4rem);
    line-height: 1.1;
    margin: 0 0 1.25rem;
    color: #fff;
  }
  .psp-hero__lead {
    font-size: clamp(1.15rem, 1.5vw + 0.5rem, 1.4rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.95);
    max-width: 62ch;
    margin: 0;
  }
  .psp-hero__lead strong { color: #fff; font-weight: 700; }

  /* ── Main section ─────────────────────────────────────────── */
  .psp-main { background: var(--c-paper); }
  .psp-main__inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 1100px;
  }
  .psp-top-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 660px) {
    .psp-top-grid { grid-template-columns: 1fr; }
  }

  .psp-card {
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 16px;
    padding: 1.75rem;
  }
  .psp-card__head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .psp-card__icon {
    flex-shrink: 0;
    width: 48px; height: 48px;
    border-radius: 12px;
    background: var(--c-ink);
    color: var(--c-ember-bright);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .psp-card__icon-svg { width: 26px; height: 26px; }
  .psp-card h2 { font-size: 1.35rem; margin: 0; color: var(--c-ink); }
  .psp-card__sub { margin: 0.2rem 0 0; font-size: 0.88rem; color: var(--c-ink-soft); }
  .psp-card__note {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-top: 1.1rem;
    padding: 0.7rem 0.9rem;
    background: var(--c-paper);
    border-radius: 8px;
    font-size: 0.88rem;
    color: var(--c-ink-soft);
    line-height: 1.5;
  }
  .psp-card__note-icon { flex-shrink: 0; width: 15px; height: 15px; margin-top: 2px; color: var(--c-ember); }

  /* ── Alternatives grid ────────────────────────────────────── */
  .psp-alts-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 0;
    border-top: 1px solid var(--c-fog);
    padding-top: 1.5rem;
    margin-top: 0.25rem;
  }
  .psp-alt { padding-right: 2rem; }
  .psp-alt--canadian {
    padding-right: 0;
    padding-left: 2rem;
    border-left: 1px solid var(--c-fog);
  }
  .psp-alt h3 {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-ember);
    margin: 0 0 1rem;
  }
  @media (max-width: 760px) {
    .psp-alts-grid { grid-template-columns: 1fr; gap: 2rem; }
    .psp-alt { padding-right: 0; }
    .psp-alt--canadian { padding-left: 0; border-left: none; border-top: 1px solid var(--c-fog); padding-top: 2rem; }
  }

  /* ── Lists ────────────────────────────────────────────────── */
  .psp-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .psp-list li {
    position: relative;
    padding-left: 1.4rem;
    line-height: 1.6;
    color: var(--c-ink);
  }
  .psp-list li::before {
    content: "";
    position: absolute;
    left: 0; top: 0.6em;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--c-ember);
  }
  .psp-list strong { color: var(--c-ink); }

  /* ── Inline REAL ID warning ───────────────────────────────── */
  .psp-inline-note {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-top: 0.6rem;
    padding: 0.65rem 0.85rem;
    background: #fef2f2;
    border: 1px solid #fca5a5;
    border-radius: 8px;
    font-size: 0.86rem;
    line-height: 1.5;
    color: #7f1d1d;
  }
  .psp-inline-note__icon { flex-shrink: 0; width: 14px; height: 14px; margin-top: 2px; color: #dc2626; }
  .psp-inline-note strong { color: #7f1d1d; }

  /* ── Not Allowed ──────────────────────────────────────────── */
  .psp-denied { padding: 0.75rem 0.25rem 0; }
  .psp-denied h2 { margin: 0 0 0.4rem; color: var(--c-ink); font-size: 1.35rem; }
  .psp-denied__lead {
    margin: 0 0 1.25rem;
    color: var(--c-ink-soft);
    font-size: 0.97rem;
  }
  .psp-denied__lead strong { color: var(--c-ink); }
  .psp-denied__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .psp-denied__list li {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    font-size: 0.97rem;
    line-height: 1.5;
    color: var(--c-ink);
  }
  .psp-denied__icon {
    flex-shrink: 0;
    width: 18px; height: 18px;
    margin-top: 2px;
    color: var(--c-ember);
  }

  /* ── Help CTA ─────────────────────────────────────────────── */
  .psp-help {
    background: linear-gradient(135deg, #1f1c39 0%, #292546 55%, #3d3870 100%);
    text-align: center;
  }
  .psp-help__inner { max-width: 560px; }
  .psp-help h2 { color: #fff; font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2rem); margin: 0 0 0.6rem; }
  .psp-help p { font-size: 1rem; margin: 0 0 1.5rem; color: rgba(246, 241, 231, 0.85); }
  .psp-help__actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .psp-help__actions :global(.button--ghost) {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }
  .psp-help__actions :global(.button--ghost:hover) {
    background: rgba(255, 255, 255, 0.12);
    border-color: #fff;
    color: #fff;
    text-decoration: none;
  }
</style>
