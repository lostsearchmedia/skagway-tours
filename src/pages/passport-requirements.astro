---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "passport-requirements");
const d = entry?.data;

const passportPoints = [
  "A valid passport is required for all travel between the US and Canada.",
  "Must be valid for the entire duration of your trip.",
  "Photocopies or digital copies are not accepted.",
];

const visaPoints = [
  "If your nationality requires a visa for the US or Canada, bring it with you.",
  "You may be asked to show your visa at the border.",
];

const usAlternatives = [
  "US Passport Card",
  "Original birth certificate (not a copy) + government-issued ID",
  "Enhanced Driver's License (Michigan, Minnesota, New York, Vermont, Washington) — must say \"ENHANCED\" in bold",
  "Green Card",
  "Children under 16: Original birth certificate only",
  "Ages 16+: Birth certificate + government-issued ID",
];

const canadianAlternatives = [
  "Original birth certificate (not a copy) + government-issued ID",
];
---

<BaseLayout title={d?.title ?? "Passport Requirements"} description={d?.description} seo={d?.seo}>

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="psp-hero">
    <div class="psp-hero__inner container">
      <span class="psp-eyebrow">Border Crossing</span>
      <h1 class="psp-hero__title">Skagway Passport Requirements</h1>
      <p class="psp-hero__lead">Every Skagway Tours route crosses into Canada. A valid passport — or an approved alternative for US &amp; Canadian residents — is required for every traveler.</p>
    </div>
  </section>

  <!-- ── Key requirements ─────────────────────────────────────── -->
  <section class="psp-section psp-main">
    <div class="container psp-main__inner">

      <article class="psp-card">
        <div class="psp-card__head">
          <div class="psp-card__icon" aria-hidden="true">
            <Icon name="ph:identification-card-fill" class="psp-card__icon-svg" />
          </div>
          <h2>Passports</h2>
        </div>
        <ul class="psp-list">
          {passportPoints.map((p) => (
            <li>{p}</li>
          ))}
        </ul>
      </article>

      <article class="psp-card">
        <div class="psp-card__head">
          <div class="psp-card__icon" aria-hidden="true">
            <Icon name="ph:globe-hemisphere-west-fill" class="psp-card__icon-svg" />
          </div>
          <h2>Visas</h2>
        </div>
        <ul class="psp-list">
          {visaPoints.map((p) => (
            <li>{p}</li>
          ))}
        </ul>
      </article>

      <article class="psp-card psp-card--wide">
        <div class="psp-card__head">
          <div class="psp-card__icon" aria-hidden="true">
            <Icon name="ph:check-circle-fill" class="psp-card__icon-svg" />
          </div>
          <div>
            <h2>Acceptable ID Alternatives</h2>
            <p class="psp-card__sub">Only for US &amp; Canadian residents.</p>
          </div>
        </div>

        <div class="psp-alts">
          <div class="psp-alt">
            <h3>For US Residents</h3>
            <ul class="psp-list">
              {usAlternatives.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
          <div class="psp-alt">
            <h3>For Canadian Residents</h3>
            <ul class="psp-list">
              {canadianAlternatives.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </article>

    </div>
  </section>

  <!-- ── Help CTA ─────────────────────────────────────────────── -->
  <section class="psp-section psp-help">
    <div class="container psp-help__inner">
      <h2>Still unsure what you need?</h2>
      <p>We'd rather clear up any confusion ahead of time than have you miss your tour. Get in touch and we'll walk you through it.</p>
      <div class="psp-help__actions">
        <a href="mailto:info@skagway.tours" class="button">Email Us</a>
        <a href="/faqs/" class="button button--ghost-light">View FAQs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .psp-section { padding: clamp(3rem, 6vw, 5rem) 0; }

  .psp-eyebrow {
    display: inline-block;
    font-family: var(--font-accent);
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: var(--c-ember-bright);
    margin-bottom: 0.4rem;
  }

  /* ── Hero ─────────────────────────────────────────────────── */
  .psp-hero {
    background: linear-gradient(135deg, #1f1c39 0%, #292546 55%, #3d3870 100%);
    color: #fff;
    padding: clamp(4rem, 8vw, 6rem) 0 clamp(3rem, 6vw, 4.5rem);
  }
  .psp-hero__inner {
    max-width: 780px;
  }
  .psp-hero__title {
    font-size: clamp(2.2rem, 4vw + 1rem, 3.4rem);
    line-height: 1.1;
    margin: 0 0 1rem;
    color: #fff;
  }
  .psp-hero__lead {
    font-size: 1.1rem;
    line-height: 1.6;
    opacity: 0.9;
    max-width: 62ch;
    margin: 0;
  }

  /* ── Main cards ───────────────────────────────────────────── */
  .psp-main { background: var(--c-paper); }
  .psp-main__inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 1000px;
  }
  .psp-card {
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 16px;
    padding: 1.75rem;
  }
  .psp-card--wide { grid-column: 1 / -1; }

  .psp-card__head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .psp-card__icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: var(--c-ink);
    color: var(--c-ember-bright);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .psp-card__icon-svg { width: 28px; height: 28px; }
  .psp-card h2 {
    font-size: 1.4rem;
    margin: 0;
    color: var(--c-ink);
    letter-spacing: 0.01em;
  }
  .psp-card__sub {
    margin: 0.15rem 0 0;
    font-size: 0.88rem;
    color: var(--c-ink-soft);
  }

  .psp-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .psp-list li {
    position: relative;
    padding-left: 1.4rem;
    line-height: 1.55;
    color: var(--c-ink);
  }
  .psp-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-ember);
  }

  /* ── Alternatives grid (inside wide card) ─────────────────── */
  .psp-alts {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 2rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--c-fog);
    margin-top: 0.25rem;
    padding: 1.5rem 0 0;
  }
  .psp-alt h3 {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-ember);
    margin: 0 0 1rem;
  }

  @media (max-width: 760px) {
    .psp-main__inner { grid-template-columns: 1fr; }
    .psp-alts { grid-template-columns: 1fr; gap: 1.75rem; }
  }

  /* ── Help CTA ─────────────────────────────────────────────── */
  .psp-help {
    background: var(--c-ink);
    color: var(--c-paper);
    text-align: center;
  }
  .psp-help__inner { max-width: 620px; }
  .psp-help h2 {
    color: #fff;
    font-size: clamp(1.75rem, 3vw + 0.75rem, 2.5rem);
    margin: 0 0 0.75rem;
  }
  .psp-help p {
    font-size: 1.05rem;
    margin: 0 0 1.5rem;
    color: rgba(246, 241, 231, 0.85);
    line-height: 1.6;
  }
  .psp-help__actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .psp-help__actions :global(.button--ghost-light) {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }
  .psp-help__actions :global(.button--ghost-light:hover) {
    background: rgba(255, 255, 255, 0.12);
    border-color: #fff;
    text-decoration: none;
  }
</style>
