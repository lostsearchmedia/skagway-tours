---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "passport-requirements");
const d = entry?.data;

const notAllowed = [
  "Photocopies or digital copies of passports or IDs",
  "Expired passports",
  "Global Entry Card, Nexus Card, Student IDs, Cruise Ship IDs, or other forms of ID",
  "REAL ID — unless accompanied by an original birth certificate",
];
---

<BaseLayout title={d?.title ?? "Passport Requirements"} description={d?.description} seo={d?.seo}>

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="psp-hero">
    <div class="psp-hero__inner container">
      <span class="psp-eyebrow">Border Crossing</span>
      <h1 class="psp-hero__title">Skagway Passport Requirements</h1>
      <p class="psp-hero__lead">Every Skagway Tours route crosses into Canada. A valid passport — or an approved alternative for US &amp; Canadian residents — is <strong>required for every traveler</strong>.</p>
    </div>
  </section>

  <!-- ── Passports + Visas ─────────────────────────────────────── -->
  <section class="psp-section psp-top">
    <div class="container psp-top__inner">

      <article class="psp-card">
        <div class="psp-card__head">
          <div class="psp-card__icon" aria-hidden="true">
            <Icon name="ph:identification-card-fill" class="psp-card__icon-svg" />
          </div>
          <h2>Passports</h2>
        </div>
        <ul class="psp-list">
          <li>A valid passport is required for all travel between the US and Canada.</li>
          <li>Must be valid for the entire duration of your trip.</li>
          <li>Photocopies or digital copies are not accepted.</li>
        </ul>
      </article>

      <article class="psp-card">
        <div class="psp-card__head">
          <div class="psp-card__icon" aria-hidden="true">
            <Icon name="ph:globe-hemisphere-west-fill" class="psp-card__icon-svg" />
          </div>
          <h2>Visas</h2>
        </div>
        <ul class="psp-list">
          <li>If your nationality requires a visa for the US or Canada, bring it with you.</li>
          <li>You may be asked to show your visa at the border.</li>
        </ul>
        <div class="psp-card__note">
          <Icon name="ph:info-fill" class="psp-card__note-icon" aria-hidden="true" />
          <span>Exceptions apply for US and Canadian residents only — see below.</span>
        </div>
      </article>

    </div>
  </section>

  <!-- ── Acceptable ID Alternatives ───────────────────────────── -->
  <section class="psp-section psp-alts-section">
    <div class="container">
      <div class="psp-section-head">
        <div class="psp-section-head__icon" aria-hidden="true">
          <Icon name="ph:check-circle-fill" class="psp-section-head__icon-svg" />
        </div>
        <div>
          <h2>Acceptable ID Alternatives</h2>
          <p>For US &amp; Canadian residents only.</p>
        </div>
      </div>

      <div class="psp-alts-grid">

        <!-- US Residents -->
        <div class="psp-alt">
          <h3>US Residents</h3>
          <p class="psp-alt__lead">The following are acceptable for US residents traveling between Canada and the US:</p>
          <ul class="psp-list">
            <li><strong>US Passport Card</strong></li>
            <li>
              <strong>Original birth certificate</strong> (not a photocopy) + government-issued ID
            </li>
            <li>
              <strong>Enhanced Driver's License (EDL)</strong> — only issued by Michigan, Minnesota, New York, Vermont, and Washington. No other states offer them. The license must have the word <strong>ENHANCED</strong> in bold letters at the top.
              <div class="psp-inline-note">
                <Icon name="ph:warning-fill" class="psp-inline-note__icon" aria-hidden="true" />
                <span><strong>Real ID is NOT an Enhanced Driver's License.</strong> Real ID has a star at the top and is <strong>not valid</strong> for Canada unless accompanied by an original birth certificate.</span>
              </div>
            </li>
            <li><strong>Green Card</strong></li>
            <li>
              <strong>Children traveling with a parent or legal guardian:</strong>
              <ul class="psp-sublist">
                <li><strong>Under 16:</strong> original birth certificate (not a photocopy)</li>
                <li><strong>16 and older:</strong> original birth certificate + government-issued ID</li>
                <li>Single parents and legal guardians are <strong>not</strong> required to carry a permission letter from the other parent while on tour.</li>
              </ul>
            </li>
          </ul>
        </div>

        <!-- Canadian Residents -->
        <div class="psp-alt psp-alt--canadian">
          <h3>Canadian Residents</h3>
          <p class="psp-alt__lead">The following is acceptable for Canadian citizens traveling into the US and Canada:</p>
          <ul class="psp-list">
            <li><strong>Original birth certificate</strong> (not a photocopy) + government-issued ID</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Not Allowed ───────────────────────────────────────────── -->
  <section class="psp-section psp-denied">
    <div class="container psp-denied__inner">
      <div class="psp-section-head psp-section-head--light">
        <h2>Not Allowed — Ever</h2>
        <p>These documents will <strong>not</strong> get you across the border.</p>
      </div>
      <ul class="psp-denied__list">
        {notAllowed.map((item) => (
          <li>
            <Icon name="ph:prohibit-fill" class="psp-denied__icon" aria-hidden="true" />
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <p class="psp-denied__note">REAL ID is NOT an ENHANCED ID. Enhanced IDs have the word "ENHANCED" written across the top. Real ID has a star at the top.</p>
    </div>
  </section>

  <!-- ── Help CTA ─────────────────────────────────────────────── -->
  <section class="psp-section psp-help">
    <div class="container psp-help__inner">
      <h2>Still unsure what you need?</h2>
      <p>We'd rather clear up any confusion ahead of time than have you miss your tour.</p>
      <div class="psp-help__actions">
        <a href="mailto:info@skagway.tours" class="button">Email Us</a>
        <a href="/faqs/" class="button button--ghost-light">View FAQs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .psp-section { padding: clamp(3rem, 6vw, 5rem) 0; }

  .psp-eyebrow {
    display: inline-block;
    font-family: var(--font-accent);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--c-ember-bright);
    margin-bottom: 0.4rem;
  }

  /* ── Hero ─────────────────────────────────────────────────── */
  .psp-hero {
    background: linear-gradient(135deg, #1f1c39 0%, #292546 55%, #3d3870 100%);
    color: #fff;
    padding: clamp(4rem, 8vw, 6rem) 0 clamp(3rem, 6vw, 4.5rem);
  }
  .psp-hero__inner { max-width: 820px; }
  .psp-hero__title {
    font-size: clamp(2.2rem, 4vw + 1rem, 3.4rem);
    line-height: 1.1;
    margin: 0 0 1.25rem;
    color: #fff;
  }
  .psp-hero__lead {
    font-size: clamp(1.15rem, 1.5vw + 0.5rem, 1.4rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.95);
    max-width: 62ch;
    margin: 0;
    font-weight: 400;
  }
  .psp-hero__lead strong {
    color: #fff;
    font-weight: 700;
  }

  /* ── Section head ─────────────────────────────────────────── */
  .psp-section-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.25rem;
  }
  .psp-section-head h2 {
    font-size: clamp(1.75rem, 2.5vw + 1rem, 2.25rem);
    margin: 0 0 0.2rem;
    color: var(--c-ink);
  }
  .psp-section-head p {
    margin: 0;
    color: var(--c-ink-soft);
    font-size: 0.95rem;
  }
  .psp-section-head--light {
    text-align: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.4rem;
  }
  .psp-section-head--light h2 { color: #fff; }
  .psp-section-head--light p { color: rgba(246, 241, 231, 0.75); }
  .psp-section-head--light p strong { color: var(--c-ember-bright); }
  .psp-section-head__icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: var(--c-ink);
    color: var(--c-ember-bright);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .psp-section-head__icon-svg { width: 28px; height: 28px; }

  /* ── Top two cards ────────────────────────────────────────── */
  .psp-top { background: var(--c-paper); }
  .psp-top__inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 960px;
  }
  @media (max-width: 680px) {
    .psp-top__inner { grid-template-columns: 1fr; }
  }

  .psp-card {
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 16px;
    padding: 1.75rem;
  }
  .psp-card__head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .psp-card__icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--c-ink);
    color: var(--c-ember-bright);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .psp-card__icon-svg { width: 26px; height: 26px; }
  .psp-card h2 {
    font-size: 1.35rem;
    margin: 0;
    color: var(--c-ink);
  }
  .psp-card__note {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    background: var(--c-paper);
    border-radius: 8px;
    font-size: 0.9rem;
    color: var(--c-ink-soft);
    line-height: 1.5;
  }
  .psp-card__note-icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    margin-top: 2px;
    color: var(--c-ember);
  }

  /* ── Lists ────────────────────────────────────────────────── */
  .psp-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .psp-list li {
    position: relative;
    padding-left: 1.4rem;
    line-height: 1.6;
    color: var(--c-ink);
  }
  .psp-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-ember);
    flex-shrink: 0;
  }
  .psp-list strong { color: var(--c-ink); }

  .psp-sublist {
    list-style: none;
    padding: 0;
    margin: 0.65rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .psp-sublist li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--c-ink-soft);
  }
  .psp-sublist li::before {
    content: "–";
    position: absolute;
    left: 0;
    color: var(--c-ember);
    font-weight: 700;
  }
  .psp-sublist strong { color: var(--c-ink); }

  /* ── Inline warning note (inside list item) ───────────────── */
  .psp-inline-note {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-top: 0.6rem;
    padding: 0.7rem 0.9rem;
    background: #fef2f2;
    border: 1px solid #fca5a5;
    border-radius: 8px;
    font-size: 0.88rem;
    line-height: 1.5;
    color: #7f1d1d;
  }
  .psp-inline-note__icon {
    flex-shrink: 0;
    width: 15px;
    height: 15px;
    margin-top: 2px;
    color: #dc2626;
  }
  .psp-inline-note strong { color: #7f1d1d; }

  /* ── Alternatives section ─────────────────────────────────── */
  .psp-alts-section { background: var(--c-paper-soft); }

  .psp-alts-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    max-width: 1100px;
  }
  .psp-alt {
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 16px;
    padding: 1.75rem;
  }
  .psp-alt h3 {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-ember);
    margin: 0 0 0.5rem;
  }
  .psp-alt__lead {
    margin: 0 0 1.25rem;
    font-size: 0.92rem;
    color: var(--c-ink-soft);
    line-height: 1.55;
  }
  @media (max-width: 780px) {
    .psp-alts-grid { grid-template-columns: 1fr; }
  }

  /* ── Not Allowed ──────────────────────────────────────────── */
  .psp-denied {
    background: var(--c-ink);
    color: var(--c-paper);
  }
  .psp-denied__inner { max-width: 860px; margin: 0 auto; }
  .psp-denied__list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 0.75rem;
  }
  .psp-denied__list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    color: rgba(246, 241, 231, 0.9);
    font-size: 0.95rem;
    line-height: 1.45;
  }
  .psp-denied__icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    margin-top: 2px;
    color: var(--c-ember-bright);
  }
  .psp-denied__note {
    margin: 0;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    font-size: 0.88rem;
    line-height: 1.6;
    color: rgba(246, 241, 231, 0.65);
    font-style: italic;
    text-align: center;
  }

  /* ── Help CTA ─────────────────────────────────────────────── */
  .psp-help {
    background: var(--c-paper);
    text-align: center;
  }
  .psp-help__inner { max-width: 560px; }
  .psp-help h2 {
    color: var(--c-ink);
    font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2rem);
    margin: 0 0 0.6rem;
  }
  .psp-help p {
    font-size: 1rem;
    margin: 0 0 1.5rem;
    color: var(--c-ink-soft);
  }
  .psp-help__actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
