---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout
  title="Group Tours"
  description="Private tours and charters for groups from Skagway, AK."
>
  <PageHero
    eyebrow="Group sales"
    title="Group Tours"
    lead="Private tours and charters for groups up to 160 along the South Klondike Highway."
  />
  <section class="section">
    <div class="container prose">
      <p>
        Full details coming soon. For rates, availability, and reservations,
        call <a href="tel:9079214344">(907) 921-4344</a> or email
        <a href="mailto:info@skagway.tours">info@skagway.tours</a>.
      </p>
    </div>
  </section>
</BaseLayout>
