---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const tours = await getCollection("tours", (e) => !e.data.draft);
  return tours.map((tour) => ({
    params: { slug: tour.id },
    props: { tour },
  }));
}

const { tour } = Astro.props;
const { Content } = await render(tour);
const d = tour.data;

const GALLERY_PLACEHOLDER = "https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2024/02/st_wide.jpg";
const galleryImages = Array.from({ length: 6 }, () => GALLERY_PLACEHOLDER);
---

<BaseLayout title={d.title} description={d.summary} seo={d.seo}>
  <article class="tour">
    <header class="tour__hero">
      {
        d.featured_image ? (
          <Image
            src={d.featured_image}
            alt={d.title}
            widths={[800, 1200, 1800]}
            sizes="100vw"
            class="tour__hero-img"
          />
        ) : (
          <img
            class="tour__hero-img"
            src="https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2024/02/st_wide.jpg"
            alt=""
            loading="eager"
          />
        )
      }
      <div class="tour__hero-shade"></div>
      <div class="container tour__hero-inner">
        <h1 data-editable="text" data-prop="title">{d.title}</h1>
        <p class="tour__summary" data-editable="text" data-prop="summary">{d.summary}</p>
      </div>
    </header>

    <div class="container tour__layout">
      <section class="tour__content prose">

        <!-- Stats row -->
        <div class="tour-stats">
          {d.duration_hours && (
            <div class="tour-stat">
              <span class="tour-stat__label">Duration</span>
              <span class="tour-stat__value">{d.duration_hours}h</span>
            </div>
          )}
          {d.price_from && (
            <div class="tour-stat">
              <span class="tour-stat__label">Adults</span>
              <span class="tour-stat__sublabel">Ages 12+</span>
              <span class="tour-stat__value">${d.price_from}</span>
            </div>
          )}
          {d.price_child && (
            <div class="tour-stat">
              <span class="tour-stat__label">Children</span>
              <span class="tour-stat__sublabel">Ages 2–11</span>
              <span class="tour-stat__value">${d.price_child}</span>
            </div>
          )}
          {(d.price_from || d.price_child) && (
            <div class="tour-stat">
              <span class="tour-stat__label">Lap Child</span>
              <span class="tour-stat__sublabel">Under 2 years old</span>
              <span class="tour-stat__value">Free</span>
            </div>
          )}
        </div>

        <!-- Passport notice -->
        <div class="tour-passport">
          <svg aria-hidden="true" viewBox="0 0 24 24" width="22" height="22" flex-shrink="0">
            <rect x="5" y="3" width="14" height="18" rx="2" fill="#dd5154" />
            <circle cx="12" cy="10" r="3" fill="#fff" />
            <rect x="8" y="15" width="8" height="1.5" fill="#fff" />
            <rect x="8" y="17" width="8" height="1.5" fill="#fff" />
          </svg>
          <p>
            <strong>Passport required.</strong> Every tour crosses into Canada — a valid passport or approved WHTI document is required for all passengers. <a href="/passport-requirements/">Passport requirements →</a>
          </p>
        </div>

        <!-- Video player (if tour has a video) -->
        {d.video_url && (
          <div class="tour-video" data-video-src={d.video_url} role="button" tabindex="0" aria-label={`Watch ${d.title} video`}>
            <div class="tour-video__thumb">
              {d.featured_image
                ? <Image src={d.featured_image} alt="" widths={[800]} sizes="100vw" />
                : <img src="https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2024/02/st_wide.jpg" alt="" loading="lazy" />
              }
              <div class="tour-video__overlay">
                <div class="tour-video__play">
                  <Icon name="ph:play-fill" class="tour-video__play-icon" aria-hidden="true" />
                </div>
                <span class="tour-video__label">Watch the tour video</span>
              </div>
            </div>
          </div>
        )}

        {
          d.highlights && d.highlights.length > 0 && (
            <>
              <h2>Highlights</h2>
              <ul data-editable="array" data-prop="highlights">
                {d.highlights.map((h, i) => (
                  <li data-editable="array-item">
                    <span data-editable="text" data-prop={`highlights[${i}]`}>{h}</span>
                  </li>
                ))}
              </ul>
            </>
          )
        }

        <div id="tour-body" data-editable="text" data-type="block" data-prop="@content">
          <Content />
        </div>

      </section>

      <aside class="tour__sidebar">
        {d.fareharbor_item_id && (
          <div class="booking-block">
            <h3 class="booking-block__heading">Ready to Book</h3>
            <div id="tour-calendar" class="booking-card calendar-embed">
              <script
                is:inline
                src={`https://fareharbor.com/embeds/script/calendar/skagway/items/${d.fareharbor_item_id}/?fallback=simple&full-items=yes&flow=${d.fareharbor_flow ?? "no"}`}
              />
            </div>
          </div>
        )}
        <div class="tour__before">
          <h3>Before your tour</h3>
          <ul>
            <li><a href="/find-us/">Dock pickup details</a> — we pick up at all three cruise docks in Skagway.</li>
            <li><a href="/passport-requirements/">Passport requirements</a> — every tour crosses into Canada.</li>
            <li><a href="/faqs/">FAQs, accessibility, and our All Aboard guarantee</a>.</li>
          </ul>
        </div>
      </aside>
    </div>

    <!-- Photo gallery -->
    <section class="tour-gallery" aria-label="Tour photos">
      <div class="container">
        <div class="tour-gallery__head">
          <span class="script script--accent tour-gallery__script">Photos</span>
          <h2 class="tour-gallery__title">Moments from the road</h2>
        </div>
        <div class="tour-gallery__grid">
          {galleryImages.map((src, i) => (
            <div class="tour-gallery__item">
              <img src={src} alt="" loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </section>

    {d.fareharbor_item_id && (
      <div class="mobile-book-bar" aria-hidden="true">
        <a href="#tour-calendar" class="mobile-book-bar__btn">
          Check availability
          <Icon name="ph:arrow-down-fill" class="mobile-book-bar__icon" aria-hidden="true" />
        </a>
      </div>
    )}
  </article>
</BaseLayout>

<script>
  const bar = document.querySelector('.mobile-book-bar') as HTMLElement | null;
  const calendar = document.getElementById('tour-calendar');
  if (bar && calendar) {
    const obs = new IntersectionObserver(
      ([entry]) => bar.classList.toggle('is-hidden', entry.isIntersecting),
      { threshold: 0.1 }
    );
    obs.observe(calendar);
  }
</script>

<script>
  // Transform each <h2> + its following siblings inside #tour-body into a
  // <details>/<summary> accordion. Skip inside the CloudCannon visual
  // editor so editors see the flat, expanded content.
  if (!(window as any).inEditorMode) {
    const root = document.getElementById("tour-body");
    if (root) {
      const children = Array.from(root.children);
      type Group = { heading: Element; content: Element[] };
      const groups: Group[] = [];
      let current: Group | null = null;

      for (const el of children) {
        if (el.tagName === "H2") {
          current = { heading: el, content: [] };
          groups.push(current);
        } else if (current) {
          current.content.push(el);
        }
        // Elements before the first h2 stay in place as intro prose.
      }

      groups.forEach((g, i) => {
        const details = document.createElement("details");
        details.className = "tour-accordion";
        if (i === 0) details.open = true;

        const summary = document.createElement("summary");
        summary.textContent = g.heading.textContent;
        details.appendChild(summary);

        const body = document.createElement("div");
        body.className = "tour-accordion__body";
        for (const el of g.content) body.appendChild(el);
        details.appendChild(body);

        g.heading.replaceWith(details);
      });
    }
  }
</script>

<style>
  .tour__hero {
    position: relative;
    min-height: 440px;
    display: flex;
    align-items: flex-end;
    color: #fff;
    overflow: hidden;
    background: var(--c-spruce-deep);
  }
  .tour__hero-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .tour__hero-shade {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(41, 37, 70,0.8), rgba(41, 37, 70,0.2));
  }
  .tour__hero-inner {
    position: relative;
    padding: 6rem 0 2.5rem;
  }
  .tour__summary { font-size: 1.15rem; max-width: 60ch; opacity: 0.95; }

  .tour__layout {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 3rem;
    padding: 3rem 0 clamp(3rem, 6vw, 5rem);
  }
  @media (max-width: 880px) {
    .tour__layout { grid-template-columns: 1fr; }
    .tour-gallery { padding-bottom: 7rem; }
  }

  .booking-card {
    position: sticky;
    top: 6rem;
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 10px 30px -12px rgba(41, 37, 70,0.15);
  }
  .booking-card h3 { margin-top: 0; }
  .calendar-embed {
    position: static;
    padding: 0;
    overflow: hidden;
  }
  @media (max-width: 880px) {
    .booking-card { position: static; }
  }

  .mobile-book-bar {
    display: none;
  }
  @media (max-width: 880px) {
    .mobile-book-bar {
      display: block;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      padding: 0.85rem 1rem;
      background: #fff;
      border-top: 1px solid var(--c-fog);
      box-shadow: 0 -4px 20px -4px rgba(41, 37, 70,0.15);
      z-index: 40;
      transition: transform 0.25s ease;
    }
    .mobile-book-bar.is-hidden {
      transform: translateY(110%);
    }
  }
  .mobile-book-bar__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.85rem 1.5rem;
    background: var(--c-ember, #c94a1e);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 10px;
    letter-spacing: 0.02em;
  }
  .mobile-book-bar__icon { width: 14px; height: 14px; }

  /* ── Stats row ───────────────────────────────────────────────── */
  .tour-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .tour-stat {
    background: var(--c-paper-soft);
    border: 1px solid var(--c-fog);
    border-radius: 10px;
    padding: 0.65rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 100px;
  }
  .tour-stat__label {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-ink-soft);
  }
  .tour-stat__sublabel {
    font-family: var(--font-display);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-ink-soft);
    opacity: 0.7;
    margin-top: -0.1rem;
  }
  .tour-stat__value {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 900;
    color: var(--c-ink);
    line-height: 1;
  }

  /* ── Passport notice ─────────────────────────────────────────── */
  .tour-passport {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    background: #fef2f2;
    border: 1px solid #fca5a5;
    border-radius: 10px;
    padding: 0.9rem 1rem;
    margin-bottom: 1.5rem;
  }
  .tour-passport svg { flex-shrink: 0; margin-top: 1px; }
  .tour-passport p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: #7f1d1d;
  }
  .tour-passport a { color: #991b1b; font-weight: 600; }

  /* ── Video block ─────────────────────────────────────────────── */
  .tour-video {
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    margin-bottom: 1.5rem;
    display: block;
  }
  .tour-video__thumb {
    position: relative;
    aspect-ratio: 16 / 9;
  }
  .tour-video__thumb img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .tour-video:hover .tour-video__thumb img { transform: scale(1.03); }
  .tour-video__overlay {
    position: absolute; inset: 0;
    background: rgba(15, 10, 30, 0.42);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    transition: background 0.2s ease;
  }
  .tour-video:hover .tour-video__overlay { background: rgba(15, 10, 30, 0.55); }
  .tour-video__play {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    border: 2px solid rgba(255,255,255,0.7);
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .tour-video__play-icon {
    width: 28px;
    height: 28px;
    transform: translateX(2px);
  }
  .tour-video:hover .tour-video__play {
    background: var(--c-ember);
    border-color: var(--c-ember);
    transform: scale(1.1);
  }
  .tour-video__label {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.9);
  }

  /* ── Sidebar stacking ───────────────────────────────────────── */
  .tour__sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Booking block (heading + calendar) ─────────────────────── */
  .booking-block__heading {
    margin: 0 0 0.75rem;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c-ink);
  }

  /* ── Before your tour (sidebar) ─────────────────────────────── */
  .tour__before {
    background: var(--c-ink);
    color: var(--c-paper);
    border: 1px solid var(--c-ink);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 10px 30px -12px rgba(41, 37, 70,0.15);
  }
  .tour__before h3 {
    margin-top: 0;
    color: var(--c-paper);
  }
  .tour__before ul { margin: 0; padding-left: 1.1rem; }
  .tour__before li {
    margin-bottom: 0.5rem;
    font-size: 0.92rem;
    color: rgba(246, 241, 231, 0.88);
  }
  .tour__before a {
    color: var(--c-ember-bright, #ff6b6b);
    text-decoration: underline;
  }
  .tour__before a:hover {
    color: #fff;
  }

  /* ── Tour photo gallery ─────────────────────────────────────── */
  .tour-gallery {
    padding: clamp(3rem, 6vw, 5rem) 0;
    background: var(--c-paper-soft);
    border-top: 1px solid var(--c-fog);
  }
  .tour-gallery__head {
    text-align: center;
    margin-bottom: 2rem;
  }
  .tour-gallery__script {
    display: block;
    font-size: 2rem;
    margin-bottom: -0.25rem;
  }
  .tour-gallery__title {
    margin: 0;
  }
  .tour-gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .tour-gallery__item {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 12px;
    background: var(--c-fog);
  }
  .tour-gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }
  .tour-gallery__item:hover img {
    transform: scale(1.04);
  }

  /* Mobile: horizontal snap-scroll carousel */
  @media (max-width: 760px) {
    .tour-gallery__grid {
      display: flex;
      grid-template-columns: none;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 0.75rem;
      padding: 0.25rem 1rem 1rem;
      margin: 0 -1rem;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .tour-gallery__grid::-webkit-scrollbar { display: none; }
    .tour-gallery__item {
      flex: 0 0 78%;
      scroll-snap-align: start;
    }
  }

  /* Accordion treatment for #tour-body — JS below transforms each <h2> +
     following content into a <details>. Progressive enhancement: content
     renders fully without JS, accordions activate once JS runs. */
  :global(.tour-accordion) {
    border-top: 1px solid var(--c-fog);
    margin: 0;
  }
  :global(.tour-accordion:last-of-type) {
    border-bottom: 1px solid var(--c-fog);
  }
  :global(.tour-accordion > summary) {
    cursor: pointer;
    padding: 1.1rem 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    color: var(--c-ink);
  }
  :global(.tour-accordion > summary::-webkit-details-marker) { display: none; }
  :global(.tour-accordion > summary::after) {
    content: "+";
    font-weight: 400;
    font-size: 1.6rem;
    color: var(--c-ember);
    line-height: 1;
    transition: transform 0.2s ease;
  }
  :global(.tour-accordion[open] > summary::after) {
    content: "−";
  }
  :global(.tour-accordion__body) {
    padding: 0 0 1.25rem;
  }
  :global(.tour-accordion__body > :first-child) {
    margin-top: 0;
  }
</style>
