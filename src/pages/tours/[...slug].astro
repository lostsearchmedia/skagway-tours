---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BookButton from "../../components/BookButton.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const tours = await getCollection("tours", (e) => !e.data.draft);
  return tours.map((tour) => ({
    params: { slug: tour.id },
    props: { tour },
  }));
}

const { tour } = Astro.props;
const { Content } = await render(tour);
const d = tour.data;
---

<BaseLayout title={d.title} description={d.summary} seo={d.seo}>
  <article class="tour">
    <header class="tour__hero">
      {
        d.featured_image && (
          <Image
            src={d.featured_image}
            alt={d.title}
            widths={[800, 1200, 1800]}
            sizes="100vw"
            class="tour__hero-img"
          />
        )
      }
      <div class="tour__hero-shade"></div>
      <div class="container tour__hero-inner">
        <span class="eyebrow">Skagway Tour</span>
        <h1 data-editable="text" data-prop="title">{d.title}</h1>
        <p class="tour__summary" data-editable="text" data-prop="summary">{d.summary}</p>
      </div>
    </header>

    <div class="container tour__layout">
      <section class="tour__content prose">
        <div class="meta-row">
          {d.duration_hours && <span><strong>{d.duration_hours}h</strong> duration</span>}
          {d.difficulty && <span><strong>{d.difficulty}</strong> level</span>}
          {d.price_from && <span>adults from <strong>${d.price_from}</strong></span>}
          {d.price_child && <span>kids from <strong>${d.price_child}</strong></span>}
        </div>

        {
          d.highlights && d.highlights.length > 0 && (
            <>
              <h2>Highlights</h2>
              <ul data-editable="array" data-prop="highlights">
                {d.highlights.map((h, i) => (
                  <li data-editable="array-item">
                    <span data-editable="text" data-prop={`highlights[${i}]`}>{h}</span>
                  </li>
                ))}
              </ul>
            </>
          )
        }

        <div data-editable="text" data-type="block" data-prop="@content">
          <Content />
        </div>

        <aside class="tour__before">
          <h3>Before your tour</h3>
          <ul>
            <li><a href="/find-us/">Dock pickup details</a> — we pick up at all three cruise docks in Skagway.</li>
            <li><a href="/passport-requirements/">Passport requirements</a> — every tour crosses into Canada.</li>
            <li><a href="/faqs/">FAQs, accessibility, and our All Aboard guarantee</a>.</li>
          </ul>
        </aside>
      </section>

      <aside class="tour__sidebar">
        <div class="booking-card">
          <h3>Ready to go?</h3>
          <ul class="booking-card__prices">
            {d.price_from && <li><span>Adults (13+)</span><strong>${d.price_from}</strong></li>}
            {d.price_child && <li><span>Children (2–11)</span><strong>${d.price_child}</strong></li>}
            {(d.price_from || d.price_child) && <li><span>Infants under 2</span><strong>Free</strong></li>}
          </ul>
          <BookButton itemId={d.fareharbor_item_id} label="Book now" fullWidth />
          <p class="booking-card__note">
            A valid passport is required — this tour crosses into Canada.
          </p>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .tour__hero {
    position: relative;
    min-height: 440px;
    display: flex;
    align-items: flex-end;
    color: #fff;
    overflow: hidden;
    background: var(--c-spruce-deep);
  }
  .tour__hero-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .tour__hero-shade {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(41, 37, 70,0.8), rgba(41, 37, 70,0.2));
  }
  .tour__hero-inner {
    position: relative;
    padding: 6rem 1rem 2.5rem;
  }
  .tour__summary { font-size: 1.15rem; max-width: 60ch; opacity: 0.95; }

  .tour__layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 3rem;
    padding: 3rem 1rem 1rem;
  }
  @media (max-width: 880px) {
    .tour__layout { grid-template-columns: 1fr; }
  }

  .booking-card {
    position: sticky;
    top: 6rem;
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 10px 30px -12px rgba(41, 37, 70,0.15);
  }
  .booking-card h3 { margin-top: 0; }
  .booking-card__prices {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: grid;
    gap: 0.35rem;
    font-size: 0.95rem;
  }
  .booking-card__prices li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .booking-card__prices span { color: var(--c-ink-soft); }
  .booking-card__note {
    margin: 1rem 0 0;
    font-size: 0.85rem;
    color: var(--c-ink-soft);
  }

  .tour__before {
    margin-top: 2.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--c-paper-soft);
    border-radius: 16px;
  }
  .tour__before h3 { margin-top: 0; }
  .tour__before ul { margin: 0; padding-left: 1.1rem; }
  .tour__before li { margin-bottom: 0.4rem; }
</style>
