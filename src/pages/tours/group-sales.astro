---
import BaseLayout from "../../layouts/BaseLayout.astro";

const FALLBACK = "https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2024/02/st_wide.jpg";

const error = Astro.url.searchParams.get("error");
const errorMessage =
  error === "validation"
    ? "Please fill in all required fields with a valid email."
    : error
    ? "Something went wrong. Please try again or call us directly."
    : null;

const vehicles = [
  {
    name: "MCI Coach",
    capacity: "Up to 58 passengers",
    body: "Seats up to 58 passengers comfortably and includes an onboard bathroom for longer trips.",
  },
  {
    name: "VIP Coach",
    capacity: "Up to 44 passengers",
    body: "Seats up to 44 passengers with spacious interiors and a bathroom for added convenience.",
  },
  {
    name: "Passenger Tour Buses",
    capacity: "30–40 passengers",
    body: "Available in 40-passenger and 30-seat configurations, featuring wide windows for 360-degree views.",
  },
  {
    name: "Luxury Passenger Van",
    capacity: "Up to 13 passengers",
    body: "Seats up to 13 passengers with premium seating and modern amenities for small group travel.",
  },
];

const details = [
  {
    icon: "capacity",
    title: "Group & Capacity",
    body: "We can accommodate up to <strong>160 passengers</strong> in a single departure across multiple vehicles.",
  },
  {
    icon: "calendar",
    title: "Reservations",
    body: "Private tours or charters on <strong>Wednesday or Thursday</strong> require reservations <strong>6 months in advance</strong> — availability is limited on those days.",
  },
  {
    icon: "route",
    title: "Experience Onboard",
    body: "Driver guide provides narration. Photo stops and wildlife spotting included. Guaranteed return to your ship on time.",
  },
  {
    icon: "pin",
    title: "Pick-Up & Drop-Off",
    body: "Pick-up and drop-off at your ship, with the option to be dropped off in town after your tour.",
  },
  {
    icon: "sun",
    title: "Departure Times",
    body: "Book morning or afternoon departures for the best experience.",
  },
];
---

<BaseLayout
  title="Group Sales | Skagway Tours"
  description="Private tours and charters from Skagway, AK along the South Klondike Highway. Buses from 13 to 58 passengers, up to 160 guests in a single departure."
>

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="gs-hero">
    <div class="gs-hero__media" aria-hidden="true">
      <img src={FALLBACK} alt="" />
      <div class="gs-hero__shade"></div>
    </div>
    <div class="gs-hero__inner">
      <span class="gs-chip">Cruise Groups · Charters · Tours</span>
      <h1 class="gs-hero__title">Group Sales</h1>
      <p class="gs-hero__lead">Private tours and charters from Skagway, AK along the South Klondike Highway — up to <strong>160 passengers</strong> in a single departure.</p>
      <a href="#contact-form" class="button">Book Your Group Tour</a>
    </div>
  </section>

  <!-- ── Fleet ───────────────────────────────────────────────── -->
  <section class="gs-section gs-fleet">
    <div class="gs-container">
      <span class="gs-eyebrow gs-eyebrow--light">Our Fleet</span>
      <h2 class="gs-fleet__heading">Explore Our Diverse Bus Options</h2>
      <p class="gs-fleet__lead">Choose from a variety of buses designed for comfort and convenience. Whether you're a small group or a large party, we have the perfect vehicle for your adventure.</p>

      <div class="gs-fleet__grid">
        {vehicles.map((v) => (
          <article class="gs-vehicle">
            <div class="gs-vehicle__icon" aria-hidden="true">
              <svg viewBox="0 0 48 28" width="48" height="28" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="7" width="40" height="16" rx="3"/>
                <rect x="42" y="11" width="4" height="8" rx="1"/>
                <circle cx="10" cy="25" r="3"/>
                <circle cx="36" cy="25" r="3"/>
                <rect x="6" y="10" width="6" height="5" rx="1"/>
                <rect x="15" y="10" width="6" height="5" rx="1"/>
                <rect x="24" y="10" width="6" height="5" rx="1"/>
                <rect x="33" y="10" width="5" height="5" rx="1"/>
              </svg>
            </div>
            <h3 class="gs-vehicle__name">{v.name}</h3>
            <p class="gs-vehicle__capacity">{v.capacity}</p>
            <p class="gs-vehicle__body">{v.body}</p>
          </article>
        ))}
      </div>

      <div class="gs-fleet__cta">
        <a href="#contact-form" class="button">Book Your Group Tour Now</a>
      </div>
    </div>
  </section>

  <!-- ── Details ─────────────────────────────────────────────── -->
  <section class="gs-section gs-details">
    <div class="gs-container">
      <span class="gs-eyebrow">How It Works</span>
      <h2 class="gs-details__heading">Everything You Need to Know</h2>

      <div class="gs-details__grid">
        {details.map((d) => (
          <article class="gs-detail">
            <div class="gs-detail__icon" aria-hidden="true">
              {d.icon === "capacity" && (
                <svg viewBox="0 0 40 40" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="14" cy="15" r="5"/>
                  <circle cx="26" cy="15" r="5"/>
                  <path d="M4 32 Q6 24 14 24 Q20 24 22 28 Q24 24 30 24 Q34 24 36 32"/>
                </svg>
              )}
              {d.icon === "calendar" && (
                <svg viewBox="0 0 40 40" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="6" y="8" width="28" height="26" rx="2"/>
                  <path d="M6 16 H34"/>
                  <path d="M13 5 V11 M27 5 V11"/>
                </svg>
              )}
              {d.icon === "route" && (
                <svg viewBox="0 0 40 40" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10 6 C10 6 10 14 14 18 C18 22 22 22 26 26 C30 30 30 34 30 34"/>
                  <circle cx="10" cy="6" r="3"/>
                  <circle cx="30" cy="34" r="3"/>
                </svg>
              )}
              {d.icon === "pin" && (
                <svg viewBox="0 0 40 40" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 4 C14 4 10 9 10 15 C10 22 20 34 20 34 C20 34 30 22 30 15 C30 9 26 4 20 4 Z"/>
                  <circle cx="20" cy="15" r="4"/>
                </svg>
              )}
              {d.icon === "sun" && (
                <svg viewBox="0 0 40 40" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="20" cy="20" r="7"/>
                  <path d="M20 4 V10 M20 30 V36 M4 20 H10 M30 20 H36 M8 8 L12 12 M28 28 L32 32 M32 8 L28 12 M12 28 L8 32"/>
                </svg>
              )}
            </div>
            <h3 class="gs-detail__title">{d.title}</h3>
            <p class="gs-detail__body" set:html={d.body}></p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Tour & Charter Options ──────────────────────────────── -->
  <section class="gs-section gs-options">
    <div class="gs-container">
      <span class="gs-eyebrow gs-eyebrow--light">Choose Your Style</span>
      <h2 class="gs-options__heading">Tour &amp; Charter Options</h2>

      <div class="gs-options__grid">
        <article class="gs-option">
          <span class="gs-option__badge">Private Tours</span>
          <h3>Pre-Built Itineraries</h3>
          <ul>
            <li>Choose from <strong>5 tour options</strong> for your group</li>
            <li>Pricing is <strong>per bus</strong> and includes applicable admission fees</li>
            <li>Proven routes along the South Klondike Highway</li>
          </ul>
        </article>
        <article class="gs-option gs-option--alt">
          <span class="gs-option__badge">Charters</span>
          <h3>Fully Customizable</h3>
          <ul>
            <li>Pricing is <strong>by the hour</strong> (4-hour minimum)</li>
            <li>Additional costs for any attractions you choose</li>
            <li>You decide the route, timing, stops, and return</li>
            <li>Local catering available — we pick up your order and have it onboard at departure</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ── Phone CTA Banner ────────────────────────────────────── -->
  <section class="gs-section gs-phone-cta">
    <div class="gs-container gs-phone-cta__inner">
      <span class="gs-eyebrow gs-eyebrow--light">Ready to talk rates?</span>
      <h2>Call (907) 921-4344</h2>
      <p>For rates, availability, and to make reservations — give us a call. We'll match your group with the right tour and vehicle.</p>
      <a href="tel:+19079214344" class="button button--dark">Call Now</a>
    </div>
  </section>

  <!-- ── Contact Form ────────────────────────────────────────── -->
  <section id="contact-form" class="gs-section gs-form-section">
    <div class="gs-container gs-form-layout">
      <div class="gs-form-intro">
        <span class="gs-eyebrow">Inquiry</span>
        <h2>Book Your Group Tour</h2>
        <p>Tell us about your group and we'll get back to you with availability and rates. For the fastest response, give us a call at <a href="tel:+19079214344"><strong>(907) 921-4344</strong></a>.</p>
        <ul class="gs-form-intro__list">
          <li>Responses within 24 hours (often faster)</li>
          <li>Custom proposals for groups of any size</li>
          <li>Flexible departures matched to your ship</li>
        </ul>
      </div>

      <div class="gs-form-card">
        {errorMessage && <p class="gs-form-error" role="alert">{errorMessage}</p>}

        <form class="gs-form" action="/api/contact" method="POST">
          <input type="hidden" name="subject" value="Group Tour Inquiry" />

          <div class="gs-form__row">
            <label>
              <span>Name <abbr title="required">*</abbr></span>
              <input type="text" name="name" required />
            </label>
            <label>
              <span>Email Address <abbr title="required">*</abbr></span>
              <input type="email" name="email" required />
            </label>
          </div>

          <div class="gs-form__row">
            <label>
              <span>Arrival Date</span>
              <input type="date" name="arrival_date" />
            </label>
            <label>
              <span>Ship / Hotel Name</span>
              <input type="text" name="ship_hotel" placeholder="e.g. Norwegian Bliss" />
            </label>
          </div>

          <div class="gs-form__row">
            <label>
              <span># of Passengers in Your Group <abbr title="required">*</abbr></span>
              <select name="passengers" required>
                <option value="">Select group size…</option>
                <option>1–5</option>
                <option>6–10</option>
                <option>11–15</option>
                <option>16–25</option>
                <option>26–40</option>
                <option>41–60</option>
                <option>60+</option>
              </select>
            </label>
          </div>

          <label class="gs-form__full">
            <span>How Can We Help?</span>
            <textarea name="message" rows="5" placeholder="Tell us about your group and what you're looking for…"></textarea>
          </label>

          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" class="gs-honeypot" />

          <button type="submit" class="button gs-form__submit">Send</button>
        </form>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Shared ──────────────────────────────────────────────────── */
  .gs-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  .gs-section { padding: clamp(3.5rem, 7vw, 6rem) 0; }

  .gs-eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-ember);
    margin-bottom: 0.6rem;
  }
  .gs-eyebrow--light { color: var(--c-ember-bright); }

  .gs-chip {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    background: var(--c-ember);
    color: #fff;
    padding: 0.35rem 0.9rem;
    border-radius: var(--radius-pill);
    margin-bottom: 1.25rem;
  }

  /* ── Hero ────────────────────────────────────────────────────── */
  .gs-hero {
    position: relative;
    min-height: 78vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
    overflow: hidden;
  }
  .gs-hero__media { position: absolute; inset: 0; }
  .gs-hero__media img { width: 100%; height: 100%; object-fit: cover; }
  .gs-hero__shade {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom,
      rgba(15, 10, 30, 0.55) 0%,
      rgba(15, 10, 30, 0.78) 100%);
  }
  .gs-hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 4rem 1.25rem;
    max-width: 760px;
    margin: 0 auto;
  }
  .gs-hero__title {
    font-size: clamp(2.5rem, 6vw + 1rem, 5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.0;
    margin: 0 0 1.25rem;
    color: #fff;
  }
  .gs-hero__lead {
    font-size: clamp(1rem, 1.5vw + 0.5rem, 1.2rem);
    max-width: 56ch;
    opacity: 0.92;
    margin: 0 0 2rem;
    line-height: 1.6;
  }
  .gs-hero__lead strong { color: #fff; font-weight: 700; }

  /* ── Fleet ───────────────────────────────────────────────────── */
  .gs-fleet {
    background: var(--c-ink);
    color: #fff;
  }
  .gs-fleet__heading {
    font-size: clamp(1.6rem, 3vw + 0.5rem, 2.5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.75rem;
    color: #fff;
  }
  .gs-fleet__lead {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.98rem;
    max-width: 70ch;
    margin: 0 0 2.5rem;
    line-height: 1.65;
  }
  .gs-fleet__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }
  .gs-vehicle {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .gs-vehicle:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-3px);
  }
  .gs-vehicle__icon {
    color: var(--c-ember-bright);
    margin-bottom: 0.5rem;
  }
  .gs-vehicle__name {
    font-size: 1.1rem;
    margin: 0;
    color: #fff;
  }
  .gs-vehicle__capacity {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-ember-bright);
    margin: 0;
  }
  .gs-vehicle__body {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.72);
    margin: 0.35rem 0 0;
    line-height: 1.6;
  }
  .gs-fleet__cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* ── Details ─────────────────────────────────────────────────── */
  .gs-details { background: var(--c-paper-soft); }
  .gs-details__heading {
    font-size: clamp(1.5rem, 3vw + 0.5rem, 2.25rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin: 0 0 2.5rem;
  }
  .gs-details__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .gs-detail {
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 14px;
    padding: 1.6rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .gs-detail__icon {
    color: var(--c-ember);
    margin-bottom: 0.25rem;
  }
  .gs-detail__title {
    font-size: 1rem;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-ink);
  }
  .gs-detail__body {
    margin: 0;
    font-size: 0.92rem;
    color: var(--c-ink-soft);
    line-height: 1.65;
  }
  .gs-detail__body strong { color: var(--c-ink); }

  /* ── Tour & Charter Options ──────────────────────────────────── */
  .gs-options { background: var(--c-spruce); color: #fff; }
  .gs-options__heading {
    font-size: clamp(1.5rem, 3vw + 0.5rem, 2.25rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 2.5rem;
    color: #fff;
  }
  .gs-options__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  @media (max-width: 760px) {
    .gs-options__grid { grid-template-columns: 1fr; }
  }
  .gs-option {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 14px;
    padding: 2rem 1.75rem;
  }
  .gs-option--alt {
    background: var(--c-ember);
    border-color: var(--c-ember);
  }
  .gs-option__badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-ember-bright);
    margin-bottom: 1rem;
  }
  .gs-option--alt .gs-option__badge {
    color: #fff;
    opacity: 0.85;
  }
  .gs-option h3 {
    font-size: 1.4rem;
    margin: 0 0 1rem;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .gs-option ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .gs-option li {
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.95rem;
    padding-left: 1.5rem;
    position: relative;
    line-height: 1.55;
  }
  .gs-option li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 0.5rem;
    height: 0.5rem;
    background: var(--c-ember-bright);
    border-radius: 50%;
  }
  .gs-option--alt li::before {
    background: #fff;
  }
  .gs-option--alt li { color: rgba(255, 255, 255, 0.95); }
  .gs-option li strong { color: #fff; font-weight: 700; }

  /* ── Phone CTA Banner ────────────────────────────────────────── */
  .gs-phone-cta {
    background: var(--c-ember);
    color: #fff;
  }
  .gs-phone-cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
  }
  .gs-phone-cta h2 {
    font-size: clamp(1.8rem, 4vw + 0.5rem, 3rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
    color: #fff;
  }
  .gs-phone-cta p {
    max-width: 55ch;
    margin: 0;
    opacity: 0.92;
    font-size: 1rem;
    line-height: 1.6;
  }
  .gs-phone-cta .button--dark { margin-top: 0.75rem; }

  /* ── Form Section ────────────────────────────────────────────── */
  .gs-form-section { background: #fff; }
  .gs-form-layout {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 4rem;
    align-items: start;
  }
  @media (max-width: 960px) {
    .gs-form-layout { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  .gs-form-intro h2 {
    font-size: clamp(1.6rem, 3vw + 0.5rem, 2.5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin: 0 0 1rem;
    line-height: 1.1;
  }
  .gs-form-intro p {
    color: var(--c-ink-soft);
    font-size: 1rem;
    margin: 0 0 1.5rem;
    line-height: 1.65;
  }
  .gs-form-intro__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .gs-form-intro__list li {
    padding-left: 1.5rem;
    position: relative;
    color: var(--c-ink);
    font-size: 0.95rem;
  }
  .gs-form-intro__list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--c-ember);
    font-weight: 700;
  }

  .gs-form-card {
    background: var(--c-paper-soft);
    border-radius: 16px;
    padding: 2rem;
  }
  .gs-form-error {
    background: #fdecea;
    color: #a12a1f;
    border: 1px solid #f5b5ad;
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    font-size: 0.88rem;
    margin: 0 0 1rem;
  }
  .gs-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .gs-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 600px) {
    .gs-form__row { grid-template-columns: 1fr; }
  }
  .gs-form label {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-size: 0.88rem;
  }
  .gs-form label span { font-weight: 600; color: var(--c-ink); }
  .gs-form label abbr { text-decoration: none; color: var(--c-ember); }
  .gs-form input,
  .gs-form select,
  .gs-form textarea {
    padding: 0.65rem 0.8rem;
    border: 1px solid var(--c-fog);
    border-radius: var(--radius-sm);
    font: inherit;
    font-size: 0.92rem;
    background: #fff;
    transition: border-color 0.15s ease;
  }
  .gs-form input:focus,
  .gs-form select:focus,
  .gs-form textarea:focus {
    outline: 2px solid var(--c-ember);
    outline-offset: 1px;
    border-color: transparent;
  }
  .gs-form__full { grid-column: 1 / -1; }
  .gs-form__submit {
    align-self: flex-start;
    justify-content: center;
