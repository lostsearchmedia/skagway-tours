---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "find-us");
if (!entry || entry.data._schema !== "page") {
  throw new Error("src/content/pages/find-us.md is missing or has the wrong _schema");
}
const d = entry.data;
const { Content } = await render(entry);
---

<BaseLayout title={d.title} description={d.description} seo={d.seo}>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_title ?? d.title}
    lead={d.hero_lead}
  />

  <section class="section">
    <div class="container find-us__grid">
      <div class="find-us__map">
        <iframe
          title="Skagway Tours pickup map"
          src={d.map_embed_url ?? "https://www.google.com/maps?q=Skagway%2C%20AK&output=embed"}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>

      <div>
        {d.pickup_heading && <h2 data-editable="text" data-prop="pickup_heading">{d.pickup_heading}</h2>}

        <div class="prose" data-editable="text" data-type="block" data-prop="@content">
          <Content />
        </div>

        {d.pickup_details_heading && (
          <h3 data-editable="text" data-prop="pickup_details_heading">{d.pickup_details_heading}</h3>
        )}
        {d.pickup_details_note && (
          <p class="muted" data-editable="text" data-prop="pickup_details_note">{d.pickup_details_note}</p>
        )}

        <form class="pickup-form" action="https://formspree.io/f/REPLACE_ME" method="POST">
          <label>
            <span>Ship name</span>
            <input type="text" name="ship" required />
          </label>
          <label>
            <span>Arrival date</span>
            <input type="date" name="arrival_date" required />
          </label>
          <label>
            <span>Arrival time</span>
            <input type="time" name="arrival_time" required />
          </label>
          <label>
            <span>Email</span>
            <input type="email" name="email" required />
          </label>
          <label>
            <span>Mobile phone</span>
            <input type="tel" name="phone" />
          </label>
          <label class="full">
            <span>Anything we should know?</span>
            <textarea name="notes" rows="3"></textarea>
          </label>
          <button type="submit" class="button">Send pickup details</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .find-us__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (max-width: 880px) {
    .find-us__grid { grid-template-columns: 1fr; }
  }
  .find-us__map iframe {
    width: 100%;
    aspect-ratio: 4 / 3;
    border: 0;
    border-radius: 16px;
  }
  .muted { color: var(--c-ink-soft); font-size: 0.9rem; }
  .pickup-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1rem;
  }
  .pickup-form label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.9rem;
  }
  .pickup-form label span { font-weight: 600; }
  .pickup-form label.full { grid-column: 1 / -1; }
  .pickup-form input,
  .pickup-form textarea {
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--c-fog);
    border-radius: var(--radius-sm);
    font: inherit;
    background: #fff;
  }
  .pickup-form input:focus,
  .pickup-form textarea:focus {
    outline: 2px solid var(--c-ember);
    outline-offset: 1px;
  }
  .pickup-form button { grid-column: 1 / -1; justify-self: start; }
  @media (max-width: 560px) {
    .pickup-form { grid-template-columns: 1fr; }
    .pickup-form button { justify-self: stretch; }
  }
</style>
