---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "about");
if (!entry || entry.data._schema !== "page") {
  throw new Error("src/content/pages/about.md is missing or has the wrong _schema");
}
const d = entry.data;
const { Content } = await render(entry);
---

<BaseLayout title={d.title} description={d.description} seo={d.seo}>
  <section class="about-hero">
    <div class="about-hero__media" aria-hidden="true">
      <div class="about-hero__placeholder">
        <span class="eyebrow">[ staff & buses video — client-supplied ]</span>
      </div>
      <div class="about-hero__shade"></div>
    </div>
    <div class="container about-hero__inner">
      {d.hero_eyebrow && (
        <span class="eyebrow" data-editable="text" data-prop="hero_eyebrow">{d.hero_eyebrow}</span>
      )}
      <h1 data-editable="text" data-prop="hero_title">{d.hero_title ?? d.title}</h1>
      {d.description && (
        <p data-editable="text" data-prop="description">{d.description}</p>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container prose" data-editable="text" data-type="block" data-prop="@content">
      <Content />
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    position: relative;
    min-height: 460px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    color: #fff;
    background: var(--c-spruce-deep);
  }
  .about-hero__media { position: absolute; inset: 0; }
  .about-hero__placeholder {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, #0f2419, #1d3b2a 60%, #4d7a8c);
    display: grid; place-items: center;
  }
  .about-hero__placeholder .eyebrow {
    color: rgba(255, 255, 255, 0.6);
  }
  .about-hero__shade {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(41, 37, 70,0.75), rgba(41, 37, 70,0.15));
  }
  .about-hero__inner {
    position: relative;
    padding: 6rem 1rem 2.5rem;
  }
</style>
