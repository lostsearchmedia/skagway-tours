---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "about");
const d = entry?.data;

const FALLBACK = "https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2024/02/st_wide.jpg";

const values = [
  {
    icon: "ph:smiley-fill",
    title: "Fun",
    body: "We create memorable experiences filled with joy and excitement, ensuring every moment of your tour is enjoyable.",
  },
  {
    icon: "ph:book-open-text-fill",
    title: "Knowledgeable",
    body: "Our guides provide insightful and accurate information, enriching your understanding of Skagway's history and natural beauty.",
  },
  {
    icon: "ph:heart-fill",
    title: "Genuine",
    body: "We offer authentic and sincere experiences, connecting you with the true spirit of Alaska.",
  },
  {
    icon: "ph:hand-waving-fill",
    title: "Engaging",
    body: "Our tours are designed to be interactive and captivating, keeping you involved and entertained throughout your adventure.",
  },
  {
    icon: "ph:medal-fill",
    title: "Professional",
    body: "We deliver high-quality, reliable service with a commitment to excellence and your utmost satisfaction.",
  },
];


const expectations = [
  {
    icon: "ph:user-sound-fill",
    title: "Knowledgeable & Engaging Guides",
    body: "Our local guides know Skagway's history — particularly the 1898 Klondike Gold Rush — and have the gift of making it come alive for every passenger.",
  },
  {
    icon: "ph:camera-fill",
    title: "Stunning Scenery & Photo Stops",
    body: "6–8 stops on most tours at iconic spots like the 'Welcome to Alaska' sign, Pitchfork Falls, and Tormented Valley. Shots that train tours simply can't match.",
  },
  {
    icon: "ph:tag-fill",
    title: "Outstanding Value",
    body: "More ground, more stops, more activities than the railroad — at a fraction of the price. Suspension bridge walks, musher camps, and BBQ lunches included on select tours.",
  },
  {
    icon: "ph:headset-fill",
    title: "Exceptional Service",
    body: "Direct booking, local ownership. We answer the phone, resolve issues fast, and have never missed a ship departure — that's our All Aboard guarantee.",
  },
];
---

<BaseLayout title={d?.title} description={d?.description} seo={d?.seo}>

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="ab-hero">
    <div class="ab-hero__media" aria-hidden="true">
      <img src={FALLBACK} alt="" />
      <div class="ab-hero__shade"></div>
    </div>
    <div class="ab-hero__inner container">
      <span class="ab-eyebrow ab-eyebrow--light">About Us</span>
      <h1 class="ab-hero__title">The Crew Behind<br />Skagway Tours</h1>
      <p class="ab-hero__lead">Locally owned and led by Mike Vondette — Skagway resident, 25-year guide, and the guy whose business card says "Lead Driver."</p>
      <a href="#our-story" class="button">Our Story</a>
    </div>
  </section>

  <!-- ── Story ─────────────────────────────────────────────────── -->
  <section id="our-story" class="ab-section ab-story">
    <div class="container ab-story__grid">
      <div class="ab-story__text">
        <span class="ab-eyebrow">Our Story</span>
        <h2>Built on 25 Years<br />in the Klondike</h2>
        <p>Skagway Tours is an Alaskan company, locally owned and operated by Mike Vondette, a long-time resident of Skagway, AK. For 25+ years, Mike has been sharing his love of Alaska as a tour guide. His business card doesn't say owner — it says <strong>"Lead Driver."</strong></p>
        <p>Skagway Tours launched in 2014, built on a simple idea: <em>"Combine affordability with excellence, the flexibility to stop when we spot something interesting, and a guarantee you'll get back to your ship on time."</em></p>
        <p>Mike infuses his guides with the know-how, local knowledge, and passion that make every tour more than a bus ride — it's a story you'll tell when you get home.</p>
      </div>
      <div class="ab-story__stats">
        <div class="ab-stat">
          <span class="ab-stat__number">25+</span>
          <span class="ab-stat__label">Years guiding</span>
        </div>
        <div class="ab-stat">
          <span class="ab-stat__number">2014</span>
          <span class="ab-stat__label">Founded</span>
        </div>
        <div class="ab-stat">
          <span class="ab-stat__number">13</span>
          <span class="ab-stat__label">Passengers max</span>
        </div>
        <div class="ab-stat">
          <span class="ab-stat__number">3,000+</span>
          <span class="ab-stat__label">Five-star reviews</span>
        </div>
        <div class="ab-stat ab-stat--wide">
          <span class="ab-stat__number">100%</span>
          <span class="ab-stat__label">All Aboard guarantee — never missed a ship</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Core Values ────────────────────────────────────────────── -->
  <section class="ab-section ab-values">
    <div class="container">
      <div class="ab-section-head">
        <span class="ab-eyebrow ab-eyebrow--light">What drives us</span>
        <h2 class="ab-section-head__title">Our Core Values</h2>
      </div>
      <div class="ab-values__grid">
        {values.map((v) => (
          <article class="ab-value">
            <Icon name={v.icon} class="ab-value__icon" aria-hidden="true" />
            <h3 class="ab-value__title">{v.title}</h3>
            <p class="ab-value__body">{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Testimonials ───────────────────────────────────────────── -->
  <section class="ab-section ab-reviews">
    <div class="container">
      <div class="ab-section-head">
        <span class="ab-eyebrow ab-eyebrow--ember">What our guests say</span>
        <h2 class="ab-section-head__title">Stories From the Road</h2>
      </div>
      <div class="ab-reviews__widget">
        <script src="https://elfsightcdn.com/platform.js" async is:inline></script>
        <div class="elfsight-app-be8882ad-c2f2-4122-a216-f1f1f2793578" data-elfsight-app-lazy></div>
      </div>
      <div class="ab-reviews__cta">
        <a href="/reviews/" class="button button--dark">Read all reviews</a>
      </div>
    </div>
  </section>

  <!-- ── What to Expect ─────────────────────────────────────────── -->
  <section class="ab-section ab-expect">
    <div class="container">
      <div class="ab-section-head">
        <span class="ab-eyebrow">Before you book</span>
        <h2 class="ab-section-head__title">What to Expect</h2>
      </div>
      <div class="ab-expect__grid">
        {expectations.map((e) => (
          <article class="ab-expect-item">
            <Icon name={e.icon} class="ab-expect-item__icon" aria-hidden="true" />
            <div class="ab-expect-item__text">
              <h3 class="ab-expect-item__title">{e.title}</h3>
              <p class="ab-expect-item__body">{e.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────────────── -->
  <section class="ab-section ab-cta">
    <div class="container ab-cta__inner">
      <img src={FALLBACK} alt="" class="ab-cta__img" aria-hidden="true" />
      <div class="ab-cta__text">
        <span class="ab-eyebrow ab-eyebrow--light">Ready to go?</span>
        <h2>Come ride with Mike's crew.</h2>
        <p>Small groups. Local guides. A guarantee you'll never miss your ship.</p>
        <div class="ab-cta__actions">
          <a href="/#tours" class="button">Browse Tours</a>
          <a href="/contact/" class="button button--ghost-light">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Shared ──────────────────────────────────────────────────── */
  .ab-section { padding: clamp(3.5rem, 7vw, 6rem) 0; }

  .ab-eyebrow {
    display: inline-block;
    font-family: var(--font-accent);
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: var(--c-ember);
    margin-bottom: 0.4rem;
  }
  .ab-eyebrow--light  { color: var(--c-ember-bright); }
  .ab-eyebrow--ember  { color: var(--c-ember); }

  .ab-section-head { margin-bottom: 2.5rem; }
  .ab-section-head__title {
    font-size: clamp(1.6rem, 3vw + 0.5rem, 2.5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin: 0;
    line-height: 1.05;
  }

  /* ── Hero ────────────────────────────────────────────────────── */
  .ab-hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    color: #fff;
    overflow: hidden;
  }
  .ab-hero__media { position: absolute; inset: 0; }
  .ab-hero__media img { width: 100%; height: 100%; object-fit: cover; }
  .ab-hero__shade {
    position: absolute; inset: 0;
    background: linear-gradient(105deg,
      rgba(31, 28, 57, 0.88) 0%,
      rgba(41, 37, 70, 0.65) 60%,
      rgba(41, 37, 70, 0.25) 100%);
  }
  .ab-hero__inner {
    position: relative;
    max-width: 680px;
    padding-top: 6rem;
    padding-bottom: 4rem;
  }
  .ab-hero__title {
    font-size: clamp(2.4rem, 5vw + 1rem, 4.5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.0;
    margin: 0 0 1.25rem;
    color: #fff;
  }
  .ab-hero__lead {
    font-size: clamp(1rem, 1.5vw + 0.5rem, 1.2rem);
    max-width: 50ch;
    opacity: 0.9;
    margin: 0 0 2rem;
    line-height: 1.65;
  }

  /* ── Story ───────────────────────────────────────────────────── */
  .ab-story { background: #fff; }
  .ab-story__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  @media (max-width: 800px) {
    .ab-story__grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  .ab-story__text h2 {
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.75rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    line-height: 1.05;
    margin: 0 0 1.25rem;
  }
  .ab-story__text p {
    color: var(--c-ink-soft);
    font-size: 0.98rem;
    line-height: 1.75;
    margin: 0 0 1rem;
  }
  .ab-story__text strong { color: var(--c-ink); }
  .ab-story__text em { color: var(--c-ink); font-style: italic; }

  .ab-story__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .ab-stat {
    background: var(--c-paper-soft);
    border: 1px solid var(--c-fog);
    border-radius: 14px;
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .ab-stat--wide { grid-column: span 2; }
  .ab-stat__number {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 900;
    color: var(--c-ember);
    line-height: 1;
  }
  .ab-stat__label {
    font-size: 0.82rem;
    color: var(--c-ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: var(--font-display);
    font-weight: 600;
  }

  /* ── Values ──────────────────────────────────────────────────── */
  .ab-values {
    background: var(--c-ink);
    color: #fff;
  }
  .ab-values .ab-section-head__title { color: #fff; }
  .ab-values__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
  }
  .ab-value {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .ab-value:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-3px);
  }
  .ab-value__icon {
    width: 36px;
    height: 36px;
    color: var(--c-ember-bright);
    margin-bottom: 0.25rem;
  }
  .ab-value__title {
    font-size: 1rem;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
  }
  .ab-value__body {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Reviews ─────────────────────────────────────────────────── */
  .ab-reviews { background: var(--c-spruce); color: #fff; }
  .ab-reviews .ab-section-head__title { color: #fff; }
  .ab-reviews__widget { width: 100%; }
  .ab-reviews__cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* ── Expect ──────────────────────────────────────────────────── */
  .ab-expect { background: var(--c-paper-soft); }
  .ab-expect__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .ab-expect-item {
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 14px;
    padding: 1.75rem 1.5rem;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }
  .ab-expect-item__icon {
    width: 36px;
    height: 36px;
    color: var(--c-ember);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .ab-expect-item__title {
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin: 0 0 0.5rem;
    color: var(--c-ink);
  }
  .ab-expect-item__body {
    font-size: 0.9rem;
    color: var(--c-ink-soft);
    line-height: 1.65;
    margin: 0;
  }

  /* ── CTA ─────────────────────────────────────────────────────── */
  .ab-cta {
    background: var(--c-spruce-deep);
    color: #fff;
    padding: 0;
    overflow: hidden;
  }
  .ab-cta__inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    min-height: 400px;
  }
  @media (max-width: 760px) {
    .ab-cta__inner { grid-template-columns: 1fr; }
    .ab-cta__img { height: 240px; }
  }
  .ab-cta__img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .ab-cta__text {
    padding: clamp(2.5rem, 5vw, 5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.75rem;
  }
  .ab-cta__text h2 {
    font-size: clamp(1.6rem, 3vw + 0.5rem, 2.5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
    color: #fff;
    line-height: 1.1;
  }
  .ab-cta__text p {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 44ch;
    margin: 0;
  }
  .ab-cta__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
  :global(.button--ghost-light) {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }
  :global(.button--ghost-light:hover) {
    background: rgba(255, 255, 255, 0.1);
    border-color: #fff;
    text-decoration: none;
  }
</style>
