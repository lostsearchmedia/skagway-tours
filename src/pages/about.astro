---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getEntry, render } from "astro:content";

// Body content is driven by src/content/pages/about.md so it's editable in CloudCannon.
const entry = await getEntry("pages", "about");
const Content = entry ? (await render(entry)).Content : null;
const data = entry?.data;
---

<BaseLayout title={data?.title ?? "About"} description={data?.description}>
  <section class="about-hero">
    <div class="about-hero__media" aria-hidden="true">
      <!-- Embed the client-supplied About video here (staff + buses at the docks). -->
      <!-- Replace the src below with the actual file once supplied. -->
      <div class="about-hero__placeholder">
        <span class="eyebrow">[ staff & buses video — client-supplied ]</span>
      </div>
      <div class="about-hero__shade"></div>
    </div>
    <div class="container about-hero__inner">
      <span class="eyebrow">About us</span>
      <h1>{data?.title ?? "The crew behind Skagway Tours"}</h1>
      {data?.description && <p>{data.description}</p>}
    </div>
  </section>

  <section class="section">
    <div class="container prose">
      {Content ? <Content /> : (
        <>
          <p>
            Add your About copy in <code>src/content/pages/about.md</code> (or
            via CloudCannon once the repo is connected). This is placeholder
            copy so you can see the layout.
          </p>
          <p>
            We're a small team of Alaska and Yukon locals who've been showing
            visitors the White Pass, Emerald Lake, and the old Gold Rush trails
            since before GPS worked up here.
          </p>
        </>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    position: relative;
    min-height: 460px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    color: #fff;
    background: var(--c-spruce-deep);
  }
  .about-hero__media { position: absolute; inset: 0; }
  .about-hero__placeholder {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, #0f2419, #1d3b2a 60%, #4d7a8c);
    display: grid; place-items: center;
  }
  .about-hero__placeholder .eyebrow {
    color: rgba(255, 255, 255, 0.6);
  }
  .about-hero__shade {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(15,23,32,0.75), rgba(15,23,32,0.15));
  }
  .about-hero__inner {
    position: relative;
    padding: 6rem 1rem 2.5rem;
  }
</style>
