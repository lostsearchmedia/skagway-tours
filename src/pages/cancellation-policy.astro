---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "cancellation-policy");
const d = entry?.data;

const FALLBACK = "https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2024/02/st_wide.jpg";
const KPP_EXAMPLE = "https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2022/11/kpp1.png";

const policyPoints = [
  {
    icon: "calendar",
    title: "14-Day Window",
    body: "All tours are nonrefundable within 14 days of travel. Purchase our Klondike Prospector Protection at booking for refunds up to tour departure.",
  },
  {
    icon: "swap",
    title: "Changes & Date Swaps",
    body: "Time changes or date changes are permitted with a 20% penalty for all independent bookings.",
  },
  {
    icon: "ship",
    title: "Ship No-Shows",
    body: "A full refund is processed for ALL tours if your ship doesn't arrive in port — or arrives too late for us to accommodate you on a later departure.",
  },
  {
    icon: "link",
    title: "Third-Party Bookings",
    body: "Tours booked through a third party are subject to the rules and policies set by that operator.",
  },
  {
    icon: "id",
    title: "Border ID",
    body: "All tours require proper ORIGINAL government identification. Failure to bring the correct ID will result in a forfeit of your funds paid.",
  },
  {
    icon: "lock",
    title: "Custom & Private Tours",
    body: "Custom or Private tour sales are final. Tour price is forfeited if canceled for any reason other than your ship not arriving or arriving too late.",
  },
];

const terms = [
  "Klondike Prospector Protection is only available when making the original booking — it cannot be added after your purchase is complete.",
  "Klondike Prospector Protection is not valid for bookings made less than the Klondike Prospector Protection offer window for the specific tour start date or departure time.",
  "Klondike Prospector Protection is only valid on bookings made directly with Skagway Tours.",
  "Bookings made through third parties do not qualify for Klondike Prospector Protection.",
];

const refundProcess = [
  "Contact Skagway Tours via phone or email no less than the Klondike Prospector Protection term PRIOR to the departure time (day tours) of your activity — see your confirmation for details.",
  "Tell the reservation agent the booking number of the activity to receive a full refund, minus the Klondike Prospector Protection fee. The booking number is visible on the booking confirmation (sent via email).",
  "Klondike Prospector Protection does not qualify for no-shows or late arrivals. If a customer calls or emails less than the Klondike Prospector Protection term from the scheduled departure time, the protection will not be valid.",
];
---

<BaseLayout title={d?.title ?? "Cancellation Policy"} description={d?.description} seo={d?.seo}>

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="cnl-hero">
    <div class="cnl-hero__media" aria-hidden="true">
      <img src={FALLBACK} alt="" />
      <div class="cnl-hero__shade"></div>
    </div>
    <div class="cnl-hero__inner container">
      <span class="cnl-eyebrow cnl-eyebrow--light">Booking Peace of Mind</span>
      <h1 class="cnl-hero__title">Cancellation Policy</h1>
      <p class="cnl-hero__lead">Plans change. Weather shifts. Ships reroute. Here's exactly how refunds, changes, and Klondike Prospector Protection work.</p>
    </div>
  </section>

  <!-- ── Policy grid ──────────────────────────────────────────── -->
  <section class="cnl-section cnl-policy">
    <div class="container">
      <div class="cnl-section-head">
        <span class="cnl-eyebrow">The Basics</span>
        <h2>Our Standard Policy</h2>
        <p>Straight answers to the six questions we get asked most about cancellations.</p>
      </div>
      <div class="cnl-policy__grid">
        {policyPoints.map((point) => (
          <article class="cnl-policy-card">
            <div class="cnl-policy-card__icon" aria-hidden="true">
              {point.icon === "calendar" && (
                <svg viewBox="0 0 40 40" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="10" width="28" height="24" rx="2"/><path d="M6 18 H34 M14 6 V14 M26 6 V14"/><circle cx="14" cy="26" r="1.5" fill="currentColor" stroke="none"/></svg>
              )}
              {point.icon === "swap" && (
                <svg viewBox="0 0 40 40" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 14 H30 L26 10 M32 26 H10 L14 30"/></svg>
              )}
              {point.icon === "ship" && (
                <svg viewBox="0 0 40 40" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 26 Q20 32 32 26 L34 20 H6 Z"/><path d="M20 20 V10 M14 14 H26"/></svg>
              )}
              {point.icon === "link" && (
                <svg viewBox="0 0 40 40" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 24 L24 16"/><path d="M20 12 L24 8 Q30 6 32 12 Q34 16 30 20 L28 22"/><path d="M20 28 L16 32 Q10 34 8 28 Q6 24 10 20 L12 18"/></svg>
              )}
              {point.icon === "id" && (
                <svg viewBox="0 0 40 40" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="10" width="28" height="20" rx="2"/><circle cx="14" cy="20" r="3"/><path d="M22 18 H30 M22 24 H28"/></svg>
              )}
              {point.icon === "lock" && (
                <svg viewBox="0 0 40 40" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="10" y="18" width="20" height="16" rx="2"/><path d="M14 18 V13 Q14 7 20 7 Q26 7 26 13 V18"/></svg>
              )}
            </div>
            <h3>{point.title}</h3>
            <p>{point.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── KPP Hero intro (dark) ────────────────────────────────── -->
  <section class="cnl-section cnl-kpp-intro">
    <div class="container cnl-kpp-intro__inner">
      <span class="cnl-eyebrow cnl-eyebrow--light">Trip Cancellation Protection</span>
      <h2>Klondike Prospector Protection</h2>
      <p class="cnl-kpp-intro__sub">Flexible booking for travelers who want options.</p>
      <div class="cnl-kpp-intro__copy">
        <p>Klondike Prospector Protection was created as a way for travelers to safeguard their purchase with <a href="/">Skagway Tours</a>. With Prospector coverage added to your reservation, you get extra protection for changes in plans — full refunds with no fees allowed up to <strong>6 hours before tour time</strong>.</p>
        <p>Our Klondike Prospector Protection is especially handy when travelers are forced to cancel <strong>AFTER</strong> the standard cancellation cut-off (typically 14 days before the tour). Without it, refunds cannot be administered after the cut-off.</p>
        <p>Klondike Prospector Protection is <strong>ONLY</strong> for tours operated by Skagway Tours and may not apply to affiliates or tours in other parts of the state.</p>
      </div>
    </div>
  </section>

  <!-- ── Fees & example ───────────────────────────────────────── -->
  <section class="cnl-section cnl-fees">
    <div class="container cnl-fees__grid">
      <div class="cnl-fees__copy">
        <span class="cnl-eyebrow">Fees &amp; Conditions</span>
        <h2>How The Fee Works</h2>
        <p>The Klondike Prospector Protection fee is based on the cost of each tour — it varies by tour type. <strong>This fee is non-refundable.</strong></p>
        <p>The option to add Klondike Prospector Protection appears in the lower section of the booking form for each trip that offers it. Look for the checkbox before you finish checking out.</p>
      </div>
      <figure class="cnl-fees__example">
        <figcaption class="cnl-fees__caption">Example — as shown at checkout</figcaption>
        <img src={KPP_EXAMPLE} alt="Example of Klondike Prospector Protection option at checkout" loading="lazy" />
      </figure>
    </div>
  </section>

  <!-- ── Terms & Conditions ───────────────────────────────────── -->
  <section class="cnl-section cnl-terms">
    <div class="container cnl-terms__inner">
      <div class="cnl-terms__col">
        <span class="cnl-eyebrow">Fine Print</span>
        <h2>Terms &amp; Conditions</h2>
        <ol class="cnl-numbered">
          {terms.map((item, i) => (
            <li>
              <span class="cnl-numbered__num">{String(i + 1).padStart(2, "0")}</span>
              <span class="cnl-numbered__text">{item}</span>
            </li>
          ))}
        </ol>
      </div>
      <div class="cnl-terms__col">
        <span class="cnl-eyebrow">Step By Step</span>
        <h2>How To Get A Refund</h2>
        <ol class="cnl-numbered">
          {refundProcess.map((item, i) => (
            <li>
              <span class="cnl-numbered__num">{String(i + 1).padStart(2, "0")}</span>
              <span class="cnl-numbered__text">{item}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- ── Contact CTA ──────────────────────────────────────────── -->
  <section class="cnl-section cnl-help">
    <div class="container cnl-help__inner">
      <span class="cnl-eyebrow cnl-eyebrow--light">Questions?</span>
      <h2>We're Happy To Walk You Through It</h2>
      <p>Still not sure how the policy applies to your booking? Give us a shout — we'll sort it out.</p>
      <div class="cnl-help__actions">
        <a href="mailto:info@skagway.tours" class="button">Email Us</a>
        <a href="/faqs/" class="button button--ghost-light">View FAQs</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cnl-section { padding: clamp(3.5rem, 7vw, 6rem) 0; }

  .cnl-eyebrow {
    display: inline-block;
    font-family: var(--font-accent);
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: var(--c-ember);
    margin-bottom: 0.4rem;
  }
  .cnl-eyebrow--light { color: var(--c-ember-bright); }

  .cnl-section-head {
    text-align: center;
    margin-bottom: 2.5rem;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }
  .cnl-section-head h2 {
    font-size: clamp(2rem, 3.5vw + 1rem, 3rem);
    margin: 0;
  }
  .cnl-section-head p {
    color: var(--c-ink-soft);
    font-size: 1.05rem;
    margin: 0.75rem 0 0;
  }

  /* ── Hero ─────────────────────────────────────────────────── */
  .cnl-hero {
    position: relative;
    min-height: 50vh;
    display: flex;
    align-items: flex-end;
    color: #fff;
    overflow: hidden;
    background: var(--c-spruce-deep);
  }
  .cnl-hero__media { position: absolute; inset: 0; }
  .cnl-hero__media img { width: 100%; height: 100%; object-fit: cover; }
  .cnl-hero__shade {
    position: absolute; inset: 0;
    background: linear-gradient(105deg,
      rgba(31, 28, 57, 0.9) 0%,
      rgba(41, 37, 70, 0.65) 60%,
      rgba(41, 37, 70, 0.25) 100%);
  }
  .cnl-hero__inner {
    position: relative;
    max-width: 780px;
    padding-top: 6rem;
    padding-bottom: 4rem;
  }
  .cnl-hero__title {
    font-size: clamp(2.5rem, 5vw + 1rem, 4.5rem);
    line-height: 1.05;
    margin: 0 0 1.2rem;
    color: #fff;
  }
  .cnl-hero__lead {
    font-size: 1.15rem;
    line-height: 1.55;
    opacity: 0.95;
    max-width: 62ch;
    margin: 0;
  }

  /* ── Policy grid ──────────────────────────────────────────── */
  .cnl-policy { background: var(--c-paper); }
  .cnl-policy__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }
  .cnl-policy-card {
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 16px;
    padding: 1.75rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .cnl-policy-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(41, 37, 70, 0.2);
  }
  .cnl-policy-card__icon {
    width: 52px; height: 52px;
    border-radius: 12px;
    background: var(--c-paper-soft);
    color: var(--c-ember);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .cnl-policy-card h3 {
    font-size: 1.2rem;
    margin: 0 0 0.5rem;
    color: var(--c-ink);
  }
  .cnl-policy-card p {
    margin: 0;
    color: var(--c-ink-soft);
    line-height: 1.6;
  }

  /* ── KPP intro (dark) ─────────────────────────────────────── */
  .cnl-kpp-intro {
    background: var(--c-ink);
    color: var(--c-paper);
    text-align: center;
  }
  .cnl-kpp-intro__inner { max-width: 820px; }
  .cnl-kpp-intro h2 {
    color: #fff;
    font-size: clamp(2.25rem, 4vw + 1rem, 3.5rem);
    margin: 0 0 0.75rem;
  }
  .cnl-kpp-intro__sub {
    color: rgba(246, 241, 231, 0.7);
    font-size: 1.1rem;
    margin: 0 0 2rem;
    font-style: italic;
  }
  .cnl-kpp-intro__copy {
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .cnl-kpp-intro__copy p {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(246, 241, 231, 0.88);
  }
  .cnl-kpp-intro__copy a { color: var(--c-ember-bright); }
  .cnl-kpp-intro__copy strong { color: #fff; }

  /* ── Fees & example ───────────────────────────────────────── */
  .cnl-fees { background: var(--c-paper-soft); }
  .cnl-fees__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
    max-width: 1080px;
    margin: 0 auto;
  }
  .cnl-fees__copy h2 {
    font-size: clamp(1.75rem, 2.5vw + 1rem, 2.5rem);
    margin: 0 0 1rem;
  }
  .cnl-fees__copy p {
    margin: 0 0 1rem;
    color: var(--c-ink-soft);
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .cnl-fees__copy strong { color: var(--c-ink); }
  .cnl-fees__example {
    margin: 0;
    background: #fff;
    border-radius: 16px;
    padding: 1.25rem;
    box-shadow: 0 20px 40px -20px rgba(41, 37, 70, 0.25);
    border: 1px solid var(--c-fog);
  }
  .cnl-fees__caption {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-ink-soft);
    margin-bottom: 0.75rem;
    display: block;
  }
  .cnl-fees__example img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }
  @media (max-width: 820px) {
    .cnl-fees__grid { grid-template-columns: 1fr; }
  }

  /* ── Terms & refund columns ───────────────────────────────── */
  .cnl-terms { background: #fff; }
  .cnl-terms__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    max-width: 1100px;
    margin: 0 auto;
  }
  .cnl-terms__col h2 {
    font-size: clamp(1.5rem, 2vw + 1rem, 2rem);
    margin: 0 0 1.5rem;
  }
  .cnl-numbered {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    counter-reset: cnl-num;
  }
  .cnl-numbered li {
    display: flex;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--c-paper);
    border: 1px solid var(--c-fog);
    border-radius: 12px;
  }
  .cnl-numbered__num {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--c-ember);
    line-height: 1;
    padding-top: 0.1em;
  }
  .cnl-numbered__text {
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--c-ink);
  }
  @media (max-width: 820px) {
    .cnl-terms__inner { grid-template-columns: 1fr; }
  }

  /* ── Help CTA ─────────────────────────────────────────────── */
  .cnl-help {
    background: var(--c-spruce-deep);
    color: var(--c-paper);
    text-align: center;
  }
  .cnl-help__inner { max-width: 640px; }
  .cnl-help h2 {
    color: #fff;
    font-size: clamp(2rem, 3.5vw + 1rem, 3rem);
    margin: 0 0 1rem;
  }
  .cnl-help p {
    font-size: 1.1rem;
    margin: 0 0 1.75rem;
    color: rgba(246, 241, 231, 0.88);
  }
  .cnl-help__actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cnl-help__actions :global(.button--ghost-light) {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }
  .cnl-help__actions :global(.button--ghost-light:hover) {
    background: rgba(255, 255, 255, 0.12);
    border-color: #fff;
    text-decoration: none;
  }
</style>
