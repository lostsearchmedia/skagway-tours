---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("pages", "groups");
if (!entry || entry.data._schema !== "page") {
  throw new Error("src/content/pages/groups.md is missing or has the wrong _schema");
}
const d = entry.data;
const { Content } = await render(entry);
---

<BaseLayout title={d.title} description={d.description} seo={d.seo}>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_title ?? d.title}
    lead={d.hero_lead}
  />
  <section class="section">
    <div class="container prose" data-editable="text" data-type="block" data-prop="@content">
      <Content />
    </div>
  </section>
</BaseLayout>
