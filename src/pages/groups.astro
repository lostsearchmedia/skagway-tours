---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout title="Group sales" description="Large groups, cruise charters, and incentive programs.">
  <PageHero
    eyebrow="Group sales"
    title="Big groups, big days out"
    lead="Cruise charters, corporate incentives, school groups — we'll build the right day."
  />
  <section class="section">
    <div class="container prose">
      <p>
        Tell us what you're planning and we'll put together a proposal. Client
        to supply full copy for this page.
      </p>
      <p>
        Email <a href="mailto:groups@skagway.tours">groups@skagway.tours</a> to start.
      </p>
    </div>
  </section>
</BaseLayout>
