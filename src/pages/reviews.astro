---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("pages", "reviews");
if (!entry || entry.data._schema !== "page") {
  throw new Error("src/content/pages/reviews.md is missing or has the wrong _schema");
}
const d = entry.data;
---

<BaseLayout title={d.title} description={d.description}>
  <PageHero
    eyebrow={d.hero_eyebrow}
    title={d.hero_title ?? d.title}
    lead={d.hero_lead}
  />

  <section class="section">
    <div class="container">
      <div class="reviews-placeholder">
        {d.placeholder_text && (
          <p data-editable="text" data-prop="placeholder_text">{d.placeholder_text}</p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .reviews-placeholder {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem;
    border: 1px dashed var(--c-fog);
    border-radius: 8px;
    background: #fff;
    color: var(--c-ink-soft);
    text-align: center;
  }
</style>
