---
// Renders a "Book Now" button that opens the FareHarbor widget.
// Requires the FareHarbor lightframe script to be loaded on the page (included in BaseLayout).
// The passport interstitial intercepts this click (once per session) before FareHarbor opens.
import { Icon } from "astro-icon/components";
import { getEntry } from "astro:content";

interface Props {
  itemId?: string;
  flow?: string;
  label?: string;
  variant?: "primary" | "ghost" | "dark";
  fullWidth?: boolean;
}
const { itemId, flow, label = "Book Now", variant = "primary", fullWidth = false } = Astro.props;

const site = await getEntry("site", "default");
const shortname = site?.data.fareharbor_shortname;
const fallback = site?.data.booking_url;

const flowParam = flow ? flow : "no";
const href = shortname
  ? itemId
    ? `https://fareharbor.com/embeds/book/${shortname}/items/${itemId}/?full-items=yes&flow=${flowParam}`
    : `https://fareharbor.com/embeds/book/${shortname}/?full-items=yes&flow=${flowParam}`
  : fallback || "#";

const classList = [
  "button",
  variant === "ghost" && "button--ghost",
  variant === "dark" && "button--dark",
  fullWidth && "button--full",
]
  .filter(Boolean)
  .join(" ");
---

<a
  href={href}
  class={classList}
  data-fareharbor
  data-book-now
>
  {label}
  <Icon name="ph:arrow-right-fill" class="book-btn__arrow" aria-hidden="true" />
</a>

<style>
  .button--full { width: 100%; justify-content: center; }
  .book-btn__arrow { width: 14px; height: 14px; }
</style>
