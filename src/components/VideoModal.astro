---
// Video lightbox. Any element with [data-video-src="..."] opens a modal player.
// Only one video plays at a time (player is torn down on close).
---

<div id="video-modal" class="vm" hidden role="dialog" aria-modal="true" aria-label="Video player">
  <div class="vm__backdrop" data-vm-close></div>
  <div class="vm__panel" tabindex="-1">
    <button class="vm__close" type="button" aria-label="Close video" data-vm-close>×</button>
    <div class="vm__frame" id="vm-frame"></div>
  </div>
</div>

<script>
  const modal = document.getElementById("video-modal")!;
  const frame = document.getElementById("vm-frame")!;
  let lastFocus: HTMLElement | null = null;

  const toEmbed = (src: string): string => {
    try {
      const url = new URL(src);
      if (/(?:^|\.)youtube\.com$/.test(url.hostname)) {
        // Standard /watch?v=ID
        const v = url.searchParams.get("v");
        if (v) {
          return `https://www.youtube.com/embed/${v}?autoplay=1&rel=0&playsinline=1`;
        }
        // Shorts: /shorts/ID
        const shorts = url.pathname.match(/^\/shorts\/([^/?#]+)/);
        if (shorts) {
          return `https://www.youtube.com/embed/${shorts[1]}?autoplay=1&rel=0&playsinline=1`;
        }
        // Embed: /embed/ID — just add params if missing
        const embed = url.pathname.match(/^\/embed\/([^/?#]+)/);
        if (embed) {
          return `https://www.youtube.com/embed/${embed[1]}?autoplay=1&rel=0&playsinline=1`;
        }
      }
      if (url.hostname === "youtu.be") {
        const id = url.pathname.slice(1).split(/[/?#]/)[0];
        if (id) return `https://www.youtube.com/embed/${id}?autoplay=1&rel=0&playsinline=1`;
      }
      if (/(?:^|\.)vimeo\.com$/.test(url.hostname)) {
        const id = url.pathname.split("/").filter(Boolean).pop();
        if (id) return `https://player.vimeo.com/video/${id}?autoplay=1&playsinline=1`;
      }
    } catch {}
    return src;
  };

  const open = (src: string) => {
    lastFocus = document.activeElement as HTMLElement;
    modal.hidden = false;
    document.body.style.overflow = "hidden";

    frame.innerHTML = "";
    const mediaStyle = "position:absolute;inset:0;width:100%;height:100%;border:0;display:block";
    const isFile = /\.(mp4|webm|mov)(\?|$)/i.test(src);
    if (isFile) {
      const video = document.createElement("video");
      video.setAttribute("src", src);
      video.setAttribute("controls", "");
      video.setAttribute("autoplay", "");
      video.setAttribute("playsinline", "");
      video.muted = true;
      video.style.cssText = mediaStyle;
      frame.appendChild(video);
    } else {
      const iframe = document.createElement("iframe");
      iframe.setAttribute("src", toEmbed(src));
      iframe.setAttribute("allow", "autoplay; fullscreen; picture-in-picture");
      iframe.setAttribute("allowfullscreen", "");
      iframe.style.cssText = mediaStyle;
      frame.appendChild(iframe);
    }

    requestAnimationFrame(() => {
      (modal.querySelector(".vm__panel") as HTMLElement)?.focus();
    });
  };

  const close = () => {
    frame.innerHTML = "";
    modal.hidden = true;
    document.body.style.overflow = "";
    lastFocus?.focus?.();
  };

  // On mobile, replace the thumbnail with an inline player instead of opening
  // the lightbox — YouTube/iOS interactions inside a fixed modal are flaky.
  const isMobile = () => window.matchMedia("(max-width: 640px)").matches;

  const playInline = (container: HTMLElement, src: string) => {
    if (container.dataset.inlinePlaying === "true") return;
    container.dataset.inlinePlaying = "true";
    container.removeAttribute("data-video-src");
    container.removeAttribute("role");
    container.removeAttribute("tabindex");
    container.style.cursor = "default";

    // Measure the thumbnail's ACTUAL rendered size before we modify it.
    // This is the most reliable way to size the iframe — no dependence on
    // aspect-ratio, position, or any CSS that might be overridden.
    const rect = container.getBoundingClientRect();
    const width = Math.round(rect.width);
    let height = Math.round(rect.height);
    if (height < 40) height = Math.round(width * 0.5625); // 16:9 fallback

    // Pin the container's height so it can't collapse when we replace its
    // children (important for .tour-video which has no intrinsic height —
    // the inner __thumb child was what gave it dimensions).
    container.style.height = `${height}px`;
    container.style.minHeight = `${height}px`;

    // Nuke the existing content (thumb image, overlay, play button, badges)
    // so the iframe is the only visible element. This avoids every
    // positioning/stacking/scoping issue we've hit.
    container.replaceChildren();

    const isFile = /\.(mp4|webm|mov)(\?|$)/i.test(src);
    const style = `display:block;width:100%;height:${height}px;border:0;background:#000`;
    if (isFile) {
      const video = document.createElement("video");
      video.src = src;
      video.controls = true;
      video.autoplay = true;
      video.muted = true;
      video.playsInline = true;
      video.setAttribute("style", `${style};object-fit:cover`);
      container.appendChild(video);
    } else {
      const iframe = document.createElement("iframe");
      iframe.src = toEmbed(src);
      iframe.allow = "autoplay; fullscreen; picture-in-picture";
      iframe.allowFullscreen = true;
      iframe.setAttribute("style", style);
      container.appendChild(iframe);
    }
  };

  document.addEventListener("click", (e) => {
    const trigger = (e.target as HTMLElement).closest<HTMLElement>("[data-video-src]");
    if (!trigger) return;
    e.preventDefault();
    const src = trigger.getAttribute("data-video-src");
    if (!src) return;
    if (isMobile()) {
      playInline(trigger, src);
    } else {
      open(src);
    }
  });

  modal.querySelectorAll("[data-vm-close]").forEach((el) =>
    el.addEventListener("click", close)
  );

  document.addEventListener("keydown", (e) => {
    if (!modal.hidden && e.key === "Escape") close();
  });
</script>

<style>
  .vm {
    position: fixed;
    inset: 0;
    z-index: 110;
    display: grid;
    place-items: center;
    padding: 1rem;
  }
  .vm[hidden] { display: none; }
  .vm__backdrop {
    position: absolute; inset: 0;
    background: rgba(0, 0, 0, 0.85);
  }
  .vm__panel {
    position: relative;
    width: min(100%, 960px);
    aspect-ratio: 16 / 9;
    background: #000;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .vm__frame {
    position: absolute;
    inset: 0;
  }
  .vm__frame iframe, .vm__frame video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .vm__close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 2;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    color: #fff;
    transition: background 0.15s ease;
  }
  .vm__close:hover {
    background: var(--c-ember);
    border-color: var(--c-ember);
  }

  /* ── Mobile: fill the viewport so the video is actually watchable ─── */
  @media (max-width: 640px) {
    .vm {
      padding: 0;
      place-items: stretch;
    }
    .vm__panel {
      width: 100%;
      max-width: none;
      height: 100svh;
      aspect-ratio: auto;
      border-radius: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .vm__frame {
      position: relative;
      inset: auto;
      width: 100%;
      aspect-ratio: 16 / 9;
      max-height: 100%;
    }
    .vm__close {
      top: max(0.75rem, env(safe-area-inset-top));
      right: max(0.75rem, env(safe-area-inset-right));
      width: 44px;
      height: 44px;
      font-size: 1.6rem;
      background: rgba(0, 0, 0, 0.6);
      border-color: rgba(255, 255, 255, 0.5);
    }
  }
</style>
