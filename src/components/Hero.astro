---
import { getEntry } from "astro:content";

const site = await getEntry("site", "default");
const hero = site?.data.hero;
const videoSrc = hero?.video_src;
const poster = hero?.video_poster;
const ctaLabel = hero?.primary_cta_label ?? "Book a Tour";
const ctaHref = hero?.primary_cta_href ?? "#tours";
---

<section class="hero">
  <div class="hero__media" aria-hidden="true">
    {
      videoSrc ? (
        <video
          src={videoSrc}
          poster={poster}
          autoplay
          loop
          muted
          playsinline
        />
      ) : (
        <div class="hero__placeholder">
          <span class="eyebrow">[ hero video goes here ]</span>
        </div>
      )
    }
  </div>

  <div class="hero__content container">
    <div class="hero__reviews" aria-label="Guest reviews">
      <script src="https://elfsightcdn.com/platform.js" async is:inline></script>
      <div class="elfsight-app-cef6aa1d-9689-489a-a453-893dde2e56a8" data-elfsight-app-lazy></div>
    </div>
    <a href={ctaHref} class="button hero__cta">{ctaLabel}</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: clamp(520px, 80vh, 780px);
    display: flex;
    align-items: flex-end;
    color: #fff;
    overflow: hidden;
  }
  .hero__media {
    position: absolute; inset: 0;
  }
  .hero__media video {
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .hero__placeholder {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, #1f1c39 0%, #292546 60%, #3d3870 100%);
    display: grid; place-items: center;
  }
  .hero__placeholder .eyebrow {
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: 0.3em;
  }
  .hero__content {
    position: relative;
    padding: 6rem 1rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    flex-wrap: wrap;
    width: 100%;
  }
  .hero__cta {
    font-size: 1.05rem;
    padding: 1.1rem 2rem;
  }
  /* Elfsight reviews widget wrapper — keep the card compact in the hero */
  .hero__reviews {
    width: 100%;
    max-width: 260px;
  }
  .hero__reviews :global(.elfsight-app-cef6aa1d-9689-489a-a453-893dde2e56a8) {
    display: block;
  }
  @media (max-width: 640px) {
    .hero__reviews { max-width: 220px; }
  }
</style>
