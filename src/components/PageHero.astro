---
import { Image } from "astro:assets";

interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  image?: ImageMetadata;
  video?: string;
}
const { eyebrow, title, lead, image, video } = Astro.props;
---

<section class="page-hero">
  <div class="page-hero__media" aria-hidden="true">
    {video ? (
      <video src={video} autoplay muted loop playsinline />
    ) : image ? (
      <Image src={image} alt="" widths={[1200, 1800, 2400]} sizes="100vw" />
    ) : (
      <div class="page-hero__fallback"></div>
    )}
    <div class="page-hero__shade"></div>
  </div>
  <div class="container page-hero__inner">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h1>{title}</h1>
    {lead && <p class="page-hero__lead">{lead}</p>}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    min-height: 380px;
    display: flex;
    align-items: flex-end;
    color: #fff;
    overflow: hidden;
    background: var(--c-spruce-deep);
  }
  .page-hero__media { position: absolute; inset: 0; }
  .page-hero__media img,
  .page-hero__media video {
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .page-hero__fallback {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, #0f2419, #1d3b2a 60%, #4d7a8c);
  }
  .page-hero__shade {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(41, 37, 70,0.75), rgba(41, 37, 70,0.25));
  }
  .page-hero__inner {
    position: relative;
    padding: 6rem 1rem 2.5rem;
  }
  .page-hero__lead { font-size: 1.15rem; max-width: 60ch; opacity: 0.95; }
</style>
