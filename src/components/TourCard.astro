---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

interface Props {
  slug: string;
  title: string;
  summary: string;
  image?: ImageMetadata;
  duration?: number;
  priceFrom?: number;
  priceChild?: number;
  videoUrl?: string;
  fareharborItemId?: string;
  featured?: boolean;
  featuredColor?: string;
  featuredIcon?: "group" | "luxury";
}

const {
  slug,
  title,
  summary,
  image,
  duration,
  priceFrom,
  priceChild,
  videoUrl,
  fareharborItemId,
  featured = false,
  featuredColor = "#1f1c39",
  featuredIcon = "group",
} = Astro.props;

const candidatePrices = [priceFrom, priceChild].filter(
  (p): p is number => typeof p === "number" && p > 0
);
const displayPrice = candidatePrices.length ? Math.min(...candidatePrices) : undefined;

const detailHref = `/tours/${slug}/`;
const FALLBACK = "https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2024/02/st_wide.jpg";
---

<article class:list={["tour-card", featured && "tour-card--featured"]}>

  <!-- Media: opens video lightbox if video exists, otherwise inert -->
  <div
    class:list={["tour-card__media", videoUrl && "tour-card__media--playable"]}
    data-video-src={videoUrl || undefined}
    style={undefined}
    role={videoUrl ? "button" : undefined}
    tabindex={videoUrl ? 0 : undefined}
    aria-label={videoUrl ? `Watch ${title} video` : undefined}
  >
    {!featured && image && <Image src={image} alt={title} widths={[400, 600, 800]} sizes="(max-width: 700px) 100vw, 33vw" />}
    {(!featured && !image) && (
      <img class="tour-card__media-fallback" src={FALLBACK} alt="" loading="lazy" />
    )}

    {featured && (
      <img class="tour-card__media-fallback" src={FALLBACK} alt="" loading="lazy" />
    )}

    {!featured && duration && (
      <span class="tour-card__badge" aria-label={`${duration} hour tour`}>
        <Icon name="ph:clock-fill" class="tour-card__badge-icon" aria-hidden="true" />
        {duration}h
      </span>
    )}

    {videoUrl && (
      <div class="tour-card__play" aria-hidden="true">
        <Icon name="ph:play-fill" class="tour-card__play-icon" aria-hidden="true" />
      </div>
    )}
  </div>

  <div class="tour-card__body" style={featured ? `background: ${featuredColor};` : undefined}>
    <h3 class="tour-card__title">
      <a href={detailHref} data-passport-interstitial>{title}</a>
    </h3>
    <p class="tour-card__summary">{summary}</p>

    <div class="tour-card__footer">
      <div class="tour-card__price">
        {displayPrice && (
          <>
            <span class="tour-card__price-label">From</span>
            <span class="tour-card__price-value">${displayPrice}</span>
          </>
        )}
      </div>
      <div class="tour-card__actions">
        <a href={detailHref} class:list={["button", featured ? "button--ghost-light" : "button--dark"]} data-passport-interstitial>Details</a>
        <a href={detailHref} class:list={["button", featured && "button--white"]} data-passport-interstitial>Book</a>
      </div>
    </div>
  </div>
</article>

<style>
  .tour-card {
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 1px 2px rgba(41, 37, 70, 0.04);
  }
  .tour-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 48px -20px rgba(41, 37, 70, 0.28);
  }
  .tour-card--featured {
    border-color: transparent;
    box-shadow: 0 8px 32px -8px rgba(41, 37, 70, 0.3);
  }
  .tour-card--featured:hover {
    box-shadow: 0 28px 56px -16px rgba(41, 37, 70, 0.45);
  }

  /* ── Media section ─────────────────────────────────────────── */
  .tour-card__media {
    position: relative;
    aspect-ratio: 16 / 9;
    display: block;
    overflow: hidden;
    background: var(--c-fog);
  }
  .tour-card__media img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
    display: block;
  }
  .tour-card--playable,
  .tour-card__media--playable {
    cursor: pointer;
  }
  .tour-card:hover .tour-card__media img { transform: scale(1.05); }

  .tour-card__media-fallback {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }

  .tour-card__play { z-index: 2; }
  .tour-card__badge { z-index: 2; }

  /* ── Play button ────────────────────────────────────────────── */
  .tour-card__play {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(15, 10, 30, 0.55);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    pointer-events: none;
  }
  .tour-card__play-icon {
    width: 22px;
    height: 22px;
    transform: translateX(1px);
  }
  .tour-card__badge-icon { width: 12px; height: 12px; }
  .tour-card__media--playable:hover .tour-card__play {
    background: var(--c-ember);
    transform: scale(1.15);
    box-shadow: 0 4px 16px rgba(0,0,0,0.35);
  }

  /* ── Duration badge ─────────────────────────────────────────── */
  .tour-card__badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.7rem;
    background: #fff;
    color: var(--c-ink);
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    box-shadow: 0 4px 12px -4px rgba(41, 37, 70, 0.2);
  }

  /* ── Body ──────────────────────────────────────────────────── */
  .tour-card__body {
    padding: 1.25rem 1.4rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .tour-card__title {
    margin: 0;
    font-size: 1.2rem;
    letter-spacing: 0.02em;
    line-height: 1.15;
  }
  .tour-card__title a {
    color: var(--c-ink);
  }
  .tour-card--featured .tour-card__title a {
    color: #fff;
  }
  .tour-card__title a:hover {
    color: var(--c-ember);
    text-decoration: none;
  }
  .tour-card--featured .tour-card__title a:hover {
    color: rgba(255, 255, 255, 0.75);
  }
  .tour-card__summary {
    margin: 0;
    color: var(--c-ink-soft);
    font-size: 0.95rem;
    flex: 1;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    overflow: hidden;
  }
  .tour-card--featured .tour-card__summary {
    color: rgba(255, 255, 255, 0.72);
  }
  .tour-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.75rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--c-fog);
  }
  .tour-card--featured .tour-card__footer {
    border-top-color: rgba(255, 255, 255, 0.18);
  }
  .tour-card__price {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .tour-card__price-label {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-ink-soft);
  }
  .tour-card--featured .tour-card__price-label {
    color: rgba(255, 255, 255, 0.6);
  }
  .tour-card__price-value {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--c-ink);
  }
  .tour-card--featured .tour-card__price-value {
    color: #fff;
  }
  .tour-card__actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-shrink: 0;
  }

  /* Button overrides — smaller for card use */
  .tour-card__footer :global(.button) {
    padding: 0.55rem 1.15rem;
    font-size: 0.78rem;
    letter-spacing: 0.15em;
  }

  .tour-card__footer :global(.button--ghost-light) {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }
  .tour-card__footer :global(.button--ghost-light:hover) {
    background: rgba(255, 255, 255, 0.12);
    border-color: #fff;
    text-decoration: none;
    transform: translateY(-1px);
  }

  .tour-card__footer :global(.button--white) {
    background: #fff;
    color: var(--c-ink);
    border-color: #fff;
  }
  .tour-card__footer :global(.button--white:hover) {
    background: var(--c-paper);
    border-color: var(--c-paper);
    text-decoration: none;
    transform: translateY(-1px);
  }
</style>
