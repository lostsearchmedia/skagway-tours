---
import { Image } from "astro:assets";
import BookButton from "./BookButton.astro";

interface Props {
  slug: string;
  title: string;
  summary: string;
  image?: ImageMetadata;
  duration?: number;
  difficulty?: string;
  priceFrom?: number;
  videoUrl?: string;
  fareharborItemId?: string;
}

const {
  slug,
  title,
  summary,
  image,
  duration,
  difficulty,
  priceFrom,
  videoUrl,
  fareharborItemId,
} = Astro.props;

const detailHref = `/tours/${slug}/`;
---

<article class="tour-card">
  <a
    class="tour-card__media"
    href={detailHref}
    data-passport-interstitial
    aria-label={`See ${title} details`}
  >
    {image && <Image src={image} alt={title} widths={[400, 600, 800]} sizes="(max-width: 700px) 100vw, 33vw" />}
    {!image && (
      <img
        class="tour-card__media-fallback"
        src="https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp,p_h/skagway.tours/wp-content/uploads/2024/02/st_wide.jpg"
        alt=""
        loading="lazy"
      />
    )}

    {duration && (
      <span class="tour-card__badge" aria-label={`${duration} hour tour`}>
        <svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true">
          <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2" />
          <path d="M12 7 V12 L15 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        {duration}h
      </span>
    )}

    {
      videoUrl && (
        <button
          class="tour-card__video"
          type="button"
          data-video-src={videoUrl}
          aria-label={`Watch ${title} video`}
        >
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
            <path d="M8 5 L19 12 L8 19 Z" fill="currentColor" />
          </svg>
          Watch
        </button>
      )
    }
  </a>

  <div class="tour-card__body">
    <span class="tour-card__eyebrow script script--accent">Skagway tour</span>
    <h3 class="tour-card__title">
      <a href={detailHref} data-passport-interstitial>{title}</a>
    </h3>
    <p class="tour-card__summary">{summary}</p>

    <div class="tour-card__footer">
      <div class="tour-card__price">
        {priceFrom && (
          <>
            <span class="tour-card__price-label">From</span>
            <span class="tour-card__price-value">${priceFrom}</span>
          </>
        )}
        {difficulty && <span class="tour-card__difficulty">{difficulty}</span>}
      </div>
      <BookButton itemId={fareharborItemId} label="Book" />
    </div>
  </div>
</article>

<style>
  .tour-card {
    background: #fff;
    border: 1px solid var(--c-fog);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 1px 2px rgba(41, 37, 70, 0.04);
  }
  .tour-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 48px -20px rgba(41, 37, 70, 0.28);
  }

  .tour-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    display: block;
    overflow: hidden;
    background: var(--c-fog);
  }
  .tour-card__media:hover { text-decoration: none; }
  .tour-card__media img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }
  .tour-card:hover .tour-card__media img { transform: scale(1.05); }

  .tour-card__media-fallback {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }

  .tour-card__badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.7rem;
    background: #fff;
    color: var(--c-ink);
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    box-shadow: 0 4px 12px -4px rgba(41, 37, 70, 0.2);
  }

  .tour-card__video {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.75rem;
    background: rgba(41, 37, 70, 0.85);
    color: #fff;
    border: none;
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 0.7rem;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .tour-card__video:hover { background: var(--c-ember); }

  .tour-card__body {
    padding: 1.25rem 1.4rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .tour-card__eyebrow {
    font-size: 1.25rem;
    margin-bottom: -0.25rem;
  }
  .tour-card__title {
    margin: 0;
    font-size: 1.2rem;
    letter-spacing: 0.02em;
    line-height: 1.15;
  }
  .tour-card__title a {
    color: var(--c-ink);
  }
  .tour-card__title a:hover {
    color: var(--c-ember);
    text-decoration: none;
  }
  .tour-card__summary {
    margin: 0;
    color: var(--c-ink-soft);
    font-size: 0.95rem;
    flex: 1;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    overflow: hidden;
  }
  .tour-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.75rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--c-fog);
  }
  .tour-card__price {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .tour-card__price-label {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-ink-soft);
  }
  .tour-card__price-value {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--c-ink);
  }
  .tour-card__difficulty {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-ink-soft);
    margin-top: 0.2rem;
  }

  /* Book button override — smaller, tighter for card use. */
  .tour-card__footer :global(.button) {
    padding: 0.55rem 1.15rem;
    font-size: 0.78rem;
    letter-spacing: 0.15em;
  }
</style>
