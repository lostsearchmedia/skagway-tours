---
import { getEntry } from "astro:content";

const site = await getEntry("site", "default");
const rawPhone = site?.data.phone ?? "";
const email    = site?.data.email ?? "";

// Strip everything except digits and leading + for tel:/sms: links
const telNum = rawPhone.replace(/[^\d+]/g, "");
---

<nav class="mob-bar" aria-label="Quick contact">
  <a href={`tel:${telNum}`} class="mob-bar__item">
    <svg aria-hidden="true" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 4 Q6 3 7.5 5.5 L9.5 9 Q10 10 9 11 L7.5 12.5 Q9.5 16.5 12 19 L13.5 17.5 Q14.5 16.5 15.5 17 L19 19 Q21.5 20.5 20.5 22 Q19 24 16 22 Q8 18 2 10 Q0 7 5 4 Z"/>
    </svg>
    <span>Call</span>
  </a>

  <a href={`sms:${telNum}`} class="mob-bar__item">
    <svg aria-hidden="true" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 4 H20 Q21 4 21 5 V15 Q21 16 20 16 H8 L4 20 V5 Q4 4 5 4 Z"/>
      <path d="M8 9.5 H16 M8 12.5 H13"/>
    </svg>
    <span>Text</span>
  </a>

  <a href={`mailto:${email}`} class="mob-bar__item">
    <svg aria-hidden="true" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="5" width="18" height="14" rx="2"/>
      <path d="M3 7 L12 13 L21 7"/>
    </svg>
    <span>Email</span>
  </a>

  <a href="/find-us/" class="mob-bar__item">
    <svg aria-hidden="true" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2 C8.5 2 6 5 6 8.5 C6 13.5 12 22 12 22 C12 22 18 13.5 18 8.5 C18 5 15.5 2 12 2 Z"/>
      <circle cx="12" cy="8.5" r="2.5"/>
    </svg>
    <span>Find Us</span>
  </a>
</nav>

<style>
  .mob-bar {
    display: none;
  }

  @media (max-width: 880px) {
    .mob-bar {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 30;
      background: #fff;
      border-top: 1px solid var(--c-fog);
      box-shadow: 0 -4px 20px -4px rgba(41, 37, 70, 0.12);
    }
  }

  .mob-bar__item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 0.6rem 0.25rem 0.7rem;
    color: var(--c-ink-soft);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.15s ease, background 0.15s ease;
    border-right: 1px solid var(--c-fog);
  }
  .mob-bar__item:last-child {
    border-right: none;
  }
  .mob-bar__item:hover,
  .mob-bar__item:active {
    color: var(--c-ember);
    background: var(--c-paper-soft);
    text-decoration: none;
  }
  .mob-bar__item svg {
    flex-shrink: 0;
  }
</style>
