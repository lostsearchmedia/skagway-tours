---
import { Icon } from "astro-icon/components";
import { getEntry } from "astro:content";

const site = await getEntry("site", "default");
const rawPhone = site?.data.phone ?? "";
const email    = site?.data.email ?? "";

const telNum = rawPhone.replace(/[^\d+]/g, "");
---

<nav class="mob-bar" aria-label="Quick contact">
  <a href={`tel:${telNum}`} class="mob-bar__item">
    <Icon name="ph:phone-fill" class="mob-bar__icon" aria-hidden="true" />
    <span>Call</span>
  </a>

  <a href={`sms:${telNum}`} class="mob-bar__item">
    <Icon name="ph:chat-circle-text-fill" class="mob-bar__icon" aria-hidden="true" />
    <span>Text</span>
  </a>

  <a href={`mailto:${email}`} class="mob-bar__item">
    <Icon name="ph:envelope-fill" class="mob-bar__icon" aria-hidden="true" />
    <span>Email</span>
  </a>

  <a href="/find-us/" class="mob-bar__item">
    <Icon name="ph:map-pin-fill" class="mob-bar__icon" aria-hidden="true" />
    <span>Find Us</span>
  </a>
</nav>

<style>
  .mob-bar {
    display: none;
  }

  @media (max-width: 880px) {
    .mob-bar {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 30;
      background: #fff;
      border-top: 1px solid var(--c-fog);
      box-shadow: 0 -4px 20px -4px rgba(41, 37, 70, 0.12);
    }
  }

  .mob-bar__item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 0.6rem 0.25rem 0.7rem;
    color: var(--c-ink-soft);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.15s ease, background 0.15s ease;
    border-right: 1px solid var(--c-fog);
  }
  .mob-bar__item:last-child { border-right: none; }
  .mob-bar__item:hover,
  .mob-bar__item:active {
    color: var(--c-ember);
    background: var(--c-paper-soft);
    text-decoration: none;
  }
  .mob-bar__icon { width: 22px; height: 22px; flex-shrink: 0; }
</style>
