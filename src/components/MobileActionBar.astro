---
import { getEntry } from "astro:content";

const site = await getEntry("site", "default");
const rawPhone = site?.data.phone ?? "";
const email    = site?.data.email ?? "";

const telNum = rawPhone.replace(/[^\d+]/g, "");
---

<nav class="mob-bar" aria-label="Quick contact">
  <a href={`tel:${telNum}`} class="mob-bar__item">
    <!-- Phone fill -->
    <svg aria-hidden="true" viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
      <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.58.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.01L6.6 10.8z"/>
    </svg>
    <span>Call</span>
  </a>

  <a href={`sms:${telNum}`} class="mob-bar__item">
    <!-- Chat bubble fill -->
    <svg aria-hidden="true" viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
      <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
    </svg>
    <span>Text</span>
  </a>

  <a href={`mailto:${email}`} class="mob-bar__item">
    <!-- Envelope fill -->
    <svg aria-hidden="true" viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
      <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
    </svg>
    <span>Email</span>
  </a>

  <a href="/find-us/" class="mob-bar__item">
    <!-- Location pin fill -->
    <svg aria-hidden="true" viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
      <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
    </svg>
    <span>Find Us</span>
  </a>
</nav>

<style>
  .mob-bar {
    display: none;
  }

  @media (max-width: 880px) {
    .mob-bar {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 30;
      background: #fff;
      border-top: 1px solid var(--c-fog);
      box-shadow: 0 -4px 20px -4px rgba(41, 37, 70, 0.12);
    }
  }

  .mob-bar__item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 0.6rem 0.25rem 0.7rem;
    color: var(--c-ink-soft);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.15s ease, background 0.15s ease;
    border-right: 1px solid var(--c-fog);
  }
  .mob-bar__item:last-child { border-right: none; }
  .mob-bar__item:hover,
  .mob-bar__item:active {
    color: var(--c-ember);
    background: var(--c-paper-soft);
    text-decoration: none;
  }
  .mob-bar__item svg { flex-shrink: 0; }
</style>
