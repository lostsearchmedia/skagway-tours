---
import { Icon } from "astro-icon/components";
import { getEntry } from "astro:content";

const site = await getEntry("site", "default");
const s = site?.data;
const year = new Date().getFullYear();

const socials = [
  { href: "https://www.facebook.com/skagwaytours", icon: "ph:facebook-logo-fill", label: "Facebook" },
  { href: "https://www.instagram.com/skagwaytours/", icon: "ph:instagram-logo-fill", label: "Instagram" },
  { href: "https://www.youtube.com/@SkagwayTours", icon: "ph:youtube-logo-fill", label: "YouTube" },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <a href="/" class="site-footer__logo-link" aria-label="Skagway Tours home">
        <img
          src="https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp/skagway.tours/wp-content/uploads/2024/02/skagwaytours_logo.svg"
          alt={s?.site_name ?? "Skagway Tours"}
          width="160"
          height="48"
          loading="lazy"
          class="site-footer__logo"
        />
      </a>
      <p class="site-footer__tagline">{s?.tagline}</p>
      {
        s?.address && (
          <p class="site-footer__contact site-footer__address">
            {s.address.split("\n").map((line, i) => (
              <>{line}{i < s.address!.split("\n").length - 1 && <br />}</>
            ))}
          </p>
        )
      }
      {
        s?.phone && (
          <p class="site-footer__contact">
            <a href={`tel:${s.phone.replace(/[^+\d]/g, "")}`}>{s.phone}</a>
          </p>
        )
      }
      {
        s?.email && (
          <p class="site-footer__contact">
            <a href={`mailto:${s.email}`}>{s.email}</a>
          </p>
        )
      }

      <div class="site-footer__socials" aria-label="Follow us">
        {socials.map((s) => (
          <a href={s.href} class="social-icon" aria-label={s.label} target="_blank" rel="noopener noreferrer">
            <Icon name={s.icon} aria-hidden="true" />
          </a>
        ))}
      </div>
    </div>

    <nav class="site-footer__groups" aria-label="Footer">
      {
        (s?.footer_groups ?? []).map((group) => (
          <div class="footer-group">
            <h4>{group.heading}</h4>
            <ul>
              {group.links.map((l) => (
                <li>
                  <a href={l.href}>{l.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </nav>
  </div>

  <div class="site-footer__base container">
    <small>© {year} {s?.site_name ?? "Skagway Tours"}. All rights reserved.</small>
  </div>
</footer>

<style>
  .site-footer {
    background: #fff;
    color: var(--c-ink);
    border-top: 1px solid var(--c-fog);
    padding: 4rem 0 1.5rem;
  }
  .site-footer__inner {
    display: grid;
    grid-template-columns: 1.1fr 2fr;
    gap: 3rem;
  }
  @media (max-width: 780px) {
    .site-footer__inner { grid-template-columns: 1fr; gap: 2rem; }
  }
  .site-footer__logo-link { display: inline-block; margin-bottom: 1rem; }
  .site-footer__logo {
    display: block;
    height: 44px;
    width: auto;
  }
  .site-footer__tagline { color: var(--c-ink-soft); max-width: 38ch; margin-bottom: 0.75rem; }
  .site-footer__contact { margin: 0.2rem 0; font-size: 0.92rem; color: var(--c-ink-soft); }
  .site-footer__address { line-height: 1.5; }
  .site-footer__contact a { color: var(--c-ink-soft); }
  .site-footer__contact a:hover { color: var(--c-ember); }

  .site-footer__socials {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }
  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid var(--c-fog);
    color: var(--c-ink-soft);
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .social-icon svg { width: 18px; height: 18px; }
  .social-icon:hover {
    color: var(--c-ember);
    border-color: var(--c-ember);
    background: rgba(221,81,84,0.06);
    text-decoration: none;
  }

  .site-footer__groups {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2rem;
  }
  .footer-group h4 {
    font-size: 0.85rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-ember);
    margin-bottom: 0.75rem;
    font-weight: 700;
  }
  .footer-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .footer-group a {
    color: var(--c-ink-soft);
    font-size: 0.95rem;
  }
  .footer-group a:hover { color: var(--c-ember); }

  .site-footer__base {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--c-fog);
    color: var(--c-ink-soft);
    font-size: 0.85rem;
  }
</style>
