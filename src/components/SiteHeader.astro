---
import { getEntry } from "astro:content";

interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const site = await getEntry("site", "default");
const s = site?.data;
const nav = s?.nav ?? [];
const promo = s?.promo_banner;
const phone = s?.phone;
const phoneLabel = s?.phone_label ?? "Call or Text";
const telNum = phone?.replace(/[^\d+]/g, "") ?? "";
---

<header class:list={["site-header", { transparent }]}>
  <div class="site-header__bar container">

    <a href="/" class="brand" aria-label={s?.site_name ?? "Skagway Tours"}>
      <img class="brand__logo"
        src="https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp/skagway.tours/wp-content/uploads/2024/02/skagwaytours_logo.svg"
        alt={s?.site_name ?? "Skagway Tours"} width="180" height="48" />
    </a>

    {promo?.enabled && promo.text && (
      <button class="promo-bar" type="button" data-promo-copy aria-label="Copy promo code">
        <span class="promo-bar__dot" aria-hidden="true"></span>
        <span class="promo-bar__text">{promo.text}</span>
        <span class="promo-bar__ack" aria-live="assertive"></span>
      </button>
    )}

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {nav.map((item) =>
          item.children?.length ? (
            <li class="has-dropdown">
              <button type="button" aria-haspopup="true" aria-expanded="false">
                {item.label}
                <svg aria-hidden="true" width="10" height="10" viewBox="0 0 10 10">
                  <path d="M1 3 L5 7 L9 3" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
                </svg>
              </button>
              <ul class="dropdown" role="menu">
                {item.children.map((c) => (
                  <li><a href={c.href}>{c.label}</a></li>
                ))}
              </ul>
            </li>
          ) : (
            <li><a href={item.href ?? "#"}>{item.label}</a></li>
          )
        )}
      </ul>
    </nav>

    {phone && (
      <a class="phone-cta" href={`tel:${telNum}`}>
        <span class="phone-cta__label">{phoneLabel}</span>
        <span class="phone-cta__number">{phone}</span>
      </a>
    )}

    <button class="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16"/>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile navigation overlay -->
<div id="mobile-nav" class="mobile-nav" aria-hidden="true" role="dialog" aria-label="Site navigation">
  <div class="mobile-nav__inner">
    <div class="mobile-nav__head">
      <a href="/" class="brand" aria-label={s?.site_name ?? "Skagway Tours"}>
        <img class="brand__logo"
          src="https://spcdn.shortpixel.ai/spio/ret_img,q_cdnize,to_webp,s_webp/skagway.tours/wp-content/uploads/2024/02/skagwaytours_logo.svg"
          alt={s?.site_name ?? "Skagway Tours"} width="160" height="43" />
      </a>
      <button class="mobile-nav__close" type="button" aria-label="Close menu">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
          <path d="M5 5L19 19M19 5L5 19"/>
        </svg>
      </button>
    </div>

    <nav class="mobile-nav__links" aria-label="Mobile navigation">
      <ul>
        {nav.map((item) =>
          item.children?.length ? (
            <li class="mn-item mn-has-sub">
              <button class="mn-link mn-toggle" type="button" aria-expanded="false">
                {item.label}
                <svg class="mn-chevron" aria-hidden="true" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <path d="M4 7L9 12L14 7"/>
                </svg>
              </button>
              <ul class="mn-sub">
                {item.children.map((c) => (
                  <li><a class="mn-sub-link" href={c.href}>{c.label}</a></li>
                ))}
              </ul>
            </li>
          ) : (
            <li class="mn-item">
              <a class="mn-link" href={item.href ?? "#"}>{item.label}</a>
            </li>
          )
        )}
      </ul>
    </nav>

    {phone && (
      <div class="mobile-nav__foot">
        <a href={`tel:${telNum}`} class="mobile-nav__phone">
          <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" fill="currentColor">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.58.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.01L6.6 10.8z"/>
          </svg>
          {phone}
        </a>
      </div>
    )}
  </div>
</div>

<script>
  /* ── Mobile nav ─────────────────────────────────────────────── */
  const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
  const mobileNav = document.getElementById("mobile-nav");
  const closeBtn = mobileNav?.querySelector<HTMLButtonElement>(".mobile-nav__close");

  const openMenu = () => {
    if (!mobileNav) return;
    mobileNav.classList.add("is-open");
    mobileNav.setAttribute("aria-hidden", "false");
    toggle?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
    closeBtn?.focus();
  };
  const closeMenu = () => {
    if (!mobileNav) return;
    mobileNav.classList.remove("is-open");
    mobileNav.setAttribute("aria-hidden", "true");
    toggle?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
    toggle?.focus();
  };

  toggle?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && mobileNav?.classList.contains("is-open")) closeMenu();
  });

  mobileNav?.querySelectorAll<HTMLButtonElement>(".mn-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const li = btn.closest(".mn-has-sub")!;
      const isOpen = li.classList.toggle("is-open");
      btn.setAttribute("aria-expanded", String(isOpen));
    });
  });

  /* ── Desktop dropdown ───────────────────────────────────────── */
  document.querySelectorAll(".has-dropdown > button").forEach((btn) => {
    btn.addEventListener("click", () => {
      const li = btn.parentElement!;
      const wasOpen = li.classList.contains("is-open");
      document.querySelectorAll(".has-dropdown.is-open").forEach((x) => x.classList.remove("is-open"));
      if (!wasOpen) li.classList.add("is-open");
      btn.setAttribute("aria-expanded", (!wasOpen).toString());
    });
  });
  document.addEventListener("click", (e) => {
    if (!(e.target as HTMLElement).closest(".has-dropdown, .mobile-nav")) {
      document.querySelectorAll(".has-dropdown.is-open").forEach((x) => x.classList.remove("is-open"));
    }
  });

  /* ── Promo copy-to-clipboard ────────────────────────────────── */
  const promoBtn = document.querySelector<HTMLButtonElement>("[data-promo-copy]");
  if (promoBtn) {
    const textEl = promoBtn.querySelector(".promo-bar__text");
    const ackEl = promoBtn.querySelector<HTMLElement>(".promo-bar__ack");

    promoBtn.addEventListener("click", async () => {
      const raw = textEl?.textContent ?? "";
      const match = raw.match(/\b[A-Z][A-Z0-9]{2,}\b/);
      const code = match?.[0] ?? raw.trim();
      try {
        await navigator.clipboard.writeText(code);
        if (ackEl) ackEl.textContent = `✓ ${code} copied!`;
        promoBtn.classList.add("is-copied");
        setTimeout(() => promoBtn.classList.remove("is-copied"), 2400);
      } catch {}
    });
  }
</script>

<style>
  /* ── Site header ────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--c-ink);
    color: var(--c-paper);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .site-header.transparent {
    position: absolute;
    left: 0; right: 0;
    background: #292546bf;
    backdrop-filter: blur(18px) saturate(1.6);
    -webkit-backdrop-filter: blur(18px) saturate(1.6);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 2px 24px rgba(0, 0, 0, 0.12);
  }

  /* ── Top bar ────────────────────────────────────────────────── */
  .site-header__bar {
    display: grid;
    grid-template-columns: auto 1fr auto auto auto;
    align-items: center;
    gap: 1.25rem;
    padding: 0.85rem 1rem;
  }

  /* ── Brand ──────────────────────────────────────────────────── */
  .brand { display: inline-flex; align-items: center; color: inherit; }
  .brand:hover { text-decoration: none; }
  .brand__logo { width: 150px; height: auto; display: block; filter: brightness(0) invert(1); }

  /* ── Promo bar ──────────────────────────────────────────────── */
  .promo-bar {
    grid-column: 2;
    justify-self: center;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--c-ember);
    color: #fff;
    padding: 0.5rem 1.15rem;
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
    white-space: nowrap;
    max-width: min(100%, 480px);
  }
  .promo-bar:hover { background: var(--c-ember-bright); }
  .promo-bar__dot {
    display: block;
    flex-shrink: 0;
    width: 8px; height: 8px;
    min-width: 8px; min-height: 8px;
    border-radius: 50%;
    background: #fff;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  .promo-bar__text { transition: opacity 0.2s ease; }
  .promo-bar__ack {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    letter-spacing: 0.08em;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }
  .promo-bar.is-copied .promo-bar__text { opacity: 0; }
  .promo-bar.is-copied .promo-bar__ack { opacity: 1; }

  /* ── Desktop nav ────────────────────────────────────────────── */
  .site-nav > ul {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0; padding: 0;
  }
  .site-nav a,
  .site-nav button {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.55rem 0.9rem;
    color: var(--c-paper);
    font-family: var(--font-display);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1;
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .site-nav a:hover,
  .site-nav button:hover { color: var(--c-ember-bright); text-decoration: none; }

  .has-dropdown { position: relative; }
  .dropdown {
    position: absolute;
    top: 100%; right: 0;
    min-width: 220px;
    background: var(--c-ink-soft);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius);
    list-style: none;
    margin: 0; padding: 0.4rem;
    flex-direction: column;
    display: none;
    box-shadow: var(--shadow-lg);
  }
  .has-dropdown.is-open .dropdown { display: flex; }
  @media (hover: hover) and (min-width: 961px) {
    .has-dropdown:hover .dropdown,
    .has-dropdown:focus-within .dropdown { display: flex; }
    .has-dropdown:hover > button,
    .has-dropdown:focus-within > button { color: var(--c-ember-bright); }
  }
  .dropdown li { width: 100%; }
  .dropdown a { display: block; padding: 0.55rem 0.75rem; width: 100%; }

  /* ── Phone CTA ──────────────────────────────────────────────── */
  .phone-cta {
    display: inline-flex;
    flex-direction: column;
    line-height: 1.1;
    color: inherit;
    text-align: right;
    padding-left: 1rem;
    border-left: 1px solid rgba(255,255,255,0.15);
  }
  .phone-cta:hover { text-decoration: none; color: var(--c-ember-bright); }
  .phone-cta__label {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .phone-cta__number {
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.05em;
  }

  /* ── Hamburger ──────────────────────────────────────────────── */
  .nav-toggle {
    display: none;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 10px;
    width: 44px; height: 44px;
    padding: 0;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--c-paper);
    flex-shrink: 0;
    transition: background 0.15s ease;
  }
  .nav-toggle:hover { background: rgba(255,255,255,0.08); }

  /* ── Menu → hamburger at ≤1300px (phone + promo stay) ────────── */
  @media (max-width: 1300px) {
    .site-header__bar {
      grid-template-columns: auto 1fr auto auto;
    }
    .site-nav { display: none; }
    .nav-toggle {
      display: inline-flex;
      grid-column: 4;
      grid-row: 1;
    }
  }

  /* ── Promo to own row at ≤1100px ─────────────────────────────── */
  @media (max-width: 1100px) {
    .site-header__bar {
      row-gap: 0.6rem;
    }
    .phone-cta { grid-column: 3; grid-row: 1; }
    .promo-bar {
      grid-column: 1 / -1;
      grid-row: 2;
      justify-self: center;
      white-space: normal;
      text-align: center;
    }
  }

  /* ── Phone hides at ≤960px ───────────────────────────────────── */
  @media (max-width: 960px) {
    .site-header__bar {
      grid-template-columns: auto 1fr auto;
      padding: 0.85rem 1rem;
      gap: 0.75rem;
    }
    .phone-cta { display: none; }
    .nav-toggle {
      grid-column: 3;
      grid-row: 1;
    }
  }

  /* ── Promo full-bleed on mobile ──────────────────────────────── */
  @media (max-width: 640px) {
    .promo-bar {
      margin-inline: -2rem;
      width: calc(100% + 4rem);
      max-width: none;
      border-radius: 0;
      justify-content: center;
    }
  }

  /* ── Mobile nav overlay ─────────────────────────────────────── */
  .mobile-nav {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: var(--c-ink);
    color: var(--c-paper);
    overflow-y: auto;
    transform: translateX(100%);
    visibility: hidden;
    transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1), visibility 0s linear 0.38s;
  }
  .mobile-nav.is-open {
    transform: translateX(0);
    visibility: visible;
    transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1), visibility 0s linear;
  }
  .mobile-nav__inner {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.75rem 2.5rem;
  }
  .mobile-nav__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 0.25rem;
  }
  .mobile-nav__close {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    display: flex; align-items: center; justify-content: center;
    color: var(--c-paper);
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s ease;
  }
  .mobile-nav__close:hover { background: rgba(255,255,255,0.16); }

  .mobile-nav__links { flex: 1; }
  .mobile-nav__links > ul {
    list-style: none;
    margin: 0; padding: 0;
  }
  .mn-item { border-bottom: 1px solid rgba(255,255,255,0.07); }
  .mn-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1.1rem 0;
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--c-paper);
    text-decoration: none;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: color 0.15s ease;
  }
  .mn-link:hover { color: var(--c-ember); text-decoration: none; }
  .mn-chevron {
    transition: transform 0.25s ease;
    flex-shrink: 0;
    opacity: 0.55;
  }
  .mn-has-sub.is-open .mn-chevron { transform: rotate(180deg); }
  .mn-sub {
    list-style: none;
    margin: 0;
    padding: 0 0 0.75rem 0.75rem;
    display: none;
    flex-direction: column;
  }
  .mn-has-sub.is-open .mn-sub { display: flex; }
  .mn-sub-link {
    display: block;
    padding: 0.6rem 0;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(246,241,231,0.6);
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: color 0.15s ease;
  }
  .mn-sub-link:hover { color: var(--c-ember-bright); text-decoration: none; }

  .mobile-nav__foot {
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-top: auto;
  }
  .mobile-nav__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--c-ember-bright);
    text-decoration: none;
  }
  .mobile-nav__phone:hover { color: var(--c-ember-bright); text-decoration: underline; }
</style>
